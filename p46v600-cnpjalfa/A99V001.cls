                    "preenchido)."
        Exit Function
    End If
    
    If Not IsNumeric(pConta) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da conta do Banco Bancoob nï¿½o " & _
                    "numï¿½rico - " & pConta & ")."
        Exit Function
    End If

    iMultiplicador(0) = 10
    iMultiplicador(1) = 9
    iMultiplicador(2) = 8
    iMultiplicador(3) = 7
    iMultiplicador(4) = 6
    iMultiplicador(5) = 5
    iMultiplicador(6) = 4
    iMultiplicador(7) = 3
