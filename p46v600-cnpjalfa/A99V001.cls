Public Function DIG_SUDAMERIS(ByVal pAgencia As String, ByVal pConta As String, ByRef pDigito As String, _
                              ByRef pMensagem As String) As Boolean
'Funï¿½ï¿½o: calcula dï¿½gito mï¿½dulo 11 - conta corrente.

'Parï¿½metros de entrada...pAgencia....Cï¿½digo da agï¿½ncia.
'                        pConta......Nï¿½mero da conta.
'Parï¿½metros de saï¿½da.....pDigito.....Dï¿½gito calculado.
'                        pMensagem...Mensagem.

    Dim lAuxiliar As String    'Auxiliar...de 01 a 03 (03 posiï¿½ï¿½es)...Cï¿½digo do banco.
'           de 04 a 06 (03 posiï¿½ï¿½es)...Cï¿½digo da agï¿½ncia.
'           de 07 a 17 (11 posiï¿½ï¿½es)...Valor fixo.
'           de 18 a 26 (09 posiï¿½ï¿½es)...Nï¿½mero da conta.
    Dim lI As Byte    'Utilizado com For...Next.
    Dim lResto As Byte    'Resto.
    Dim lTabPesos As String    'Tabela de pesos.
    Dim lTotal As Double    'Total.

    DIG_SUDAMERIS = False

    '1. Verifica parï¿½metros de entrada.
    If Not M46V999.gfPreenchido(pAgencia) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da agï¿½ncia do Banco Sudameris nï¿½o " & _
                    "preenchido)."
        Exit Function
    End If

    If Not IsNumeric(pAgencia) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da agï¿½ncia do Banco Sudameris nï¿½o " & _
                    "numï¿½rico - " & pAgencia & ")."
        Exit Function
    End If

    If Len(pAgencia) <> 3 Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da agï¿½ncia do Banco Sudameris com " & _
                    "tamanho diferente de 3 posiï¿½ï¿½es - " & pAgencia & ")."
        Exit Function
    End If

    If Not M46V999.gfPreenchido(pConta) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (nï¿½mero da conta corrente do Banco " & _
                    "Sudameris nï¿½o preenchido)."
        Exit Function
    End If

    If Not IsNumeric(pConta) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (nï¿½mero da conta corrente do Banco " & _
                    "Sudameris nï¿½o numï¿½rico - " & pConta & ")."
        Exit Function
    End If

    If Len(pConta) <> 9 Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (nï¿½mero da conta corrente do Banco " & _
                    "Sudameris com tamanho diferente de 9 posiï¿½ï¿½es - " & pConta & ")."
        Exit Function
    End If

    '2. Posiciona controles.
    lAuxiliar = "347" & pAgencia & "10000000000" & pConta
    lTabPesos = "32987654329876543298765432"
    lTotal = 0

    '3. Aplica peso.
    For lI = 1 To 26
        lTotal = lTotal + (CByte(Mid$(lAuxiliar, lI, 1)) * CByte(Mid$(lTabPesos, lI, 1)))
    Next lI

    '4. Divide por 11 e obtï¿½m resto.
    lResto = lTotal Mod 11

    '5. Posiciona dï¿½gito.
    Select Case lResto
    Case 0
        pDigito = 1
    Case 1
        pDigito = 0
    Case Else
        pDigito = 11 - lResto
    End Select

    DIG_SUDAMERIS = True
End Function
