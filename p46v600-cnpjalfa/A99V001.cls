End Function

Public Function DIG_SAFRA(ByVal pAgencia As String, ByVal pConta As String, ByRef pDigito As String, _
                             ByRef pMensagem As String) As Boolean
                             
'*    M O D U L O   11  -  DEVE CONSIDERAR AGENCIA
'*     ALGORITIMO E REGRA OBTIDOS DO PROG MARITIMA RER01S160
'*     A CONTA SAFRA[422] TEM 6 DIGITOS + 1 DIG VERIFICADOR
'*     0140 015033-4 AGENCIA+CONTA+DIGITO 10 DIGITOS
'*     3298 765432 = MULTIPLICADOR SAFRA BYTE A BYTE
'*    ------------------------------------------------
'*    (0*3=0) + (1*2=2) + (4*9=36) + (0*8=0) +
'*    (0*7=0) + (1*6=6) + (5*5=25) + (0*4=0) +
'*    (3*3=9) + (3*2=6) = 84 MOD 11 = 7 | 11 - 7 = 4
'*    OU |84 / 11 = 7,63
'*       | 7 * 11 = 77    84 - 77 = 7
'*       |11 -  7 = 4 <<<<<DIGITO DA CONTA

'Contas para testar
'00021702012 - OK
'00190223898 - OK
'00305013505 - OK
'00540029572 - OK
'00830073205 - OK
'01158004106 - OK
'01260030269 - OK
'01470005643 - OK
'01540000483 - OK
'01970005669 - OK
                             
Dim iContadorFor As Integer
Dim iSoma As Integer
Dim iMultiplicador(10) As Integer
Dim iResto As Integer
Dim div11 As Integer
Dim mult11 As Integer
Dim sAgenciaConta As String

    
    '1. Verifica parï¿½metros de entrada.
    If Not M46V999.gfPreenchido(pAgencia) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da agï¿½ncia do Banco Safra nï¿½o " & _
                    "preenchido)."
        Exit Function
    End If
    
    If Not IsNumeric(pAgencia) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da agï¿½ncia do Banco Safra nï¿½o " & _
                    "numï¿½rico - " & pAgencia & ")."
        Exit Function
    End If
        
    If Not M46V999.gfPreenchido(pConta) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da conta do Banco Safra nï¿½o " & _
                    "preenchido)."
        Exit Function
    End If
    
    If Not IsNumeric(pConta) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da conta do Banco Safra nï¿½o " & _
                    "numï¿½rico - " & pConta & ")."
        Exit Function
    End If

    iMultiplicador(0) = 3
    iMultiplicador(1) = 2
    iMultiplicador(2) = 9
    iMultiplicador(3) = 8
    iMultiplicador(4) = 7
    iMultiplicador(5) = 6
    iMultiplicador(6) = 5
    iMultiplicador(7) = 4
    iMultiplicador(8) = 3
    iMultiplicador(9) = 2
                             
    DIG_SAFRA = False
    iSoma = 0
    iResto = 0
    pDigito = ""
    div11 = 0
    mult11 = 0
    sAgenciaConta = Replace(Format$(val(pAgencia), "0000") & Format$(val(pConta), "000000"), "-", "")

    For iContadorFor = 0 To 9
        iSoma = iSoma + iMultiplicador(iContadorFor) * Mid(sAgenciaConta, iContadorFor + 1, 1)
    Next

    div11 = iSoma Mod 11
                   
    If div11 = 1 Then
         pDigito = 0
    Else
        If div11 = 0 Then
        pDigito = 1
    Else
            pDigito = 11 - div11
        End If
    End If

    DIG_SAFRA = True

End Function

'Novo Convï¿½nio banco BRB
Public Function DIG_BANCOBRB(ByVal pAgencia As String, ByVal pConta As String, ByRef pDigito As String, _
                             ByRef pMensagem As String) As Boolean
    Dim lAuxiliar       As String
    Dim lI              As Integer
    Dim lResto          As String
    Dim lTotal          As Long
    Dim lMultiplicador  As Integer
    Dim sContaSemDigito As String
    
    DIG_BANCOBRB = False
    
    '1. Verifica parï¿½metros de entrada.
    If Not M46V999.gfPreenchido(pAgencia) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da agï¿½ncia do Banco Bancoob nï¿½o " & _
                    "preenchido)."
        Exit Function
    End If
    
    If Not IsNumeric(pAgencia) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da agï¿½ncia do Banco Bancoob nï¿½o " & _
                    "numï¿½rico - " & pAgencia & ")."
        Exit Function
    End If
        
    If Not M46V999.gfPreenchido(pConta) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da conta do Banco Bancoob nï¿½o " & _
                    "preenchido)."
        Exit Function
    End If
    
    If Not IsNumeric(pConta) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da conta do Banco Bancoob nï¿½o " & _
                    "numï¿½rico - " & pConta & ")."
        Exit Function
    End If
    
    ' Validaï¿½ï¿½o de conta do Banco BRB funciona da seguinte forma:
    ' Multiplicar cada nï¿½mero pela posiï¿½ï¿½o dele, da direita para a esquerda.
    ' A excessï¿½o ï¿½ a posiï¿½ï¿½o 10. Nesta posiï¿½ï¿½o, multiplicar o nï¿½mero por 2.
    ' Depois somar os produtos e obter o resto da divisï¿½o desta soma por 11.
    ' Se o resto for 0 ou 1, o digito ï¿½ 0, senï¿½o, o digito ï¿½ 11 - resto.
    
    ' Exemplo: Conta 167121301-4. Posiï¿½ï¿½o 1 = 4, Posiï¿½ï¿½o 2 = 1, Posiï¿½ï¿½o 3 = 0, Posiï¿½ï¿½o 4 = 3, Posiï¿½ï¿½o 5 = 1... E assim por diante.
    ' A primeira posiï¿½ï¿½o ï¿½ o dï¿½gito, entï¿½o descartar (afinal vocï¿½ estï¿½ calculando o dï¿½gito). Comeï¿½ar a partir da segunda posiï¿½ï¿½o.
    ' SomaDosProdutos = (2 * 1) + (3 * 0) + (4 * 3) + (5 * 1) + (6 * 2) + (7 * 1) + (8 * 7) + (9 * 6) + (2 * 1) => 150
    ' Resto = SomaDosProdutos Mod 11 => 150 Mod 11 => 7
    ' Digito = 11 - Resto => 11 - 7 => 4
    
    lMultiplicador = 2 ' Sempre comeï¿½a com 2
    lTotal = 0
    For lI = Len(pConta) To 1 Step -1 ' Loop para cada digito da direita para a esquerda
        If lMultiplicador = 10 Then lMultiplicador = 2
        lAuxiliar = Mid(sContaSemDigito, lI, 1)
        lTotal = lTotal + (val(lAuxiliar) * lMultiplicador)
        lMultiplicador = lMultiplicador + 1
    Next
    
    lResto = lTotal Mod 11
    
    If lResto = 0 Or lResto = 1 Then
        pDigito = 0
    Else
        pDigito = 11 - lResto
    End If
    
    DIG_BANCOBRB = True
End Function
