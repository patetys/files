                    "tamanho diferente de 4 posiï¿½ï¿½es - " & pAgencia & ")."
        Exit Function
    End If

    If Not M46V999.gfPreenchido(pConta) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (nï¿½mero da conta corrente do Banco Itaï¿½ nï¿½o " & _
                    "preenchido)."
        Exit Function
    End If

    If Not IsNumeric(pConta) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (nï¿½mero da conta corrente do Banco Itaï¿½ nï¿½o " & _
                    "numï¿½rico - " & pConta & ")."
        Exit Function
    End If

    If Len(pConta) <> 5 Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (nï¿½mero da conta corrente do Banco Itaï¿½ com " & _
                    "tamanho diferente de 5 posiï¿½ï¿½es - " & pConta & ")."
        Exit Function
    End If

    '2. Posiciona controles.
