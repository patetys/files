                    "preenchido)."
        Exit Function
    End If

    If Not IsNumeric(pConta) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da conta do Banco Banese nï¿½o " & _
                    "numï¿½rico - " & pConta & ")."
        Exit Function
    End If

    If Len(pAgencia) > 3 Then
        pAgencia = Right(pAgencia, 3)
    Else
        pAgencia = Format(pAgencia, "000")
    End If
    lAgenciaC = pAgencia
    Select Case pAgencia
