Public Function DIG_MODULO11(ByVal pCampo As String, ByVal pPesos As String, _
                             ByRef pDigito As Integer, ByRef pMensagem As String) As Boolean
'Funï¿½ï¿½o: calcula dï¿½gito utilizando peso fornecido e algorï¿½timo para mï¿½dulo 11.

'Parï¿½metros de entrada...pCampo......Campo a calcular dï¿½gito.
'                        pPesos......Pesos para efetuar cï¿½lculo.
'Parï¿½metros de saï¿½da.....pDigito.....Dï¿½gito calculado.
'                        pMensagem...Mensagem.

'Observaï¿½ï¿½o: para cada dï¿½gito de pCampo existirï¿½o dois em pPesos.
'Exemplo: se peso ï¿½ 1, 2, 3, 4, informar 01020304.

'Exemplos da funï¿½ï¿½o: DIG_MODULO11("098031208","100908070605040302") = 6.
'                    DIG_MODULO11("0980312086","01100908070605040302") = 7.
'Obs: aceita caracteres alfanumï¿½ricos (A-Z) em pCampo, conforme algoritmo de dï¿½gito verificador do
'     CNPJ alfanumï¿½rico da Receita Federal (valor do caracter = Asc(caracter) - 48).

'Se a posiï¿½ï¿½o do peso a ser aplicado ï¿½ igual a zero, o sistema nï¿½o considera a posiï¿½ï¿½o do campo a ser
'calculado dï¿½gito correspondente (mesmo que nï¿½o seja numï¿½rico).

    Dim lPosicao As Integer    'Posiï¿½ï¿½o.
    Dim lResto As Integer    'Resto.
    Dim lSoma As Integer    'Soma.
    Dim lTamCampo As Integer    'Tamanho do campo de entrada.
    Dim lTamPesos As Integer    'Tamanho do campo de pesos.
    Dim lCaracter As String    'Caracter sendo processado (suporta CNPJ alfanumï¿½rico).

    DIG_MODULO11 = False

    '1. Verifica se campos de entrada sï¿½o numï¿½ricos.
    If Not M46V999.gfPreenchido(pCampo) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (mï¿½dulo 11 - campo a ser calculado dï¿½gito " & _
                    "nï¿½o preenchido)."
        Exit Function
    End If

    If Not M46V999.gfPreenchido(pPesos) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (mï¿½dulo 11 - campo de pesos nï¿½o preenchido)."
        Exit Function
    End If

    If Not IsNumeric(pPesos) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (mï¿½dulo 11 - campo de pesos nï¿½o numï¿½rico)."
        Exit Function
    End If

    pCampo = Trim$(pCampo)
    pPesos = Trim$(pPesos)
    lTamCampo = Len(pCampo)
    lTamPesos = Len(pPesos)

    If lTamPesos < (lTamCampo * 2) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (mï¿½dulo 11 - campo de pesos (" & pPesos & _
                    ") incompatï¿½vel com campo a ser calculado dï¿½gito (" & pCampo & "))."
        Exit Function
    End If

    '2. Multiplica dï¿½gito pelo peso e acumula.
    lSoma = 0
    For lPosicao = 1 To Len(pCampo)
        lCaracter = UCase(Mid(pCampo, lPosicao, 1))
        If val(Mid(pPesos, 1 + ((lPosicao - 1) * 2), 2)) <> 0 Then
            If Not ((lCaracter >= "0" And lCaracter <= "9") Or (lCaracter >= "A" And lCaracter <= "Z")) Then
                pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (mï¿½dulo 11 - campo a ser calculado " & _
                            "dï¿½gito nï¿½o numï¿½rico/alfanumï¿½rico vï¿½lido - " & pCampo & ")."
                Exit Function
            End If
        End If
        'Valor do caracter = Asc(caracter) - 48 (idï¿½ntico ao valor numï¿½rico para '0'-'9'; para 'A'-'Z'
        'resulta em 17-42, conforme algoritmo de dï¿½gito verificador do CNPJ alfanumï¿½rico).
        lSoma = lSoma + ((Asc(lCaracter) - 48) * val(Mid(pPesos, 1 + ((lPosicao - 1) * 2), 2)))
    Next lPosicao

    '3. Retorno da funï¿½ï¿½o
    lResto = lSoma Mod 11
    Select Case lResto
    Case 0, 1       'Resto igual a zero ou um: dï¿½gito = zero.
        pDigito = 0
    Case Else       'Outro resto: dï¿½gito = diferenï¿½a entre 10 e resto da divisï¿½o.
        pDigito = 11 - (lResto)
    End Select

    DIG_MODULO11 = True
End Function
Public Function DIG_SEGSUL(ByVal pCampo As String, ByVal pPesos As String, _
