Public Function DIG_BLOQUETO(ByVal pBloqueto As String, ByRef pDigito As String, _
                             ByRef pMensagem As String) As Boolean
'Funï¿½ï¿½o: calcula dï¿½gito do bloqueto (copiado do programa P16C031).

'Parï¿½metro de entrada...pBloqueto...Campo com nï¿½mero do bloqueto.
'Parï¿½metros de saï¿½da....pDigito.....Dï¿½gito calculado.
'                       pMensagem...Mensagem.

    Dim lAuxiliar As String     'Auxiliar.
    Dim lPeso As String    'Peso.
    Dim lPosicao As Integer   'Posiï¿½ï¿½o.
    Dim lResto As Integer    'Resto.
    Dim lSoma As Integer    'Soma.

    DIG_BLOQUETO = False

    '1. Multiplica dï¿½gito pelo peso e acumula.
    lAuxiliar = Mid$(pBloqueto, 2, 7)
    lPeso = "9731973"
    lSoma = 0
    For lPosicao = 1 To 7
        lSoma = lSoma + val(Mid$(lAuxiliar, lPosicao, 1)) * val(Mid$(lPeso, lPosicao, 1))
    Next lPosicao
    lSoma = lSoma + 108
    lResto = lSoma Mod 10
    Select Case lResto
    Case 0
        pDigito = "0"
    Case Else
        pDigito = Format$(10 - lResto, "0")
    End Select

    DIG_BLOQUETO = True
End Function
Public Function DIG_BOSTON(ByVal pEntrada As String, ByRef pDigito As String, _
                           ByRef pMensagem As String) As Boolean
'Funï¿½ï¿½o: calcula dï¿½gito de conta do Banco de Boston.

'Parï¿½metro de entrada...pEntrada....Campo a ser calculado dï¿½gito verificador.
'Parï¿½metros de saï¿½da....pDigito.....Dï¿½gito calculado.
'                       pMensagem...Mensagem.

    Dim lAuxiliar As String    'Auxiliar.
    Dim lI As Byte    'Utilizado com For...Next.
    Dim lResto As Byte    'Resto.
    Dim lTabPesos As String    'Tabela de pesos.
    Dim lTotal As Double    'Total.

    DIG_BOSTON = False

    '1. Verifica parï¿½metro de entrada.
    If Not M46V999.gfPreenchido(pEntrada) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (nï¿½mero da conta corrente do Banco de " & _
                    "Boston nï¿½o preenchido)."
        Exit Function
    End If

    If Not IsNumeric(pEntrada) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (nï¿½mero da conta corrente do Banco de " & _
                    "Boston nï¿½o numï¿½rico - " & pEntrada & ")."
        Exit Function
    End If

    If Len(pEntrada) <> 7 Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (nï¿½mero da conta corrente do Banco de " & _
                    "Boston com tamanho diferente de 7 posiï¿½ï¿½es - " & pEntrada & ")."
        Exit Function
    End If

    '2. Posiciona controles.
    lAuxiliar = Trim$(pEntrada)
    lTabPesos = "4758243"
    lTotal = 0

    '3. Aplica peso.
    For lI = 1 To 7
        lTotal = lTotal + (CByte(Mid$(lAuxiliar, lI, 1)) * CByte(Mid$(lTabPesos, lI, 1)))
    Next lI

    '4. Divide por 11 e obtï¿½m resto.
    lResto = lTotal Mod 11

    '5. Posiciona dï¿½gito.
    Select Case lResto
    Case 0, 1
        pDigito = 0
    Case Else
        pDigito = 11 - lResto
    End Select

    DIG_BOSTON = True
End Function
Public Function DIG_BRADESCO(ByVal pEntrada As String, ByRef pDigito As String, _
                             ByRef pMensagem As String) As Boolean
'Funï¿½ï¿½o: calcula dï¿½gito mï¿½dulo 11 - BRADESCO.

'Parï¿½metro de entrada...pEntrada....Nï¿½mero a ser calculado dï¿½gito verificador (agï¿½ncia ou conta).
'Parï¿½metros de saï¿½da....pDigito.....Dï¿½gito calculado.
'                       pMensagem...Mensagem.

    Dim lAuxCalculo As Byte         'Auxiliar de cï¿½lculo.
    Dim lAuxiliar As String     'Auxiliar.
    Dim lI As Byte    'Utilizado com For...Next.
    Dim lPeso As Byte   'Peso.
    Dim lPosicao As Byte      'Posiï¿½ï¿½o.
    Dim lResto As Byte    'Resto.
    Dim lTabPesos As String     'Tabela de pesos.
    Dim lTamanho As Byte      'Tamanho do campo.
    Dim lTotal As Double  'Total.

    DIG_BRADESCO = False

    '1. Verifica parï¿½metro de entrada.
    If Not M46V999.gfPreenchido(pEntrada) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da agï¿½ncia ou nï¿½mero da conta " & _
                    "corrente do Banco Bradesco nï¿½o preenchido)."
        Exit Function
    End If

    If Not IsNumeric(pEntrada) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da agï¿½ncia ou nï¿½mero da conta " & _
                    "corrente do Banco Bradesco nï¿½o numï¿½rico - " & pEntrada & ")."
        Exit Function
    End If

    '2. Posiciona controle.
    lAuxiliar = Trim$(pEntrada)
    lTamanho = Len(lAuxiliar)
    lTabPesos = "234567"
    lTotal = 0

    '3. Aplica peso.
    For lI = 1 To lTamanho
        lAuxCalculo = CByte(Mid(lAuxiliar, lTamanho - lI + 1, 1))
        If lI > 6 Then
            lPosicao = lI Mod 6
        Else
            lPosicao = lI
        End If
        lPeso = CByte(Mid(lTabPesos, lPosicao, 1))
        lTotal = lTotal + (lAuxCalculo * lPeso)
    Next lI

    '4. Multiplica resultado por 10, divide por 11 e obtï¿½m resto.
    lTotal = lTotal * 10
    lResto = lTotal Mod 11
    If lResto = 10 Then
        lResto = 0
    End If

    '5. Posiciona dï¿½gito.
    pDigito = lResto

    DIG_BRADESCO = True
End Function
Public Function DIG_CNPJ(ByVal pCNPJ As String, ByRef pDigito As String, ByRef pMensagem As String) _
       As Boolean
'Funï¿½ï¿½o: calcula dï¿½gito do CNPJ (cï¿½pia da funï¿½ï¿½o QSf_iCGC).

'Parï¿½metro de entrada...pCNPJ.......Campo com CNPJ.
'Parï¿½metros de saï¿½da....pDigito.....Dï¿½gito calculado.
'                       pMensagem...Mensagem.

    Dim lAuxiliar As String    'Auxiliar.
    Dim lDigCalculado As Integer    'Dï¿½gito calculado.
    Dim lDigInformado As String    'Dï¿½gito informado.
    Dim lPeso As String    'Peso.

    DIG_CNPJ = False

    '1. Verifica CNPJ.
    pCNPJ = Trim$(pCNPJ)
    Select Case Left$(pCNPJ, 10)
    Case "12.345.678", "11.111.111", "22.222.222", "33.333.333", "44.444.444", _
         "55.555.555", "66.666.666", "77.777.777", "88.888.888", "99.999.999"
        pMensagem = "FGE0054 - CNPJ invï¿½lido: " & pCNPJ & "."
        Exit Function
    End Select

    '2. Posiciona campos.
    lAuxiliar = Left(pCNPJ, 16)
    lDigInformado = Right$(pCNPJ, 2)

    '3. Calcula primeiro dï¿½gito do CNPJ.
    lPeso = "05040003020900080706000504030200"
    If DIG_MODULO11(lAuxiliar, lPeso, lDigCalculado, pMensagem) = False Then
        Exit Function
    End If
    lAuxiliar = lAuxiliar & Format(lDigCalculado, "0")

    '4. Calcula segundo dï¿½gito do CNPJ.
    lPeso = "0605000403020009080700060504030002"
    If DIG_MODULO11(lAuxiliar, lPeso, lDigCalculado, pMensagem) = False Then
        Exit Function
    End If
    lAuxiliar = lAuxiliar & Format(lDigCalculado, "0")

    '5. Posiciona dï¿½gito do CNPJ.
    pDigito = Right$(lAuxiliar, 2)

    '6. Verifica dï¿½gito.
    If pDigito <> lDigInformado Then
        pMensagem = "FGE0055 - CNPJ com dï¿½gito invï¿½lido: " & pCNPJ & "."
        Exit Function
    End If

    DIG_CNPJ = True
End Function

Public Function DIG_CodIdeApolice(ByVal pCodIdeApolice As String, ByRef pNumApolice As String, _
                                  ByRef pNumItem As String, ByRef pDigito As String, _
                                  ByRef pMensagem As String) As Boolean
'Funï¿½ï¿½o: calcula dï¿½gito do cï¿½digo de identificaï¿½ï¿½o da apï¿½lice.

'Parï¿½metro de entrada...pCodIdeApolice...Cï¿½digo de identificaï¿½ï¿½o da apï¿½lice
'Parï¿½metros de saï¿½da....pNumApolice......Nï¿½mero da apï¿½lice.
'                       pNumItem.........Nï¿½mero do item.
'                       pDigito..........Dï¿½gito calculado.
'                       pMensagem........Mensagem.

    Dim lAuxiliar As String    'Auxiliar.
    Dim lCaracter As String    'Caracter.
    Dim lCodSeguradora As String  'Cï¿½digo da seguradora.
    Dim lI As Integer             'Utilizado com For...Next.
    Dim lParcela As Integer    'Valor da parcela.
    Dim lPosicao As Byte    'Utilizado com InStr.
    Dim lTotal As Integer    'Total.
    Dim lPeso As Integer    'Peso a ser multiplicado.
    Dim lResto As Integer    'Resto da divisï¿½o do mï¿½dulo 11.

    DIG_CodIdeApolice = False

    '1. Verifica campo de entrada - preenchimento e tamanho.
    If Not M46V999.gfPreenchido(pCodIdeApolice) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo de identificaï¿½ï¿½o da apï¿½lice nï¿½o " & _
                    "preenchido)."
        Exit Function
    End If
    lAuxiliar = Trim$(pCodIdeApolice)
    Do
        lPosicao = InStr(lAuxiliar, " ")
        If lPosicao = 0 Then
            Exit Do
        End If
        lAuxiliar = Left$(lAuxiliar, lPosicao - 1) & Mid$(lAuxiliar, lPosicao + 1)
    Loop
    If Len(lAuxiliar) <> 14 Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo de identificaï¿½ï¿½o da apï¿½lice com " & _
                    "tamanho diferente de 14 posiï¿½ï¿½es - " & pCodIdeApolice & ")."
        Exit Function
    End If

    '2. Verifica cï¿½digo de identificaï¿½ï¿½o da apï¿½lice - cï¿½digo da seguradora.
    lCodSeguradora = Left$(lAuxiliar, 3)
    If Not IsNumeric(lCodSeguradora) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo de identificaï¿½ï¿½o da apï¿½lice com " & _
                    "cï¿½digo da seguradora nï¿½o numï¿½rico - " & pCodIdeApolice & ")."
        Exit Function
    End If
    If val(lCodSeguradora) = 0 Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo de identificaï¿½ï¿½o da apï¿½lice com " & _
                    "cï¿½digo da seguradora zerado - " & pCodIdeApolice & ")."
        Exit Function
    End If

    '3. Calcula dï¿½gito novo (Mï¿½dulo 11).
    'a) Inicializa campo de total.
    lTotal = 0
    lPeso = 6

    'b) Para cada caracter, obtï¿½m valor da parcela (cï¿½digo ASCII), multiplica pelo nï¿½mero de ordem e acumula.

    For lI = 1 To 13
        lCaracter = UCase$(Mid$(lAuxiliar, lI, 1))
        Select Case lCaracter
        Case "0"
            lParcela = 48
        Case "1"
            lParcela = 49
        Case "2"
            lParcela = 50
        Case "3"
            lParcela = 51
        Case "4"
            lParcela = 52
        Case "5"
            lParcela = 53
        Case "6"
            lParcela = 54
        Case "7"
            lParcela = 55
        Case "8"
            lParcela = 56
        Case "9"
            lParcela = 57
        Case "A"
            lParcela = 65
        Case "B"
            lParcela = 66
        Case "C"
            lParcela = 67
        Case "D"
            lParcela = 68
        Case "E"
            lParcela = 69
        Case "F"
            lParcela = 70
        Case "G"
            lParcela = 71
        Case "H"
            lParcela = 72
        Case "I"
            lParcela = 73
        Case "J"
            lParcela = 74
        Case "K"
            lParcela = 75
        Case "L"
            lParcela = 76
        Case "M"
            lParcela = 77
        Case "N"
            lParcela = 78
        Case "O"
            lParcela = 79
        Case "P"
            lParcela = 80
        Case "Q"
            lParcela = 81
        Case "R"
            lParcela = 82
        Case "S"
            lParcela = 83
        Case "T"
            lParcela = 84
        Case "U"
            lParcela = 85
        Case "V"
            lParcela = 86
        Case "W"
            lParcela = 87
        Case "X"
            lParcela = 88
        Case "Y"
            lParcela = 89
        Case "Z"
            lParcela = 90
        Case Else
            pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo de identificaï¿½ï¿½o da apï¿½lice " & _
                        "com caracter (" & lCaracter & ") invï¿½lido - " & pCodIdeApolice & ")."
            Exit Function
        End Select
        lTotal = lTotal + (lParcela * lPeso)
        lPeso = lPeso - 1
        If lPeso = 1 Then
            lPeso = 9
        End If
    Next lI

    lResto = lTotal Mod 11

    Select Case lResto
    Case 0, 1       'Resto igual a zero ou um: dï¿½gito = zero.
        pDigito = 0
    Case Else       'Outro resto: dï¿½gito = diferenï¿½a entre 10 e resto da divisï¿½o.
        pDigito = 11 - (lResto)
    End Select

    If pDigito = Mid$(lAuxiliar, 14, 1) Then
        DIG_CodIdeApolice = True
        Exit Function
    End If

    '4. Calcula dï¿½gito velho.
    'a) Inicializa campo de total e parcela.
    lTotal = 0
    lParcela = 0
    'b) Para cada caracter, obtï¿½m valor da parcela (cï¿½digo ASCII), multiplica pelo nï¿½mero de ordem e
    '   acumula.
    For lI = 1 To 13
        lCaracter = UCase$(Mid$(lAuxiliar, lI, 1))
        Select Case lCaracter
        Case "0"
            lParcela = 48
        Case "1"
            lParcela = 49
        Case "2"
            lParcela = 50
        Case "3"
            lParcela = 51
        Case "4"
            lParcela = 52
        Case "5"
            lParcela = 53
        Case "6"
            lParcela = 54
        Case "7"
            lParcela = 55
        Case "8"
            lParcela = 56
        Case "9"
            lParcela = 57
        Case "A"
            lParcela = 65
        Case "B"
            lParcela = 66
        Case "C"
            lParcela = 67
        Case "D"
            lParcela = 68
        Case "E"
            lParcela = 69
        Case "F"
            lParcela = 70
        Case "G"
            lParcela = 71
        Case "H"
            lParcela = 72
        Case "I"
            lParcela = 73
        Case "J"
            lParcela = 74
        Case "K"
            lParcela = 75
        Case "L"
            lParcela = 76
        Case "M"
            lParcela = 77
        Case "N"
            lParcela = 78
        Case "O"
            lParcela = 79
        Case "P"
            lParcela = 80
        Case "Q"
            lParcela = 81
        Case "R"
            lParcela = 82
        Case "S"
            lParcela = 83
        Case "T"
            lParcela = 84
        Case "U"
            lParcela = 85
        Case "V"
            lParcela = 86
        Case "W"
            lParcela = 87
        Case "X"
            lParcela = 88
        Case "Y"
            lParcela = 89
        Case "Z"
            lParcela = 90
        Case Else
            pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo de identificaï¿½ï¿½o da apï¿½lice " & _
                        "com caracter (" & lCaracter & ") invï¿½lido - " & pCodIdeApolice & ")."
            Exit Function
        End Select
        lTotal = lTotal + (lParcela * lI)
    Next lI
    'c) Se valor acumulado > 10, soma caracter a caracter do valor acumulado atï¿½ chegar num valor menor
    '   que 10.
    Do
        If lTotal < 10 Then
            Exit Do
        End If
        lAuxiliar = lTotal
        lTotal = 0
        For lI = 1 To Len(lAuxiliar)
            lTotal = lTotal + val(Mid$(lAuxiliar, lI, 1))
        Next lI
    Loop
    'd) Posiciona valor do dï¿½gito.
    pDigito = lTotal

    '5. Obtï¿½m nï¿½mero de apï¿½lice e nï¿½mero do item (apenas para seguradora 641 - Yasuda).
    'a) Inicializa campos.
    pNumApolice = "0000000000"
    pNumItem = "0000"
    'b) Se seguradora diferente de 641, encerra processo.
    If val(lCodSeguradora) <> 641 Then
        DIG_CodIdeApolice = True
        Exit Function
    End If
    'c) Posiciona nï¿½mero da apï¿½lice e nï¿½mero do item.
    If IsNumeric(Mid$(pCodIdeApolice, 4, 1)) Then
        If val(Mid$(pCodIdeApolice, 4, 6)) > 980000 Then
            pNumApolice = "0032" & Mid$(pCodIdeApolice, 4, 6)
        Else
            pNumApolice = "0031" & Mid$(pCodIdeApolice, 4, 6)
        End If
        pNumItem = Mid$(pCodIdeApolice, 10, 4)
    Else
        Select Case Mid$(pCodIdeApolice, 4, 1)
        Case "A"
            pNumApolice = "40310" & Mid$(pCodIdeApolice, 5, 5)
            pNumItem = Mid$(pCodIdeApolice, 10, 4)
        Case "B"
            pNumApolice = "40311" & Mid$(pCodIdeApolice, 5, 5)
            pNumItem = Mid$(pCodIdeApolice, 10, 4)
        Case "C"
            pNumApolice = "40312" & Mid$(pCodIdeApolice, 5, 5)
            pNumItem = Mid$(pCodIdeApolice, 10, 4)
        Case "X"
            pNumApolice = "50310" & Mid$(pCodIdeApolice, 5, 5)
            pNumItem = Mid$(pCodIdeApolice, 10, 4)
        Case "Y"
            pNumApolice = "50311" & Mid$(pCodIdeApolice, 5, 5)
            pNumItem = Mid$(pCodIdeApolice, 10, 4)
        Case "Z"
            pNumApolice = "50312" & Mid$(pCodIdeApolice, 5, 5)
            pNumItem = Mid$(pCodIdeApolice, 10, 4)
        End Select
    End If

    DIG_CodIdeApolice = True

End Function
Public Function DIG_CPF(ByVal pCPF As String, ByRef pDigito As String, ByRef pMensagem As String) _
       As Boolean
'Funï¿½ï¿½o: calcula dï¿½gito do CPF (cï¿½pia da funï¿½ï¿½o QSf-iCPF).

'Parï¿½metro de entrada...pCPF........Campo com CPF no formato numï¿½rico.
'Parï¿½metros de saï¿½da....pDigito.....Dï¿½gito calculado.
'                       pMensagem...Mensagem.

    Dim lAuxiliar As String    'Auxiliar.
    Dim lDigCalculado As Integer    'Dï¿½gito calculado.
    Dim lDigInformado As String    'Dï¿½gito informado.
    Dim lPeso As String    'Peso.

    DIG_CPF = False

    '1. Verifica CPF.
    pCPF = Trim$(pCPF)
    Select Case Left$(pCPF, 11)
    Case "123.456.789", "111.111.111", "222.222.222", "333.333.333", "444.444.444", _
         "555.555.555", "666.666.666", "777.777.777", "888.888.888", "999.999.999"
        pMensagem = "FGE0052 - CPF invï¿½lido: " & pCPF & "."
        Exit Function
    End Select

    '2. Posiciona campos auxiliar.
    lAuxiliar = Left(pCPF, 12)
    lDigInformado = Right$(pCPF, 2)

    '3. Calcula primeiro dï¿½gito do CPF.
    lPeso = "100908000706050004030200"
    If DIG_MODULO11(lAuxiliar, lPeso, lDigCalculado, pMensagem) = False Then
        Exit Function
    End If
    lAuxiliar = lAuxiliar & Format(lDigCalculado, "0")

    '4. Calcula segundo dï¿½gito do CPF.
    lPeso = "11100900080706000504030002"
    If DIG_MODULO11(lAuxiliar, lPeso, lDigCalculado, pMensagem) = False Then
        Exit Function
    End If
    lAuxiliar = lAuxiliar & Format(lDigCalculado, "0")

    '5. Posiciona dï¿½gito do CPF.
    pDigito = Right$(lAuxiliar, 2)

    '6. Verifica dï¿½gito.
    If pDigito <> lDigInformado Then
        pMensagem = "FGE0053 - CPF com dï¿½gito invï¿½lido: " & pCPF & "."
        Exit Function
    End If

    DIG_CPF = True
End Function
Public Function DIG_ITAU(ByVal pAgencia As String, ByVal pConta As String, ByRef pDigito As String, _
                         ByRef pMensagem As String) As Boolean
'Funï¿½ï¿½o: calcula dï¿½gito mï¿½dulo 10 - Itaï¿½.

'Parï¿½metros de entrada...pAgencia....Cï¿½digo da agï¿½ncia.
'                        pConta......Nï¿½mero da conta corrente.
'Parï¿½metros de saï¿½da.....pDigito.....Dï¿½gito calculado.
'                        pMensagem...Mensagem.

    Dim lAuxiliar As String     'Auxiliar.
    Dim lI As Byte    'Utilizado com For...Next.
    Dim lResto As Byte    'Resto.
    Dim lResultado As String      'Resultado.
    Dim lTabPesos As String     'Tabela de pesos.
    Dim lTotal As Double  'Total.

    DIG_ITAU = False

    '1. Verifica se parï¿½metros de entrada estï¿½o preenchidos e vï¿½lidos.
    If Not M46V999.gfPreenchido(pAgencia) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da agï¿½ncia do Banco Itaï¿½ nï¿½o " & _
                    "preenchido)."
        Exit Function
    End If

    If Not IsNumeric(pAgencia) Then
