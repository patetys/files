Public Function DIG_UNIBANCO(ByVal pAgencia As String, ByVal pConta As String, ByRef pDigito As String, _
                             ByRef pMensagem As String) As Boolean
'Funï¿½ï¿½o: calcula dï¿½gito mï¿½dulo 10 - Unibanco.

'Parï¿½metros de entrada...pAgencia....Cï¿½digo da agï¿½ncia.
'                        pConta......Nï¿½mero da conta.
'Parï¿½metros de saï¿½da.....pDigito.....Dï¿½gito calculado.
'                        pMensagem...Mensagem.

'Exemplo para Banco Unibanco:
'
'3   9   8   1   0   3   5  1  4    ===>>> Agï¿½ncia 3 posiï¿½ï¿½es e conta 6 posiï¿½ï¿½es.
'2   1   2   1   2   1   2  1  2    ===>>> Seqï¿½ï¿½ncia de 2 e 1.
'6   9  16   1   0   3  10  1  8    ===>>> Total da multiplicaï¿½ï¿½o.
'
'Para consistir todos os nï¿½meros alteradas a seqï¿½ï¿½ncia de 2 e 1.
'
'0  3   9   8   0  1   0   3   5  1  4  ===>>> Agï¿½ncia 4 posiï¿½ï¿½es e conta 7 posiï¿½ï¿½es.
'   2   1   2      1   2   1   2  1  2  ===>>> Seqï¿½ï¿½ncia de 2 e 1.
'   6   9  16      1   0   3  10  1  8  ===>>> Total da multiplicaï¿½ï¿½o.

    Dim lI As Byte    'Utilizado com For...Next.
    Dim lResto As Byte    'Resto.
    Dim lResultado As String  'Resultado.
    Dim lTabPesos As String    'Tabela de pesos.
    Dim lTotal As Double    'Total.

    DIG_UNIBANCO = False

    '1. Verifica se parï¿½metros de entrada estï¿½o preenchidos e vï¿½lidos.
    If Not M46V999.gfPreenchido(pAgencia) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da agï¿½ncia do Unibanco nï¿½o preenchido)."
        Exit Function
    End If

    If Not IsNumeric(pAgencia) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da agï¿½ncia do Unibanco nï¿½o numï¿½rico " & _
                    "- " & pAgencia & ")."
        Exit Function
    End If

    If Len(pAgencia) <> 4 Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (cï¿½digo da agï¿½ncia do Unibanco com tamanho " & _
                    "diferente de 4 posiï¿½ï¿½es - " & pAgencia & ")."
        Exit Function
    End If

    If Not M46V999.gfPreenchido(pConta) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (nï¿½mero da conta corrente do Unibanco nï¿½o " & _
                    "preenchido)."
        Exit Function
    End If

    If Not IsNumeric(pConta) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (nï¿½mero da conta corrente do Unibanco nï¿½o " & _
                    "numï¿½rico - " & pConta & ")."
        Exit Function
    End If

    If Len(pConta) <> 6 Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (nï¿½mero da conta corrente do Unibanco com " & _
                    "tamanho diferente de 6 posiï¿½ï¿½es - " & pConta & ")."
        Exit Function
    End If

    '2. Posiciona controles.
    lTabPesos = "1212121212121"
    lTotal = 0

    '3. Aplica peso.
    'a) Para agï¿½ncia.
    For lI = 1 To 4
        lResultado = Format$(CByte(Mid(pAgencia, lI, 1)) * CByte(Mid(lTabPesos, lI, 1)), "00")
        lTotal = lTotal + CByte(Mid(lResultado, 1, 1)) + CByte(Mid(lResultado, 2, 1))
    Next lI
    'b) Para conta.
    For lI = 1 To 6
        lResultado = Format$(CByte(Mid(pConta, lI, 1)) * CByte(Mid(lTabPesos, lI, 1)), "00")
        lTotal = lTotal + CByte(Mid(lResultado, 1, 1)) + CByte(Mid(lResultado, 2, 1))
    Next lI

    '4. Divide por 10 e obtï¿½m resto.
    lResto = lTotal Mod 10

    '5. Posiciona dï¿½gito.
    Select Case lResto
    Case 0
        pDigito = 0
    Case Else
        pDigito = 10 - lResto
    End Select

    DIG_UNIBANCO = True
End Function
Public Function DIG_YASUDA(ByVal pEntrada As String, ByRef pDigito As String, _
                           ByRef pMensagem As String) As Boolean
'Funï¿½ï¿½o: calcula dï¿½gito mï¿½dulo 11 - Yasuda.

'Parï¿½metro de entrada...pEntrada.....Nï¿½mero a ser calculado dï¿½gito verificador.
'Parï¿½metros de saï¿½da....pDigito.....Dï¿½gito calculado.
'                       pMensagem...Mensagem.

    Dim lAuxCalculo As Byte     'Auxiliar de cï¿½lculo.
    Dim lAuxiliar As String    'Auxiliar.
    Dim lI As Byte    'Utilizado com For...Next.
    Dim lPeso As Byte    'Peso.
    Dim lPosicao As Byte  'Posiï¿½ï¿½o.
    Dim lResto As Byte    'Resto.
    Dim lResultado As String  'Resultado.
    Dim lTamanho As Byte  'Tamanho do campo.
    Dim lTabPesos As String    'Tabela de pesos.
    Dim lTotal As Double    'Total.

    DIG_YASUDA = False

    '1. Verifica se parï¿½metros de entrada estï¿½o preenchidos e vï¿½lidos.
    If Not M46V999.gfPreenchido(pEntrada) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (nï¿½mero da Yasuda nï¿½o preenchido)."
        Exit Function
    End If
    If Not IsNumeric(pEntrada) Then
        pMensagem = "FTE0047 - Erro no cï¿½lculo de dï¿½gito (nï¿½mero da Yasuda nï¿½o nï¿½o numï¿½rico - " & _
                    pEntrada & ")."
        Exit Function
    End If

    '2. Posiciona controle.
    lAuxiliar = Trim$(pEntrada)
    lTamanho = Len(lAuxiliar)
    lTabPesos = "234567"
    lTotal = 0

    '3. Aplica pesos.
    For lI = 1 To lTamanho
        lAuxCalculo = CByte(Mid(lAuxiliar, lTamanho - lI + 1, 1))
        If lI > 6 Then
            lPosicao = lI Mod 6
        Else
            lPosicao = lI
        End If
        lPeso = CByte(Mid(lTabPesos, lPosicao, 1))
        lResultado = Format$(lAuxCalculo * lPeso, "00")
        lTotal = lTotal + CByte(Mid(lResultado, 1, 1)) + CByte(Mid(lResultado, 2, 1))
    Next lI

    '4. Divide resultado por 11 e obtï¿½m resto.
    lResto = lTotal Mod 11

    '5. Posiciona dï¿½gito.
    Select Case lResto
    Case 0
        pDigito = "A"
    Case 1
        pDigito = "0"
    Case Else
        pDigito = Format$(11 - lResto, "0")
    End Select

    DIG_YASUDA = True
End Function

