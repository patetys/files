                        .Cod_Ramo = objstcPedido.Cod_Ramo
                        .Num_Ped = objstcPedido.Num_Ped
                        .NUM_PI = gM46V111.gNum_Pi
                        Set .ObjPai = objstcPedLoc
                    End With
                    If lobjstcPedFator.Cod_Ramo <> e_CodRamo_Residencial And lobjstcPedFator.Cod_Fator <> 7 Then
                        If lObjPedFator.mfIncluir(lobjstcPedFator, "", "", "") Then
                            objstcPedLoc.ColecaoPedFator.Add lobjstcPedFator, lobjstcPedFator.Class_ID
                        End If
                    End If
                End If
            Next
        End If
    End If

FimFalse:
    mfSalvarFatoresProtecao = True
Finalizar:
    Set lobjstcPedFator = Nothing
    Set lObjPedFator = Nothing
    Exit Function
ControleErro:
    Set lobjstcPedFator = Nothing
    Set lObjPedFator = Nothing
    If gM46V999.gfPreenchido(pMensagem) = False Then
        pMensagem = Err.Description
    End If
    Call gM46V999.gpGraLog(0, "mfSalvarFatoresProtecao ERRO - " & Err & " " & ERROR & _
                              Chr(13) & pMensagem)

End Function

