Private Function mfConsTotBens(ByVal pValLMG As Double, ByVal pCodCobert As Long, pobjstcLoc As stcA46V708B)
    Dim pValBens As Double
    Dim lI As Integer    'Utilizado no for...loop.
    Dim lObjstcBens As stcA46V715B

    'Verificar se a soma dos Bens � igual ao LMG - para plano All Risks
    pValBens = 0

    If gM46V999.gCodProduto >= 947 And gM46V999.gCod_Ramo = e_CodRamo_Roubos Then


        For Each lObjstcBens In pobjstcLoc.ColecaoPedLocBem
            pValBens = pValBens + lObjstcBens.Val_Bem
        Next lObjstcBens

        'Ficha 1000308 - Permitir itens com planos diferentes no produto Roubo (c�lculo coletivo)
        If pobjstcLoc.Cod_Plano = 1 Then
            If pValBens <> pValLMG Then
                Screen.MousePointer = vbDefault
                Call gM46V999.gpMenErro("FNP0074 - " & gM46V999.gPrefixo & "Somat�ria dos bens deve ser igual ao LMI.")
                Exit Function
            End If
        Else
            If pValBens > pValLMG Then
                Screen.MousePointer = vbDefault
                Call gM46V999.gpMenErro("FNP0074 - " & gM46V999.gPrefixo & "Somat�ria dos bens n�o deve ser maior que o LMI total.")
                Exit Function
            End If
        End If

    End If

    If gM46V999.gCodProduto >= 999 And (gM46V999.gCod_Ramo = e_CodRamo_Empresarial Or gM46V999.gCod_Ramo = e_CodRamo_Residencial) And gM46V111.gCod_plano = 1 Then

        For Each lObjstcBens In pobjstcLoc.ColecaoPedLocBem
            pValBens = pValBens + lObjstcBens.Val_Bem
        Next lObjstcBens

        If Trim(pValBens) <> Trim(pValLMG) Then
            Screen.MousePointer = vbDefault
            Call gM46V999.gpMenErro("FNP0074 - " & gM46V999.gPrefixo & "O somat�rio dos valores da rela��o de bens deve ser igual ao LMI da cobertura " & pCodCobert & ".")
            Exit Function
        End If

    End If

    mfConsTotBens = True
    Exit Function

ControleErro:
    mfConsTotBens = False

End Function

Private Sub mpInformarErro(pTexto As String, pStatus As Byte, pDeslocado As Boolean)
    Dim lPos As Long  'Posi��o de caracter.
    Dim lTamanho As Long      'Tamanho.
    Dim lAuxiliar As String     'Auxiliar.

    If pDeslocado = True Then
        lPos = 1
        lTamanho = 105
        Do
            Do
                lAuxiliar = Mid(" - " & pTexto, lPos, lTamanho)

                If Right(lAuxiliar, 1) <> " " And Len(lAuxiliar) = lTamanho Then
                    lTamanho = lTamanho - 1
                Else
                    Exit Do
                End If
            Loop

            If gM46V999.gfPreenchido(lAuxiliar) Then
                lPos = lPos + lTamanho
                lTamanho = 105
                frmT46V136A.flxMensagens.row = mLinha
                frmT46V136A.flxMensagens.Col = 0
                mLinha = mLinha + 1
                frmT46V136A.flxMensagens.AddItem "", mLinha
                frmT46V136A.flxMensagens.TextMatrix(mLinha, 1) = Space(10) & lAuxiliar
            Else
                Exit Do
            End If
        Loop

        mQtdErros = mQtdErros + 1
    Else
        mLinha = mLinha + 1

        frmT46V136A.flxMensagens.Col = 0
        frmT46V136A.flxMensagens.row = mLinha
        frmT46V136A.flxMensagens.CellPictureAlignment = 4

    End If

End Sub


