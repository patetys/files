            Call gM46V999.gpGraLog(1, pMensagem)
            GoTo ControleErro
        End If
    End If
    
    'Ajuste inclus�o texto circular 491
    If Not gM46V103.mfAdicionaTextoEspecificacao(6110, lobjTextoEspec, objstcPedido, "", pMensagem, "") Then
        Call gM46V999.gpGraLog(1, pMensagem)
        GoTo ControleErro
    End If
    
    If objstcPedido.objstcCtrlEmis.Ind_Cond_Constituido = 1 And objstcPedido.Cod_Produto >= 1100 Then
        If Not gM46V103.mfAdicionaTextoEspecificacao(8730, lobjTextoEspec, objstcPedido, "", pMensagem, "") Then
            Call gM46V999.gpGraLog(1, pMensagem)
            GoTo ControleErro
        End If
    End If

    mfSalvarTextoEspecPadrao = True
Finalizar:
    Set lobjTextoEspec = Nothing
    Exit Function
    Resume 0
ControleErro:
    Set lobjTextoEspec = Nothing
    If gM46V999.gfPreenchido(pMensagem) = False Then
        pMensagem = Err.Description
    End If
    Call gM46V999.gpGraLog(0, "mfSalvarTextoEspecifica��o ERRO - " & Err & " " & Err.Description & _
                              Chr(13) & pMensagem)
End Function

