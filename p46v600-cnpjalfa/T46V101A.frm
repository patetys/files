            End If
            If (CDbl(frmT46V142A.txtPosJuro(lI).Text) <> 0 Or gM46V111.gCod_plano >= 2000) And (gM46V999.gTipUsuario = e_Tipo_Usu_Corretor Or gM46V999.gTipUsuario = e_Tipo_Usu_CorretorYasuda) And gM46V111.gRegPadrao = False Then
