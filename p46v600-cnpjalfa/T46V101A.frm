        End If


        If pSitDocumento = 3 Then
            .Caption = .Caption & " - PROPOSTA J� TRANSMITIDA"
            If objstcPedido.Num_PI_Emissao <> 0 Then
                .Caption = .Caption & " - " & objstcPedido.Num_PI_Emissao & "-" & objstcPedido.Dig_PI_Emissao
