Private Sub Form_Activate()

    Dim lMensagem As String         'Mensagem.
    Dim lMudou As Boolean     'Indica que mudou linha da grade.

'1. Posiciona identifica��o do form.
    frmT46V100A.panForm.Caption = Mid$(Me.Name, 4)
    'Me.Height = 8490 '8835
    If mErrCarga = True Or gM46V999.gFinalizarPrograma = True Then
        Unload Me
        gM46V999.gFinalizarPrograma = False
        Exit Sub
    End If

    chkSuprimirBatente.Visible = gM46V999.gCodProduto >= 1118
    chkSuprimirBatente.Visible = chkSuprimirBatente.Visible And (gM46V999.gCod_Ramo = e_CodRamo_Empresarial Or gM46V999.gCod_Ramo = e_CodRamo_Residencial)
    chkSuprimirBatente.Enabled = (gM46V111.gCod_Dizer = 0)
    barFerramentas.Buttons("GerCobertura").Enabled = Not (gM46V999.gDesabilitarForms Or gM46V999.gDesabFormsCotacao Or _
                                                          gM46V111.gCod_Dizer = e_CodDizerCancelamento Or _
                                                          gM46V111.gCod_Dizer = e_CodDizerexclusao)
    'Acesso Syas Privil�gios 2
    If Not gM46V999.M46O001.PermiteAlterarFranquia = True Then
        barFerramentas.Buttons(22).Enabled = False
        barFerramentas.Buttons(28).Enabled = False
        barFerramentas.Buttons(35).Enabled = False
    End If

    '2. Verifica programa chamado.
    If Not gM46V999.gfPreenchido(gProChamado) Then
        On Error Resume Next
        If gM46V999.gCod_Ramo = e_CodRamo_NaoDefinido Then
            cboRamo.ListIndex = -1
            If cboRamo.Enabled Then
                cboRamo.SetFocus
            End If
        End If
        On Error GoTo 0
        GoTo Finalizar
    End If
    Select Case UCase(gProChamado)
        'a) T46V107A - Seleciona produto.
    Case "T46V107A"
        If mAntProduto <> gM46V999.gCodProduto Or _
           mAntProtocolo <> gM46V999.gCodProtocolo Or _
           mAntSequencia <> gM46V999.gCodSequencia Then
            Call mpObtProduto(gM46V999.gCodProduto, gM46V999.gCodSequencia, gM46V999.gCod_Ramo)
            lblNomProduto.Caption = gM46O001.gProNome
            'CR97634 emergencial melhora de performance
            'Call mpAtualizaJurosNovo
        End If
        Call mpObtProduto(gM46V999.gCodProduto, gM46V999.gCodSequencia, gM46V999.gCod_Ramo)
        lblNomProduto.Caption = gM46O001.gProNome
        lblNomProduto.Refresh
        Call mpAtualizaJurosNovo
        'b) T46V112 - Exibe tipo de emiss�o.
    Case "T46V112A"
        If gAltT46V112A = True Then
            Call gpHabSalvar
        End If
        'c) T46V125A - Navega��o entre itens.
    Case "T46V125A"
        With frmT46V125A.flxItens
            '===1) Verifica se mudou posi��o na grade de itens.
            lMudou = False
            If .row <> 0 Then
                If gM46V999.gfPreenchido(txtNumItem.Text) Then
                    .Col = 0    'N�mero do item.
                    If val(txtNumItem.Text) <> val(.Text) Then
                        lMudou = True
                    End If
                Else
                    lMudou = True
                End If
                If lMudou = True Then
                    '===a) Obt�m novo item.
                    .Col = 0    'N�mero do item.
                    On Error Resume Next
                    '                        objstcPedLoc
                    Set objstcPedLoc = objstcPedido.ColecaoPedLoc.Item(objstcPedLoc.nosso_numero & Format(.Text, "00000"))
                    On Error GoTo 0
                    '===b) Trata resultado.
                    If objstcPedLoc.Num_Item = val(txtNumItem.Text) Then
                        Call gM46V999.gpGraLog(2, "FTE0004 - " & gM46V999.gPrefixo & "Item n�o localizado (" & .Text & _
                                                " - navega��o entre itens).")
                    Else
                        gCarga = True
                        Call mpPosItem(objstcPedLoc)
                        gCarga = False
                    End If
                End If
            End If
        End With
        '   T46V167A - Mover desconto comercial
    Case "T46V167A"
        On Error Resume Next
        If frmT46V167A.cmdOk.Tag = "ALTERADO" Then
            Set objstcPedLoc = objstcPedido.ColecaoPedLoc.Item(objstcPedLoc.nosso_numero & Format(txtNumItem.Text, "00000"))
            On Error GoTo 0
            If objstcPedLoc.Num_Item <> gM46V999.CDblx(txtNumItem.Text) Then
                Call gM46V999.gpGraLog(2, "FTE0004 - " & gM46V999.gPrefixo & "Item n�o localizado (" & txtNumItem.Text & _
                                        " - Erro na carga de Desconto Comercial).")
            Else
                gCarga = True
                Call mpPosItem(objstcPedLoc)
                txtDescComercial = frmT46V167A.txtDescComercial
                gCarga = False
            End If
        End If
    Case "T46V111A"
        'nao faz nada
        'f) Outro form.
    Case "T46V102A"    '1001224 - Condi��es Diferenciada - Seguratec
        gCarga = True
        If val(frmT46V102A.txtCodSegurado.Text) <> mCodSegAnt Or _
           val(frmT46V102A.txtCorretor(1).Tag) <> mCorrAnt Then
            Call mpAtualizaJurosNovo
        End If
        gCarga = False
        mCodSegAnt = val(frmT46V102A.txtCodSegurado.Text)
        mCorrAnt = val(frmT46V102A.txtCorretor(1).Tag)

        'T46V144 - Itens para endosso
    Case "T46V145A"
        If gM46V999.gfDisponivel("frmT46V145A") = True Then
            Unload frmT46V145A
            Call mpCriGraItens
            Call gpHabSalvar
        End If
    Case Else
        Call gM46V999.gpGraLog(2, "FTE0005 - " & gM46V999.gPrefixo & "Programa chamado desconhecido (" & gProChamado & _
                                " - janela T46V101A).")
    End Select

    '3. Limpa Variaveis
    gProChamado = ""

Finalizar:
    Call mpVerDesabilitar

End Sub
Private Sub mpVerDesabilitar()
