Private Sub mpImprimirRelatorioPDF()

    Screen.MousePointer = vbHourglass

    Dim obj As New Yasuda_IntegrationReport.IntegrationMulti
    Dim objInfo As New Yasuda_IntegrationReport.ConnectionInfo
    Dim blnRelExportado As Boolean
    Dim lObj As FileSystemObject
    Dim lLocal As String
    objInfo.ServerUrl = "http://192.168.113.21:8098/ServiceImplementations/SyasMultiServices.svc"


    If gM46V999.gTipUsuario = 1 Then
        On Error Resume Next
        Set lObj = New FileSystemObject
        If lObj.FolderExists("L:\") Then
            If lObj.FolderExists("L:\User\") = False Then
                Call lObj.CreateFolder("L:\User\")
            End If
            lLocal = "L:\User\"
        Else
            lLocal = "C:\Temp\"
        End If
        On Error GoTo 0
    Else
        lLocal = gM46V999.gAppPath
    End If

    lLocal = lLocal + "Relatorio - " + Replace(Replace(CStr(DateTime.Now), "/", "_"), ":", "_") + ".PDF"

    blnRelExportado = obj.GetFile(objInfo, lLocal, "1234567890987654")

    If blnRelExportado Then
        frmPDF.CaminhoRelatorio = lLocal
        frmPDF.Show vbModal
    Else
        MsgBox obj.message
    End If

    Screen.MousePointer = vbDefault

End Sub

Private Function mfVerificarNumBoletoDisp(ByRef pDataDigit As Long, pLocal As Integer) As Boolean

    Dim lMensagem As String
    Dim lretorno As Byte
    Dim lobjBoleto As clsA28V720A
    Dim lobjstcBoleto As stcA28V720B
    Dim lobjCtrlEmis As clsA46V712A
    Dim lValorParc As Variant

    If objstcPedido.objstcCtrlEmis.Cod_Iden_Pag_Antec = e_SimNao_Sim And frmT46V102A.optForPagamento(0).Value = True And _
       (objstcPedido.objstcCtrlEmis.Num_Bloq = 0 Or Left(objstcPedido.objstcCtrlEmis.Num_Bloq, 1) = 5) And _
       (gM46V999.gTipUsuario = e_Tipo_Usu_Corretor Or gM46V999.gTipUsuario = e_Tipo_Usu_CorretorYasuda) And _
       objstcPedido.Cod_Reg <> 120 Then
       
        On Error GoTo ControleErro
        lretorno = 0
Retorno:
        Set lobjBoleto = New clsA28V720A
        Set lobjBoleto.M46V999 = gM46V999

        Set lobjstcBoleto = New stcA28V720B
        Set lobjstcBoleto.M46V999 = gM46V999

        lobjstcBoleto.nosso_numero = objstcPedido.nosso_numero


        If Not lobjBoleto.gfCarregarBoletoDisp(lobjstcBoleto.nosso_numero, (lretorno = 1), objstcPedido.Nosso_Numero_Original) Then
            Call gM46V999.gpGraLog(1, lobjBoleto.UltimoErro)
            Exit Function
        End If

        If lobjBoleto.Colecao.Count = 0 Then
            'Erro
        Else
            Set lobjstcBoleto = lobjBoleto.Colecao.Item(1)
            If lobjstcBoleto.DAT_DIGIT = 0 Then
                Set objstcPedido.objstcBoleto = lobjstcBoleto
                'Ok
            Else
                With objstcPedido
                    Call gM46V998.gfCalFracionamento(objstcPedido, objstcPedLoc.Tip_Emissao, _
                                                     lValorParc, lMensagem, gM46V111.gProJurIOF, .Cod_Reg, .Val_IOF, .Val_Parc_Min)
                End With
                objstcPedido.Val_PriParcela = lValorParc(objstcPedido.Qtd_Parc, 1)
                If lobjstcBoleto.VAL_PR <> Round(objstcPedido.Val_PriParcela, 2) Then
                    'Gero outro boleto
                    If lobjstcBoleto.nosso_numero <> objstcPedido.Nosso_Numero_Original Then
                        Call gM46V999.gpGraLog(1, "AGE0163 - Um novo boleto ser� impresso. Favor descartar o boleto emitido anteriormente.")
                    End If
                    lretorno = 1
                    GoTo Retorno
                ElseIf lobjstcBoleto.DAT_DIGIT < Format(Date - 5, "yyyymmdd") And _
                       lobjstcBoleto.DAT_VENC < Format(Date + 7, "yyyymmdd") Then
                    If objstcPedido.Ind_Reentrada = 1 And lobjstcBoleto.nosso_numero = objstcPedido.Nosso_Numero_Original Then
                        If pLocal = 1 Then
                            '                            If MsgBox("AGE0185 - **REENTRADA** - Deseja utilizar o boleto 5" & lobjstcBoleto.NUM_BOLETO & " da proposta anterior?", vbQuestion + vbYesNo) = vbYes Then
                            '1200234 - Reutilizar Numero de Boleto Automaticamente na Reentrada
                            MsgBox "AGE0185 - **REENTRADA** " & vbCrLf & "O boleto " & lobjstcBoleto.NUM_BOLETO & " (proposta anterior) ser� utilizado para emiss�o desta proposta.", vbInformation
                            GoTo UtilizarBoleto
                            '                            Else
                            '                                GoTo DesprezarBoleto
                            '                            End If
                        Else
                            GoTo UtilizarBoleto
                        End If
                    Else
                        'Gero outro boleto
                        Call gM46V999.gpGraLog(1, "AGE0163 - Um novo boleto ser� impresso. Favor descartar o boleto emitido anteriormente.")
DesprezarBoleto:
                        lretorno = 1
                        GoTo Retorno
                    End If
                Else
                    'Utilizo o mesmo
                    'Utilizo o mesmo
                    If pLocal = 1 Then
                        If objstcPedido.Ind_Reentrada = 1 And lobjstcBoleto.nosso_numero = objstcPedido.Nosso_Numero_Original Then
                            '                            If MsgBox("AGE0185 - **REENTRADA** - Deseja utilizar o boleto " & lobjstcBoleto.NUM_BOLETO & " da proposta anterior?", vbQuestion + vbYesNo) = vbYes Then
                            '1200234 - Reutilizar Numero de Boleto Automaticamente na Reentrada
                            MsgBox "AGE0185 - **REENTRADA** " & vbCrLf & "O boleto " & lobjstcBoleto.NUM_BOLETO & " (proposta anterior) ser� utilizado para emiss�o desta proposta.", vbInformation
                            GoTo UtilizarBoleto
                            '                            Else
                            '                                GoTo DesprezarBoleto
                            '                            End If
                        End If
                    End If
UtilizarBoleto:
                    Set objstcPedido.objstcBoleto = lobjstcBoleto
                    pDataDigit = lobjstcBoleto.DAT_DIGIT
                End If
            End If
        End If

        'Salvo o n�mero do boleto na tabela de comum.
        objstcPedido.objstcCtrlEmis.Num_Bloq = objstcPedido.objstcBoleto.NUM_BOLETO
        objstcPedido.objstcCtrlEmis.DIG_BLOQUETO = objstcPedido.objstcBoleto.gDigitoBloq
        Set lobjCtrlEmis = New clsA46V712A
        Set lobjCtrlEmis.M46V999 = gM46V999

        If Not lobjCtrlEmis.mfAlterar(objstcPedido.objstcCtrlEmis, "", "") Then
            lMensagem = lobjCtrlEmis.UltimoErro
            Call gM46V999.gpGraLog(1, lMensagem)
            Exit Function
        End If
        If pLocal = 0 And gM46V999.gNovaTransmissaoMulti = False Then
            '1000800 - Garantir envio de Numero do Boleto nas Transmissoes
            If gM46V999.gfCalCodUnicidade_V1(objstcPedido, lMensagem) = False Then
                Call gM46V999.gpGraLog(1, lMensagem)
                Exit Function
            End If
            objstcPedido.Dat_Liber = mComUltData
            objstcPedido.Cod_User_Liber = mComUltUsuario
            If Not objPedido.mfAlterar(objstcPedido, "", "", mComUltData, mComUltUsuario) Then
                lMensagem = objPedido.UltimoErro
                Call gM46V999.gpGraLog(1, lMensagem)
                Exit Function
            End If

            If mfTransmitir(True, lMensagem) = False Then
                Call gM46V999.gpGraLog(0, lMensagem)
            End If
        End If
    End If

    mfVerificarNumBoletoDisp = True
    Exit Function
ControleErro:
    Call gM46V999.gpGraLog(1, "Disponibilizando boleto : " & Err.Number & "-" & Err.Description)
End Function

