Private Function mfSalvarClausulas(pMensagem As String) As Boolean
    Dim lobjPedClau As clsA46V703A    'Objeto da classe clsA46V703A (TAB_PED_CLAU).
    Dim lI As Integer    'Utilizado no for...loop
    Dim lretorno As String    'Retorno.
    Dim lobjstcClau As stcA46V703B    'Objeto da classe de estrutura stcA46V703B(TAB_PED_CLAU).
    Dim Aux As String

    On Error GoTo ControleErro

    Set lobjPedClau = New clsA46V703A
    Set lobjPedClau.M46V999 = gM46V999

    Set lobjstcClau = New stcA46V703B
    Set lobjstcClau.M46V999 = gM46V999

    'If gM46V999.gfPreenchido(objstcPedLoc.objstcPedClau.NOSSO_NUMERO) Then
    If objstcPedLoc.ColecaoPedClau.Count > 0 Then
        lobjstcClau.nosso_numero = objstcPedido.nosso_numero
        lobjstcClau.Num_Item = objstcPedLoc.Num_Item_Ant
        If Not lobjPedClau.mfExcluir(lobjstcClau, "", "") Then
            pMensagem = lobjPedClau.UltimoErro
            GoTo Finalizar
        End If
    End If
    Set objstcPedLoc.ColecaoPedClau = New Collection
    If gM46V999.gCodProduto <= gM46V999.TarifaAntiga Then
        If gM46V999.gfDisponivel("frmT46V118A") Then
            Aux = Replace(frmT46V118A.txtBenCPF.Text, ".", "")
            Aux = Replace(Aux, "-", "")
            If Trim(frmT46V118A.txtBemNome.Text) <> "" Or gM46V999.CDblx(Aux) <> 0 Then
                Set lobjstcClau = New stcA46V703B
                Set lobjstcClau.M46V999 = gM46V999

                With lobjstcClau
                    .nosso_numero = objstcPedLoc.nosso_numero
                    If gM46V999.gCod_Ramo = e_CodRamo_Empresarial Then
                        .Cod_Clau = 4
                    Else
                        .Cod_Clau = 1
                    End If
                    .Cod_Ramo = objstcPedido.Cod_Ramo
                    .Num_Ped = objstcPedido.Num_Ped
                    .Num_Item = objstcPedLoc.Num_Item
                    If Len(frmT46V118A.txtBenCPF.Text) <= 14 Then
                        Call gM46V999.gpForCPF(2, frmT46V118A.txtBenCPF.Text, lretorno)
                    Else
                        Call gM46V999.gpForCNPJ(2, frmT46V118A.txtBenCPF.Text, lretorno)
                    End If
                    .Descricao = Format(val(lretorno), "00000000000000")
                    .NUM_PI = gM46V111.gNum_Pi
                    '01 - 14 CPF ou CNPJ do beneficiario
                    '15 - 74 nome do beneficiario
                    .Descricao = .Descricao & frmT46V118A.txtBemNome.Text & String(60 - Len(frmT46V118A.txtBemNome.Text), " ")
                End With
                If Not lobjPedClau.mfIncluir(lobjstcClau, "", "", "") Then
                    pMensagem = lobjPedClau.UltimoErro
                    GoTo Finalizar
                End If
                objstcPedLoc.ColecaoPedClau.Add lobjstcClau, lobjstcClau.Class_ID
            End If
        End If
    Else
        If gM46V999.gfDisponivel("frmT46V165A") Then
            For lI = 1 To 9
                If frmT46V165A.cboClausulas(lI).ListIndex > -1 And frmT46V165A.ClausulaItem = objstcPedLoc.Num_Item Then
                    If frmT46V165A.cboClausulas(lI).ItemData(frmT46V165A.cboClausulas(lI).ListIndex) <> 0 Then
                        Set lobjstcClau = New stcA46V703B
                        Set lobjstcClau.M46V999 = gM46V999
                        lobjstcClau.Cod_Clau = frmT46V165A.cboClausulas(lI).ItemData(frmT46V165A.cboClausulas(lI).ListIndex)
                        lobjstcClau.Cod_Ramo = objstcPedido.Cod_Ramo

                        If Not lobjstcClau.gEhAss24h Then
                            With lobjstcClau
                                .nosso_numero = objstcPedLoc.nosso_numero
                                '.Cod_Clau = frmT46V165A.cboClausulas(lI).ItemData(frmT46V165A.cboClausulas(lI).ListIndex)
                                '.Cod_Ramo = objstcPedido.Cod_Ramo
                                .Num_Ped = objstcPedido.Num_Ped
                                .Num_Item = objstcPedLoc.Num_Item
                                .Descricao = "  "
                                .NUM_PI = gM46V111.gNum_Pi
                            End With
                            If Not lobjPedClau.mfIncluir(lobjstcClau, "", "", "") Then
                                pMensagem = lobjPedClau.UltimoErro
                                GoTo Finalizar
                            End If
                            objstcPedLoc.ColecaoPedClau.Add lobjstcClau, lobjstcClau.Class_ID
                        End If
                    End If
                End If
            Next
        End If
    End If
    'Ass24h
    If cboAss24h.ItemData(cboAss24h.ListIndex) > 0 Then
        Set lobjstcClau = New stcA46V703B
        Set lobjstcClau.M46V999 = gM46V999

        With lobjstcClau
            .nosso_numero = objstcPedLoc.nosso_numero
            .Cod_Clau = cboAss24h.ItemData(cboAss24h.ListIndex)
            .Cod_Ramo = objstcPedido.Cod_Ramo
            .Num_Ped = objstcPedido.Num_Ped
            .Num_Item = objstcPedLoc.Num_Item
            .Descricao = "  "
            .NUM_PI = gM46V111.gNum_Pi
        End With
        If Not lobjPedClau.mfIncluir(lobjstcClau, "", "", "") Then
            pMensagem = lobjPedClau.UltimoErro
            GoTo Finalizar
        End If
        If lobjPedClau.UltimoErro = Empty Then
            objstcPedLoc.ColecaoPedClau.Add lobjstcClau, lobjstcClau.Class_ID
        End If
    End If

    mfSalvarClausulas = True
Finalizar:
    Set lobjPedClau = Nothing
    Exit Function
ControleErro:
    Set lobjPedClau = Nothing
    If gM46V999.gfPreenchido(pMensagem) = False Then
        pMensagem = Err.Description
    End If
    Call gM46V999.gpGraLog(0, "mfSalvarClausulas ERRO - " & Err & " " & ERROR & _
                              Chr(13) & pMensagem)
End Function

Private Function mfSalvarCoberturas(pMensagem As String) As Boolean
    Dim lObjPedCobert As clsA46V704A
    Dim lobjstcPedCobert As stcA46V704B
    Dim lObjPedCobertFranquia As clsA46V738A
    Dim lObjstcPedCobertFranquia As stcA46V738B
    Dim lI As Integer

    On Error GoTo ControleErro

    Set lObjPedCobert = New clsA46V704A
    Set lObjPedCobert.M46V999 = gM46V999

    Set lobjstcPedCobert = New stcA46V704B
    Set lobjstcPedCobert.M46V999 = gM46V999

    Set lObjPedCobertFranquia = New clsA46V738A
    Set lObjPedCobertFranquia.M46V999 = gM46V999
    
    Set lObjstcPedCobertFranquia = New stcA46V738B
    Set lObjstcPedCobertFranquia.M46V999 = gM46V999

    lobjstcPedCobert.nosso_numero = objstcPedido.nosso_numero
    lobjstcPedCobert.Num_Item = objstcPedLoc.Num_Item_Ant
    
    lObjstcPedCobertFranquia.nosso_numero = objstcPedido.nosso_numero
    lObjstcPedCobertFranquia.Num_Item = objstcPedLoc.Num_Item_Ant
    
    If Not lObjPedCobert.mfExcluir(lobjstcPedCobert, "", "") Then
        pMensagem = lObjPedCobert.UltimoErro
        GoTo Finalizar
    End If
    
    If Not lObjPedCobertFranquia.mfExcluir(lObjstcPedCobertFranquia, "", "") Then
        pMensagem = lObjPedCobert.UltimoErro
        GoTo Finalizar
    End If
    
    If gM46V999.gfDisponivel("frmT46V117A") Then
        ' 1300639 - Salvar a informa��o de pr�mio informado antes de destruir a cole��o
        Dim arrPremioInformado() As Boolean
        Dim arrValPremioOriginal() As Double
        Dim arrValPremioInformado() As Double
        Dim arrPremioInformadoCodCobert() As Integer
        Dim lPer_Desc_Coml_Web As Double
        Dim arrRA_C4() As Integer
        Dim arrVAL_IS_RA() As Double
        Dim arrTip_Origem_C4() As Integer

        ReDim arrPremioInformado(objstcPedLoc.ColecaoPedCobert.Count)
        ReDim arrValPremioOriginal(objstcPedLoc.ColecaoPedCobert.Count)
        ReDim arrValPremioInformado(objstcPedLoc.ColecaoPedCobert.Count)
        ReDim arrPremioInformadoCodCobert(objstcPedLoc.ColecaoPedCobert.Count)
        
        ReDim arrRA_C4(objstcPedLoc.ColecaoPedCobert.Count)
        ReDim arrVAL_IS_RA(objstcPedLoc.ColecaoPedCobert.Count)
        ReDim arrTip_Origem_C4(objstcPedLoc.ColecaoPedCobert.Count)

        Dim iii2 As Integer

        For iii2 = 1 To objstcPedLoc.ColecaoPedCobert.Count
            Set lobjstcPedCobert = objstcPedLoc.ColecaoPedCobert(iii2)
            
            arrPremioInformado(iii2) = lobjstcPedCobert.PremioInformado
            arrValPremioOriginal(iii2) = lobjstcPedCobert.Val_Pr_Orig
            arrPremioInformadoCodCobert(iii2) = lobjstcPedCobert.Cod_Cobert
            If lobjstcPedCobert.PremioInformado Then arrValPremioInformado(iii2) = lobjstcPedCobert.VAL_PR
            lPer_Desc_Coml_Web = lobjstcPedCobert.Per_Desc_Coml_Web '� unico para todo a Cota��o/Proposta
            
            If IsNull(lobjstcPedCobert.Tip_Origem_C4) Or lobjstcPedCobert.Tip_Origem_C4 = 0 Then
                lobjstcPedCobert.Tip_Origem_C4 = 2 '' Cobertura inserida no KIT
            End If
            
            If lobjstcPedCobert.VAL_IS_RA > 0 And lobjstcPedCobert.Val_IS <> lobjstcPedCobert.VAL_IS_RA Then
                If lobjstcPedCobert.Tip_Origem_C4 <> 2 Then
                    lobjstcPedCobert.Tip_Origem_C4 = 3 '' Cobertura modificada no KIT
                End If
                lobjstcPedCobert.VAL_IS_RA = lobjstcPedCobert.Val_IS
            End If
            
            If lobjstcPedCobert.VAL_IS_RA = 0 Then
                lobjstcPedCobert.VAL_IS_RA = lobjstcPedCobert.Val_IS
            End If
            
            arrRA_C4(iii2) = lobjstcPedCobert.RA_C4
            arrVAL_IS_RA(iii2) = lobjstcPedCobert.VAL_IS_RA
            arrTip_Origem_C4(iii2) = lobjstcPedCobert.Tip_Origem_C4
            
        Next iii2

        ' 1300639 - Fim
        Set objstcPedLoc.ColecaoPedCobert = New Collection
        For lI = 1 To frmT46V117A.flxSelecionadas.Rows - 1
            Set lobjstcPedCobert = New stcA46V704B
            Set lobjstcPedCobert.M46V999 = gM46V999
            Set lObjstcPedCobertFranquia = New stcA46V738B
            Set lObjstcPedCobertFranquia.M46V999 = gM46V999
            
            With lobjstcPedCobert
                .Cod_Cobert = frmT46V117A.flxSelecionadas.TextMatrix(lI, ColCodCobert)

                ' 1300639 - Devolver os valores ao novo objeto
                For iii2 = 1 To UBound(arrPremioInformadoCodCobert)
                    If arrPremioInformadoCodCobert(iii2) = .Cod_Cobert Then
                        .PremioInformado = arrPremioInformado(iii2)
                        .Val_Pr_Orig = arrValPremioOriginal(iii2)
                        If .PremioInformado Then .VAL_PR = arrValPremioInformado(iii2)
                    End If
                Next
                ' 1300639 - Fim

                .nosso_numero = objstcPedLoc.nosso_numero
                .Num_Item = objstcPedLoc.Num_Item
                If gM46V999.gCodProduto <= gM46V999.TarifaAntiga Then
                    If gM46V999.gfPreenchido(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColDescComl)) = False Then
                        frmT46V117A.flxSelecionadas.TextMatrix(lI, ColDescComl) = "0,00"
                    End If
                    .Per_Desc_Coml = frmT46V117A.flxSelecionadas.TextMatrix(lI, ColDescComl)
                Else
                    If gM46V999.gTipUsuario = e_Tipo_Usu_Yasuda And (gM46V999.PerfilAcesso <> e_Perfil_CALC And gM46V999.PerfilAcesso <> e_Perfil_CALC_Gestor) Then
                        If gM46V999.gfPreenchido(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColDescComl)) = False Then
                            frmT46V117A.flxSelecionadas.TextMatrix(lI, ColDescComl) = "0,00"
                        End If
                        .Per_Desc_Coml = frmT46V117A.flxSelecionadas.TextMatrix(lI, ColDescComl)
                    Else
                        .Per_Desc_Coml = gM46V999.CDblx(txtDescComercial)
                    End If
                End If

                If gM46V999.gCodProduto <= gM46V999.TarifaAntiga Then
                    If gM46V999.gfPreenchido(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColDescExp)) = False Then
                        frmT46V117A.flxSelecionadas.TextMatrix(lI, ColDescExp) = "0,00"
                    End If
                    .Per_Desc_Exp = frmT46V117A.flxSelecionadas.TextMatrix(lI, ColDescExp)
                Else
                    If gM46V999.gTipUsuario = e_Tipo_Usu_Yasuda And (gM46V999.PerfilAcesso <> e_Perfil_CALC And gM46V999.PerfilAcesso <> e_Perfil_CALC_Gestor) Then
                        If gM46V999.gfPreenchido(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColDescExp)) = False Then
                            frmT46V117A.flxSelecionadas.TextMatrix(lI, ColDescExp) = "0,00"
                        End If
                        .Per_Desc_Exp = frmT46V117A.flxSelecionadas.TextMatrix(lI, ColDescExp)
                    Else
                        .Per_Desc_Exp = gM46V999.CDblx(txtDescBonus)
                    End If
                End If
                If gM46V999.gfPreenchido(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColPerFranq)) = False Then
                    .Per_Franq = 0
                Else
                    .Per_Franq = frmT46V117A.flxSelecionadas.TextMatrix(lI, ColPerFranq)
                End If
                '.Per_Taxa = 0
                .Per_Taxa = gM46V999.CDblx(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColTaxaFinal))
                If gM46V999.gCodProduto <= gM46V999.TarifaAntiga Then
                    .Tab_Cobert = frmT46V117A.flxSelecionadas.TextMatrix(lI, ColTabCobert)
                Else
                    .Tab_Cobert = gM46V111.gCod_plano
                End If
                .Val_Franq_Max = 0
                If gM46V999.gfPreenchido(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColValFranq)) = False Then
                    .Val_Franq_Min = 0
                Else
                    .Val_Franq_Min = frmT46V117A.flxSelecionadas.TextMatrix(lI, ColValFranq)
                End If
                If gM46V999.gfPreenchido(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColValLMG)) = False Then
                    .Val_IS = 0
                Else
                    .Val_IS = frmT46V117A.flxSelecionadas.TextMatrix(lI, ColValLMG)
                End If
                If .PremioInformado = False Then .VAL_PR = 0
                .Val_Pr_Anu = 0
                .Val_Pr_Resg = 0
                .Val_Pr_Resg_Anu = 0
                .Val_Pr_Tarif = 0
                .Val_Pr_Tarif_Anu = 0
                .Cod_Ramo = objstcPedido.Cod_Ramo
                .Num_Ped = objstcPedido.Num_Ped
                If gM46V999.gfPreenchido(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColPInd)) = False Then
                    .Num_Meses_PI = 0
                Else
                    .Num_Meses_PI = frmT46V117A.flxSelecionadas.TextMatrix(lI, ColPInd)
                End If
                .Val_Fator_Franq = gM46V999.CDblx(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColCoefFranq))

                If .Val_Franq_Min = 0 Then .Val_Fator_Franq = 1
                .Val_Risco_Cob = gM46V999.CDblx(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColValRisco))
                .Alterar_Cobert = frmT46V117A.flxSelecionadas.TextMatrix(lI, ColTaxaAlterada)
                .AjusteEndosso = frmT46V117A.flxSelecionadas.TextMatrix(lI, ColAjusteEndosso)
                .AlterouFranquia = frmT46V117A.flxSelecionadas.TextMatrix(lI, ColAlterouFranquia)
                
                'Verifica��o de corretude do Texto de Franquia para Tarifa igual ou superior 1080
                If gM46V999.gCodProduto >= 1080 Then
                    Dim lTextoFranquia As String
                    Dim lTextoObservacao As String
                    
                    If gM46V999.gfDisponivel("frmT46V179A") Then
                        lTextoObservacao = frmT46V179A.flxCobertura.TextMatrix(frmT46V179A.mpGetFranquiaID(.Cod_Cobert), 4)
                    End If
                    lTextoFranquia = gM46V999.gfTextoFranquia(.Val_Franq_Min, .Per_Franq, Left(lTextoObservacao, 1), .Cod_Cobert, .Num_Meses_PI, .Val_Risco_Cob, objstcPedLoc)
                                                
                    'Retira caracteres especiais
                        lTextoFranquia = Trim(gM46V999.gfRetirarCaracterEspecial(lTextoFranquia))
                    frmT46V117A.flxSelecionadas.TextMatrix(lI, ColTextoFranquia) = Trim(gM46V999.gfRetirarCaracterEspecial(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColTextoFranquia)))
                    
                    If lTextoFranquia <> frmT46V117A.flxSelecionadas.TextMatrix(lI, ColTextoFranquia) Then
                        Call gM46V999.gpGraLog(0, "Texto de Franquias Divergentes! Errado: " & frmT46V117A.flxSelecionadas.TextMatrix(lI, ColTextoFranquia) & " Certo: " & lTextoFranquia)
                        Call gM46V999.gpGraLog(0, "Parametros usados na gera��o do texto:" _
                                                & " NumPed: " & objstcPedLoc.Num_Ped _
                                                & " NumItem: " & objstcPedLoc.Num_Item _
                                                & " CodCobert: " & frmT46V117A.flxSelecionadas.TextMatrix(lI, ColCodCobert) _
                                                & " ValRisco: " & frmT46V117A.flxSelecionadas.TextMatrix(lI, ColValRisco) _
                                                & " Cod_Clasf: " & objstcPedLoc.Cod_Clasf _
                                                & " Cod_Compl_Clasf: " & objstcPedLoc.Cod_Compl_Clasf _
                                                & " CEPRisco: " & Replace(txtRisCEP, "-", "") _
                                                & " TipCobert: " & cboTipCobert.ItemData(cboTipCobert.ListIndex) _
                                                & " PInd: " & IIf(IsNumeric(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColPInd)), frmT46V117A.flxSelecionadas.TextMatrix(lI, ColPInd), 0))
                                                
                    End If
                End If
                
                .TextoFranquia = frmT46V117A.flxSelecionadas.TextMatrix(lI, ColTextoFranquia)
                .Compl_Desc_Cobertura = Empty

                'Pr�dio e conte�do com verbas separadas.
                If InStr(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColNomCobert), DESC_COBERT_PREDIO) > 0 Then
                    .Compl_Desc_Cobertura = "PREDIO"
                Else
                    If InStr(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColNomCobert), DESC_COBERT_CONTEUDO) > 0 Then
                        .Compl_Desc_Cobertura = "CONTEUDO"
                    Else
                        If frmT46V117A.flxSelecionadas.TextMatrix(lI, ColCodGrupoCobert) = 1 Then
                            Select Case cboTipCobert.ItemData(cboTipCobert.ListIndex)
                                
                                Case e_TipCobert_PredioeConteudo
                                    .Compl_Desc_Cobertura = Empty
                                Case e_TipCobert_Conteudo
                                    .Compl_Desc_Cobertura = "CONTEUDO"
                                Case e_TipCobert_Predio
                                    .Compl_Desc_Cobertura = "PREDIO"
                                
                            End Select
                        End If
                    End If
                End If
                
                '== Elevador
                If frmT46V117A.flxSelecionadas.TextMatrix(lI, ColCodCobert) = 1103 And _
                   gM46V999.gCod_Ramo = e_CodRamo_Condominio And cboElevador.ListIndex <> -1 Then
                    .Compl_Desc_Cobertura = IIf(cboElevador.ItemData(cboElevador.ListIndex) = e_SimNao_Sim, "COM ELEVADOR", "SEM ELEVADOR")
                End If

                .NUM_PI = gM46V111.gNum_Pi
                
                Dim AuxDesc As Double
                AuxDesc = IIf(Trim(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColDesconto)) = "", 0, frmT46V117A.flxSelecionadas.TextMatrix(lI, ColDesconto))
                .Per_Desc_Franq = AuxDesc
                .Val_Fator_Franq = CDbl((100 - AuxDesc) / 100)
                .Per_Desc_Coml_Web = lPer_Desc_Coml_Web
                
                
                If (UBound(arrRA_C4) >= lI) Then
                    .RA_C4 = arrRA_C4(lI)
                    .VAL_IS_RA = arrVAL_IS_RA(lI)
                    .Tip_Origem_C4 = arrTip_Origem_C4(lI)
                End If
            End With
            If Not lObjPedCobert.mfIncluir(lobjstcPedCobert, "", "", False, False, "") Then
                pMensagem = lObjPedCobert.UltimoErro
                GoTo Finalizar
            End If
            
            If gM46V999.gCodProduto >= 1080 Then
                With lObjstcPedCobertFranquia
                    .Cod_Ramo = lobjstcPedCobert.Cod_Ramo
                    .Cod_Modalidade = lobjstcPedCobert.Tab_Cobert
                    .Cod_Tarif = gM46V999.gCodProduto
                    .Cod_Cobert = lobjstcPedCobert.Cod_Cobert
                    .Cod_Evento = 0
                    .Num_Ped = lobjstcPedCobert.Num_Ped
                    .Num_Apol = lobjstcPedCobert.Num_Apol
                    .Num_Item = lobjstcPedCobert.Num_Item
                    .Num_Endosso = lobjstcPedCobert.Num_Endo
                    .NUM_PI = lobjstcPedCobert.NUM_PI
                    .nosso_numero = lobjstcPedCobert.nosso_numero
                    .Val_Min_Franq = lobjstcPedCobert.Val_Franq_Min
                    .Per_Franq = lobjstcPedCobert.Per_Franq
                    .Multiplo_Franquia = IIf(Replace(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColMultiploFranquia), "x", Empty) = Empty, 1, Replace(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColMultiploFranquia), "x", Empty))
                    
                    If gM46V999.gfDisponivel("frmT46V179A") Then
                        .Texto_Franquia = frmT46V117A.flxSelecionadas.TextMatrix(lI, ColTextoFranquia)
                        '.Texto_Franquia = frmT46V179A.flxCobertura.TextMatrix(frmT46V179A.mpGetFranquiaID(.Cod_Cobert), 2)
                        .Texto_Observacoes = frmT46V179A.flxCobertura.TextMatrix(frmT46V179A.mpGetFranquiaID(.Cod_Cobert), 4)
                    End If
                    
                End With
                
                If Not lObjPedCobertFranquia.mfIncluir(lObjstcPedCobertFranquia, "", "", "") Then
                    pMensagem = lObjPedCobert.UltimoErro
                    GoTo Finalizar
                End If
                
                Set lObjstcPedCobertFranquia.ObjPai = lobjstcPedCobert
                lobjstcPedCobert.ColecaoNovaFranquia.Add lObjstcPedCobertFranquia, lObjstcPedCobertFranquia.Class_ID
            End If
            
            Set lobjstcPedCobert.ObjPai = objstcPedLoc
            objstcPedLoc.ColecaoPedCobert.Add lobjstcPedCobert, lobjstcPedCobert.Class_ID
            
        Next
    End If
    mfSalvarCoberturas = True
Finalizar:
    Set lobjstcPedCobert = Nothing
    Set lObjPedCobert = Nothing
    Exit Function

ControleErro:
    Set lobjstcPedCobert = Nothing
    Set lObjPedCobert = Nothing
    If gM46V999.gfPreenchido(pMensagem) = False Then
        pMensagem = Err.Description
    End If
    Call gM46V999.gpGraLog(0, "mfSalvarCoberturas ERRO - " & Err & " " & ERROR & _
                              Chr(13) & pMensagem)
End Function

Private Function mfSalvarCosseguro(pMensagem As String) As Boolean
    Dim lobjPedCoss As clsA46V706A
    Dim lobjstcPedCoss As stcA46V706B
    Dim lI As Integer


    On Error GoTo ControleErro
    Set lobjPedCoss = New clsA46V706A
    Set lobjPedCoss.M46V999 = gM46V999

    Set lobjstcPedCoss = New stcA46V706B
    Set lobjstcPedCoss.M46V999 = gM46V999

    If objstcPedido.ColecaoPedCoss.Count > 0 Then
        lobjstcPedCoss.nosso_numero = objstcPedido.nosso_numero
        If Not lobjPedCoss.mfExcluir(lobjstcPedCoss, "", "", "") Then
            pMensagem = lobjPedCoss.UltimoErro
            GoTo Finalizar
        End If
    End If
    Set objstcPedido.ColecaoPedCoss = New Collection
    If frmT46V102A.optCosseguro(0).Value = True Then
        For lI = 1 To 5
            If frmT46V116A.cboConSeguradora(lI).ListIndex <> -1 Then
                Set lobjstcPedCoss = New stcA46V706B
                Set lobjstcPedCoss.M46V999 = gM46V999

                With lobjstcPedCoss
                    .nosso_numero = objstcPedido.nosso_numero
