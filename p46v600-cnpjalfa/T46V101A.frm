    '=======================================================================================================
    'FRH - FICHA 901577 - INSERIR ESPECIFICA��O AUTOM. PARA SEGURADO CASAS BAHIA E CORRETORA MARINE.
    '=======================================================================================================
    Dim textoEspec As String
