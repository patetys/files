            objstcPedido.Val_Parc_Min = 9
            objstcPedido.Per_Juro_Frac = 0
        End Select
    End If

    'Ficha 901673
    If gM46V999.gCod_Ramo = e_CodRamo_Residencial And gM46V111.gCod_plano = 1 Then
        If (gM46V999.gCodProduto >= 974 And gM46V999.gCodProduto <= 979) And cboPlano.ItemData(cboPlano.ListIndex) = 1 Then
            objstcPedido.Val_Parc_Min = 10
            'Ficha 901793
            If gM46V999.gTipoAcesso = CALCULO Then
                objstcPedido.Per_Juro_Frac = 0
                frmT46V102A.txtJuros.Text = 0
            End If
        End If

        'Ficha 901772
        If val(frmT46V102A.txtCorretor(1).Tag) = 1601 Then
            If gM46V111.gCod_plano = 1 And _
               (Left(frmT46V101A.txtClassificacao, 7) = "001 -11" Or Left(frmT46V101A.txtClassificacao.Text, 6) = "001-11" Or _
                Left(frmT46V101A.txtClassificacao, 7) = "001 -21" Or Left(frmT46V101A.txtClassificacao.Text, 6) = "001-21") Then
                '                objstcPedido.Val_Parc_Min = 30 '1101209 - Premio Minimo Seguratec
                'Ficha 901793
                If gM46V999.gTipoAcesso = CALCULO Then
                    objstcPedido.Per_Juro_Frac = 0
                    frmT46V102A.txtJuros.Text = 0
                End If
            End If
        End If
    End If

    If gM46V999.gTipoAcesso = DIGITACAO Then
        'o minimo possivel  'ajuste temporario devido a erro no corretor
        objstcPedido.Val_Parc_Min = 0
    End If

