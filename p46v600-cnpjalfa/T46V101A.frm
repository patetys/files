        lTextoInc = AuxArray(lSeq)
        lTotLin = UBound(AuxArray)
    Else
        lTextoInc = frmT46V148A.txtTextoEndosso
    End If


OutraLinha:

    Set lobjstcTextoEndo = New stcA46V722B

    With lobjstcTextoEndo
