Private Function mfSplitClausula(ByVal pTexto As String, ByVal pDelimitador As Byte, ByVal pMaximo As Integer) As String()
    Dim Retorno() As String
    Dim i As Integer

    ReDim Retorno(1000)

    i = 0
    Do While Len(pTexto) > 0

        If InStr(pTexto, Chr(pDelimitador)) < 81 And InStr(pTexto, Chr(pDelimitador)) > 0 Then
            Retorno(i) = Left(pTexto, InStr(pTexto, Chr(pDelimitador)))
            pTexto = Mid(pTexto, Len(Retorno(i)) + 2, Len(pTexto))
        Else
            Retorno(i) = Left(pTexto, 80)
            pTexto = Mid(pTexto, Len(Retorno(i)) + 1, Len(pTexto))
        End If

        i = i + 1
    Loop
    
    If i > 1 Then
        ReDim Preserve Retorno(i - 1)
    Else
        ReDim Preserve Retorno(1)
    End If
    
    mfSplitClausula = Retorno
End Function

Public Function mfConstrucaoDePara(ByVal Cod_Constr As Integer, ByVal Cod_Ramo As e_CodRamo, ByVal Cod_Produto As Integer) As Integer
    
    If Cod_Produto <= 1080 And Cod_Ramo = e_CodRamo_Empresarial And Cod_Constr = 2 Then
       Cod_Constr = 4
    
    Else
        If Cod_Produto <= 1080 And Cod_Ramo = e_CodRamo_Residencial And Cod_Constr = 2 Then
           Cod_Constr = 3
        End If
    End If
    
    mfConstrucaoDePara = Cod_Constr
End Function

Private Function GravaInterfaceSAP(ByRef pobjPedido As clsA46V702A, ByRef pobjstcPedido As stcA46V702B, ByRef pMensagem As String) As Boolean
    Dim lrsTab_Cobert As clsYasRecordSet
    Dim lSql As String
    Dim lCodRamoSec As Integer
    Dim lNumApolEndosso As Long
    Dim lCodRetorno As Integer
    Dim lDescricao As String

    On Error GoTo TrataErro
    
    GravaInterfaceSAP = False
    lCodRamoSec = 0
    
    Call gM46V999.gpGraLog(0, "Call GravaInterfaceSAP - " & pobjstcPedido.NUM_PI)

    lSql = "SELECT TOP 1  COD_RAMO_SEC  FROM RamosDiversos..Tab_Ped_Cobert AS  F with(nolock) "
    lSql = lSql & " INNER JOIN RamosDiversos..Tab_Ped  AS P  with(nolock)  ON P.NOSSO_NUMERO = F.NOSSO_NUMERO"
    lSql = lSql & " INNER JOIN RamosDiversos..Tab_Cobert AS C with(nolock) ON  C.COD_RAMO = F.COD_RAMO AND C.TAB_COBERT = COD_ESTIP"
    lSql = lSql & " AND  COD_PRODUTO = COD_TARIF_INI AND C.COD_COBERT = F.COD_COBERT"
    lSql = lSql & " WHERE F.NOSSO_NUMERO = " & gM46V999.gfFormatarCamposSQL(pobjstcPedido.nosso_numero) & " and COD_RAMO_SEC <> p.Cod_Ramo"
     
    If Not gM46V999.gfObtRegistro(pobjPedido.ConexaoBD, lSql, lrsTab_Cobert, pMensagem) Then
        If gM46V999.gfPreenchido(pMensagem) Then
            GoTo TrataErro
        End If
    End If
    
    If Not lrsTab_Cobert.EOF Then
        lCodRamoSec = lrsTab_Cobert("COD_RAMO_SEC")
    End If
    Set lrsTab_Cobert = Nothing
    
    If lCodRamoSec = 0 Then
        lCodRamoSec = pobjstcPedido.Cod_Ramo
    End If
    
    If pobjstcPedido.Cod_Dizer <> 0 Then
        lNumApolEndosso = pobjstcPedido.Num_Apol_An
    End If

'    @NUM_CGC_CPF    bigint
'    @NUM_PI bigint
'    @NUM_LOGR_COBR  int
'    @NUM_LOGR_RESID int
'    @DSC_COMPL_LOGR_COBR_SN varchar
'    @DSC_COMPL_LOGR_RESID_SN    varchar
'    @COD_RAMO   smallint
'    @COD_PROD   int
'    @COD_RAMORAMO   smallint
'    @NUM_APOL_ENDO  bigint
'    @CDRET  tinyint
'    @DSC_RET    varchar
    
    
    lSql = "SET NOCOUNT ON BEGIN"
    lSql = lSql & " DECLARE @CDRET tinyint,"
    lSql = lSql & "         @DSC_RET varchar(MAX)"
    lSql = lSql & "    exec P0044800.dbo.sp_InterfaceCadastro '" & Trim(pobjstcPedido.Num_Cgc_Cpf) & "'"
    lSql = lSql & ", " & pobjstcPedido.NUM_PI
    lSql = lSql & ", " & gM46V999.gfTratarNulo(val(pobjstcPedido.objstcCtrlEmis.Num_Logr_Cobranca), tpoNumerico)
    lSql = lSql & ", " & gM46V999.gfTratarNulo(val(pobjstcPedido.objstcCtrlEmis.Num_Logr_Segurado), tpoNumerico)
    lSql = lSql & ", " & gM46V999.gfFormatarCamposSQL(pobjstcPedido.objstcCtrlEmis.Dsc_Compl_Cobranca)
    lSql = lSql & ", " & gM46V999.gfFormatarCamposSQL(pobjstcPedido.objstcCtrlEmis.Dsc_Compl_Segurado)
    lSql = lSql & ", " & gM46V999.gfTratarNulo(pobjstcPedido.Cod_Ramo, tpoNumerico)
    lSql = lSql & ", " & gM46V999.gfTratarNulo(pobjstcPedido.Cod_Estip, tpoNumerico)
    lSql = lSql & ", " & gM46V999.gfTratarNulo(lCodRamoSec, tpoNumerico)
    lSql = lSql & ", " & gM46V999.gfTratarNulo(lNumApolEndosso, tpoNumerico)
    lSql = lSql & ", " & "@CDRET OUTPUT"
    lSql = lSql & ", " & "@DSC_RET OUTPUT"
    lSql = lSql & " SELECT @CDRET as CDRET, @DSC_RET as DSC_RET"
    lSql = lSql & " END;"
    
    Call gM46V999.gpGraLog(0, lSql)
    
    If Not gM46V999.gfObtRegistro(pobjPedido.ConexaoBD, lSql, lrsTab_Cobert, pMensagem) Then
        If gM46V999.gfPreenchido(pMensagem) Then
            GoTo TrataErro
        End If
    End If

    If Not lrsTab_Cobert.EOF Then
        If gM46V999.gfTratarNulo(lrsTab_Cobert("CDRET"), tpoNumerico) <> 0 Then
            pMensagem = gM46V999.gfTratarNulo(lrsTab_Cobert("CDRET"), tpoNumerico) & " - " & gM46V999.gfTratarNulo(lrsTab_Cobert("DSC_RET"), tpoNumerico)
            GoTo TrataErro
        End If
    End If

    GravaInterfaceSAP = True
    
Fim:
    Exit Function
    
TrataErro:
    If Err.Number <> 0 Then
        pMensagem = "Erro: " & Err & " Descri��o: " & Err.Description & " SQL: " & lSql
    End If
    pMensagem = "[ERR] - GravaInterfaceSAP: " & pMensagem
    GoTo Fim
End Function

Private Sub TesteDesempenho(ByVal pDescricao As String)
    Static lInicio(100) As Date
    Static lProcesso(100) As String
    Dim lAchou As Boolean
    Dim i As Integer
    Dim j As Integer
    
    On Error GoTo TrataErro
    
    lAchou = False
    For i = 0 To UBound(lProcesso)
        If lProcesso(i) = pDescricao Then
            lAchou = True
        End If
        
        If lProcesso(i) = Empty Or lAchou Then
            Exit For
        End If
    Next
    
    If lAchou Then
        Call gM46V999.gpGraLog(0, DateDiff("s", lInicio(i), Time) & " segundos - " & pDescricao)
        
        For j = i To UBound(lProcesso) - 1
            If lInicio(j + 1) = Empty Then
                Exit For
            Else
                lInicio(j) = lInicio(j + 1)
                lProcesso(j) = lProcesso(j + 1)
            End If
        Next
        lInicio(j) = Empty
        lProcesso(j) = Empty
        
    Else
        lInicio(i) = Time
        lProcesso(i) = pDescricao
    End If
    
    Exit Sub
TrataErro:
    Call gM46V999.gpGraLog(0, "[ERR] TesteDesempenho - " & Err.Number & ":" & Err.Description)
End Sub

