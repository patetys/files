               Screen.MousePointer = vbDefault
               'Se ocorreu tudo OK finalizar o sistema
               If lOK <> "" Then
                   MsgBox "Pi: " & objstcPedido.objstcCtrlEmis.NUM_PI & " ser� " & lOK & ".", vbInformation
                   mfTransmitir = True
                   lVoltarFormularioAnterior = True
                   GoTo Inspecao
               End If
           End If
       Case Else
           If objstcPedido.Cod_Sit_Ped = e_SitPedido_Transmitido And gM46V999.gNovaTransmissaoMulti And pAutomatico = False Then
               Screen.MousePointer = vbDefault
               If MsgBox("AGE0181 - Confirma a solicita��o de cancelamento de emiss�o do PI " & objstcPedido.Num_PI_Emissao & " ?" & vbCrLf & vbCrLf & "O cancelamento somente � processado em hor�rio comercial.", vbQuestion + vbYesNo + vbDefaultButton2) = vbNo Then Exit Function

               Screen.MousePointer = vbHourglass
               If gM46V999.gfPreenchido(frmT46V102A.txtCorretor(1).Tag) Then
                   lCodCorretor = frmT46V102A.txtCorretor(1).Tag
               Else
                   lCodCorretor = 9999999
               End If
               If gfBuscaUsuarioTransmissao(lUsuario, lMensagem) = False Then
                   lMensagem = lMensagem & " Linha: 186"
                   GoTo TrataErro
               End If
               Set clsA46V101A = New clsA46V101A
               Set clsA46V101A.M46V999 = gM46V999

               If Not clsA46V101A.gfCriArqCancelamentoEmissao(lCodCorretor, lUsuario, gM46V111.gComNosNumero, objstcPedido.Num_PI_Emissao, lMensagem) Then
                   Call gM46V999.gpGraLog(1, lMensagem)
                   Screen.MousePointer = vbDefault
                   Exit Function
               End If

               Set clsA46V101A = Nothing

               Call gfExecTransmissao(enum_TipTransmissao_Transmissao, True)

               Call gM46V999.gpGraLog(1, "AGE0002 - " & gM46V999.gPrefixo & _
                                "O protocolo de cancelamento ser� enviado nas pr�ximas conex�es.")

               Unload Me
           Else
               If barFerramentas.Buttons("Salvar").Enabled = True Then
                   lMensagem = "AGE0022 - Pr�mio n�o calculado. (transmiss�o)"
                   Call gM46V999.gpGraLog(1, lMensagem)
                   Screen.MousePointer = vbDefault
                   Exit Function
               End If

               '1. Verifica controle de transmiss�o.
               ' If gfVerTransmissao = False Then
               '     Screen.MousePointer = vbDefault
               '     GoTo TrataErro
               ' End If

               '2. Verifica se os dados j� est�o calculados (as bases de dados e os recordsets ficar�o abertos).
               If mfVerDados(lTipDocumento, lMensagem) = False Then
                   lMensagem = lMensagem & " (transmiss�o)"
                   Call gM46V999.gpGraLog(1, lMensagem)
                   Screen.MousePointer = vbDefault
                   Exit Function
               End If

               '3. Verifica se � proposta.
               If lTipDocumento <> 3 And lTipDocumento <> 4 Then
                   lMensagem = "FGE0021 - " & gM46V999.gPrefixo & "Documento em fase de cota��o."
                   Call gM46V999.gpGraLog(1, lMensagem & " (transmiss�o)")
                   Screen.MousePointer = vbDefault
                   Exit Function
               End If


               '4. Posiciona controles para criar arquivo de transmiss�o.
               If gM46V999.gfPreenchido(frmT46V102A.txtCorretor(1).Tag) Then
                   lCodCorretor = frmT46V102A.txtCorretor(1).Tag
               Else
                   lCodCorretor = 9999999
               End If

               '5. Busca o usuario de Transmissao
               If gfBuscaUsuarioTransmissao(lUsuario, lMensagem) = False Then
                  lMensagem = lMensagem & " Linha: 245"
                   GoTo TrataErro
               End If
               lArqIni = gM46V999.gAppPath & "SYASMULTI.INI"
               Set clsA46V101A = New clsA46V101A
               Set clsA46V101A.M46V999 = gM46V999

               Set objPedido.Colecao = New Collection
               objPedido.Colecao.Add objstcPedido, objstcPedido.Class_ID

               If pAutomatico = False Then
                   Dim lDataDigit As Long
                   'Projeto 9075 **- Confirma��es somente quando acionado pelo uau�rio
              If ((objstcPedido.Tip_Cust_Emis = 5 Or objstcPedido.Tip_Cust_Emis = 4) And _
              objstcPedido.objstcCtrlEmis.Num_Bloq = 0) Or objstcPedido.Ind_Reentrada Then
                       If mfVerificarNumBoletoDisp(lDataDigit, 1) = False Then
                           Exit Function
                       End If
                       'lMensagem = "FGE2062 - " & gM46V999.gPrefixo & "Antes de transmitir este documento � necess�rio visualizar o documento de proposta para que o boleto seja gerado."
                       'GoTo TrataErro
                   End If

                   '6. Confirma com usu�rio.
                   lMensagem = "AGE0021 - " & gM46V999.gPrefixo & "Confirma transmiss�o da proposta?"
                   Select Case MsgBox(lMensagem, vbYesNo + vbExclamation + vbDefaultButton2)
          Case vbYes
                       Call gM46V999.gpGraLog(0, lMensagem & " Sim.")
                   Case vbNo
                       Call gM46V999.gpGraLog(0, lMensagem & " N�o.")
                       mfTransmitir = True
                       GoTo SAIDA
                   End Select
                   '7. Cria arquivo de transmiss�o.
              If clsA46V101A.gfCriArqTransmissao(lCodCorretor, lUsuario, _
                                             objPedido.Colecao, lArqTransmissao, lMensagem) = False Then
                      lMensagem = lMensagem & " Linha: 278"
                       GoTo TrataErro
                   End If

                   '8. Transmite arquivo de proposta.
                   Call gfExecTransmissao(enum_TipTransmissao_Transmissao, True)

                   mTransmitiu = True
              Call gM46V999.gpGraLog(0, "AGE0002 - " & gM46V999.gPrefixo & _
                                    "Processo conclu�do: cria��o do arquivo de transmiss�o " & lArqTransmissao & ".")
                   '9. Altera registros de dados comuns para indicar proposta transmitida.
                   objstcPedido.Cod_Sit_Ped = e_SitPedido_Transmitido
                   If Not objPedido.mfAlterar(objstcPedido, "", "") Then
                       lMensagem = objPedido.UltimoErro & " Linha: 292"
                       GoTo TrataErro
                   End If
                   gCarga = True
                   Call mfPosComum(lMensagem)
                   Call mpPosItem(objstcPedLoc)
                   gCarga = False
               Else
                   'Projeto 9075 **- Apenas transmite de forma oculta...
                   '6. Cria arquivo de transmiss�o.
                   If gM46V999.gNovaTransmissaoMulti = False Then
                  If clsA46V101A.gfCriArqTransmissao(lCodCorretor, lUsuario, _
                                                 objPedido.Colecao, lArqTransmissao, lMensagem, True, objstcPedido.Cod_Unicidade) = False Then
                           lMensagem = lMensagem & " Linha: 303"
                           GoTo TrataErro
                       End If
                       '7. Transmite arquivo de proposta.
                       Call gfExecTransmissao(enum_TipTransmissao_TransmHide, False)
                   End If
               End If
           End If
       End Select

Inspecao:
      ' Garantir que a inspe��o (se houver) foi agendada
      Call gM46V999.forcaStatusInspecao(objstcPedido.NUM_PI)
      Call gM46V999.gpGraLog(0, "Call forcaStatusInspecao - " & objstcPedido.NUM_PI)
      '************* Transmitido com sucesso
      mfTransmitir = True
      '************* Transmitido com sucesso
SAIDA:
    If mfTransmitir = True Then
  If Not (objstcPedido Is Nothing Or objstcPedido Is Nothing) Then
      Call gM46V999.updAtualizaStatusInspecao(objstcPedido.NUM_PI, lMensagem, objstcPedido)
      Call gM46V999.gpGraLog(0, "Call updAtualizaStatusInspecao - " & objstcPedido.NUM_PI)
  End If
    End If
    '9. Encerra processo.
    GoSub FechaObj
    Screen.MousePointer = vbDefault
    Err.Clear
    
    If lVoltarFormularioAnterior Then
  Call mnuArqSaiItem_Click
    End If
    
    Exit Function

TrataErro:
    If gM46V999.gfPreenchido(lMensagem) = False Then
  lMensagem = Err & " - " & ERROR
    End If
    pMsgErr = "mfTransmitir Erro:" & lMensagem & IIf(Err.Number > 0, "Linha nr: " & Erl, "")
    GoTo SAIDA

FechaObj:
    Set clsA46V101A = Nothing
    Return
End Function

