Private Function GravaPIinspecao(ByRef pobjPedido As clsA46V702A, ByRef pobjstcPedido As stcA46V702B, ByRef pMensagem As String) As Boolean
    Dim lrsTab_Aux As clsYasRecordSet
    Dim PedLoc As stcA46V708B
    Dim lSql As String
    On Error GoTo TrataErro
    
    GravaPIinspecao = False

    'Call gM46V999.gpGraLog(0, "Call GravaPIinspecao - " & pobjstcPedido.NUM_PI)

    For Each PedLoc In pobjstcPedido.ColecaoPedLoc
        If PedLoc.Num_Insp > 0 Then
            lSql = "select top 1 num_insp, NUM_PI from inspecao..Tab_DistrEmail nolock where num_insp = " & PedLoc.Num_Insp
            lSql = lSql & " and NUM_PI in (0, " & pobjstcPedido.NUM_PI & ")"
            lSql = lSql & " and Num_Item = " & PedLoc.Num_Item

            If Not gM46V999.gfObtRegistro(pobjPedido.ConexaoBD, lSql, lrsTab_Aux, pMensagem) Then
                If gM46V999.gfPreenchido(pMensagem) Then
                    GoTo TrataErro
                End If
            End If
            
            If Not lrsTab_Aux.EOF Then
                If lrsTab_Aux!NUM_PI = 0 Then
                    Set lrsTab_Aux = Nothing
                    lSql = "update inspecao..Tab_DistrEmail set Num_PI = " & pobjstcPedido.NUM_PI
                    lSql = lSql & " where Num_Insp = " & PedLoc.Num_Insp
                    lSql = lSql & " and Num_PI = 0"
                    lSql = lSql & " and Num_Item = " & PedLoc.Num_Item
                    If gM46V999.gfExeSQL(pobjPedido.ConexaoBD, lSql, pMensagem) <> 0 Then
                        If gM46V999.gfPreenchido(pMensagem) Then
                            GoTo TrataErro
                        End If
                    End If
                End If
            Else
                Set lrsTab_Aux = Nothing
                lSql = "insert into inspecao..Tab_DistrEmail (Num_Insp,Cod_Ramo,Cod_Tipo,End_Email,Dat_Cadastro,Dat_Envio,NUM_PI,Num_Item) VALUES ("
                lSql = lSql & PedLoc.Num_Insp & ", " & pobjstcPedido.Cod_Ramo & ", 3, 'pendenciainspecao@sompo.com.br', " & Format(Now, "yyyymmddhhmmss") & ", 0, " & pobjstcPedido.NUM_PI & ", " & PedLoc.Num_Item & ")"
                If gM46V999.gfExeSQL(pobjPedido.ConexaoBD, lSql, pMensagem) <> 0 Then
                    If gM46V999.gfPreenchido(pMensagem) Then
                        GoTo TrataErro
                    End If
                End If
            End If
        End If
    Next PedLoc

    GravaPIinspecao = True
    
Fim:
    Exit Function
    
TrataErro:
    If Err.Number <> 0 Then
        pMensagem = "Erro: " & Err & " Descri��o: " & Err.Description & " SQL: " & lSql
    End If
    pMensagem = "[ERR] - GravaPIinspecao: " & pMensagem
    GoTo Fim
End Function
