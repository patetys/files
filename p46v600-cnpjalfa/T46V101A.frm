Private Sub mpVerTelefone()

    On Error GoTo Erro:

    If gM46V999.gfDisponivel("frmT46V102A") Then
        With frmT46V102A
            Dim lQtdTelPrinc As Integer
            Dim lQtdTel As Integer
            Dim lI As Integer
            Dim lJ As Integer
            Dim lLinTelPrinc As Integer
            Dim lerroTipoTelefone As Boolean
            Dim lerroDDD As Boolean
            Dim lerroTelefone As Boolean

            lerroTipoTelefone = False
            lerroDDD = False
            lerroTelefone = False
            lQtdTelPrinc = 0
            lQtdTel = 0
            lLinTelPrinc = 0

            For lI = 1 To .flxTelefones.Rows - 1
                'Verifica se a linha est� preenchida
                If Not (.flxTelefones.TextMatrix(lI, 1) = Empty And val(.flxTelefones.TextMatrix(lI, 2)) = 0 And val(.flxTelefones.TextMatrix(lI, 3)) = 0) Then

                    'Conta telefones marcados como principal
                    .flxTelefones.Col = 0
                    .flxTelefones.row = lI
                    If .flxTelefones.CellPicture = .picChecked Then
                        lLinTelPrinc = lI
                        lQtdTelPrinc = lQtdTelPrinc + 1
                    End If
                    lQtdTel = lQtdTel + 1

                    'Verifica se o tipo do telefone � valido
                    If .flxTelefones.TextMatrix(lI, 1) = Empty And lerroTipoTelefone = False Then
                        gM46V999.gpMenErro ("Consist�ncia do comum - Tipo de telefone inv�lido na tela de Dados da Proposta.")
                        lerroTipoTelefone = True
                    End If

                    'Verifica se o DDD do telefone � valido
                    If (val(.flxTelefones.TextMatrix(lI, 2)) = 0 Or Len(.flxTelefones.TextMatrix(lI, 2)) < 2) And lerroDDD = False Then
                        gM46V999.gpMenErro ("Consist�ncia do comum - DDD do telefone inv�lido na tela de Dados da Proposta.")
                        lerroDDD = True
                    End If

                    'Verifica se o telefone � valido
                    If (val(.flxTelefones.TextMatrix(lI, 3)) = 0 Or Len(.flxTelefones.TextMatrix(lI, 3)) < 8) And lerroTelefone = False Then
                        gM46V999.gpMenErro ("Consist�ncia do comum - Telefone inv�lido na tela de Dados da Proposta.")
                        lerroTelefone = True
                    End If

                End If
            Next lI
            
            'Verifica se existe mais de 1 telefone marcado como principal
            If lQtdTelPrinc = 0 Then
                .txtTelefones.Text = 0
                If lQtdTel > 0 Then
                    'gM46V999.gpMenErro ("Consist�ncia do comum - � necess�rio marcar um telefone como principal.")
                End If
            Else
                If lQtdTelPrinc = 1 Then
                    .txtTelefones.Text = .flxTelefones.TextMatrix(lLinTelPrinc, 3)
                Else    '> 1
                    gM46V999.gpMenErro ("FNL0053 - H� mais de um telefone marcado como principal na tela de Dados da Proposta.")
                End If
            End If

            'Verifica inclus�o de ao menos 1 Telefone se for proposta
            'If objstcPedido.Cod_Tip_Doc = e_TipDoc_Proposta And lQtdTel = 0 Then
            '    Call gM46V999.gpMenErro("FNP0006 - � necess�rio preeencher pelo menos um telefone.(F5 - dados proposta).")
            'End If

            Dim linha1 As String
            Dim linha2 As String

            'Verifica duplicidade de registro
            For lI = 1 To .flxTelefones.Rows - 1
                For lJ = lI + 1 To .flxTelefones.Rows - 1
                    If Not (.flxTelefones.TextMatrix(lI, 1) = Empty And val(.flxTelefones.TextMatrix(lI, 2)) = 0 And val(.flxTelefones.TextMatrix(lI, 3)) = 0) And _
                       Not (.flxTelefones.TextMatrix(lJ, 1) = Empty And val(.flxTelefones.TextMatrix(lJ, 2)) = 0 And val(.flxTelefones.TextMatrix(lJ, 3)) = 0) Then
                        linha1 = .flxTelefones.TextMatrix(lI, 1) & .flxTelefones.TextMatrix(lI, 2) & .flxTelefones.TextMatrix(lI, 3) & .flxTelefones.TextMatrix(lI, 4)
                        linha2 = .flxTelefones.TextMatrix(lJ, 1) & .flxTelefones.TextMatrix(lJ, 2) & .flxTelefones.TextMatrix(lJ, 3) & .flxTelefones.TextMatrix(lJ, 4)

                        If linha1 = linha2 Then
                            gM46V999.gpMenErro ("Consist�ncia do comum - Telefone cadastrado em duplicidade na tela de Dados da Proposta.")
                            GoTo Fim
                        End If
                    End If
                Next lJ
            Next lI

        End With
    End If

Fim:
    Exit Sub
    Resume 0
Erro:
    Call gM46V999.gpMenErro("Consist�ncia do comum - " & Err.Description)
    Resume Fim
End Sub

Private Sub mpValidaParcela()
    Dim lMaxParcela As Integer  'N�mero m�ximo de parcelas permitido
    Dim lMaxParcelaAux As Integer     'N�mero m�ximo de parcelas permitido
    Dim lMaxParcelaVista As Integer       'N�mero m�ximo de parcelas permitido a vista
    Dim lMaxParcela30Dia As Integer       'N�mero m�ximo de parcelas permitido 30 dias
    Dim lDataUltVencimento As Double          'Data do ultimo vencimento possivel
    Dim lQutdeParcelas As Integer     'Quantidade de parcelas
    Dim lobjstcParc As stcA46V713B

    'Determina quantide m�xima de parcelas
    Call mpObtemMaxParcelas(gM46V999.gProQuaMaxParcelas, lMaxParcelaVista, lMaxParcela30Dia, lDataUltVencimento)

    'Informa o maior valor de parcelas
    If lMaxParcelaVista > lMaxParcela30Dia Then
        lMaxParcela = lMaxParcelaVista
    Else
        lMaxParcela = lMaxParcela30Dia
    End If

    'Guarda na variavel o numero de parcelas informado
    lQutdeParcelas = objstcPedido.Qtd_Parc
    If objstcPedido.Cod_Reg = 120 Or objstcPedido.Cod_Reg = 106 Or objstcPedido.Cod_Reg = 107 Then
        lQutdeParcelas = 0
        objstcPedido.Qtd_Parc = 0
    End If
    'caso seja proposta limita o numero maximo para o tipo
    'escolhido (antecipado ou 30dias)

    'Ficha 900665
    '    If objstcPedido.Cod_Tip_Doc = e_TipDoc_Proposta Then
    If objstcPedido.objstcCtrlEmis.Cod_Iden_Pag_Antec = e_SimNao_Sim Then
        lMaxParcela = lMaxParcelaVista
    Else
        lMaxParcela = lMaxParcela30Dia
    End If
    'ENDOSSO
    'Ap�s o c�lculo � que ser� consistido se a postecipada � permitida ou n�o.
    'atrav�s da vari�vel lMaxParcelaAux.
    lMaxParcelaAux = lMaxParcela
    If lMaxParcela = 0 And objstcPedLoc.Tip_Emissao >= 300 Then
        lMaxParcela = 1
    End If
    '    End If

    'Plano Mercedes ou RVA permite 11 parcelas
    If (gM46V111.gCod_plano >= 2021 And gM46V111.gCod_plano <= 2031) Or _
       (gM46V111.gCod_plano >= 2326 And gM46V111.gCod_plano <= 2349) Or _
       (gM46V111.gCod_plano >= 2350 And gM46V111.gCod_plano <= 2373) Or _
       (gM46V111.gCod_plano = 2303 And objstcPedido.Cod_Ramo = e_CodRamo_Empresarial) Or _
       (gM46V111.gCod_plano = 2374 And objstcPedido.Cod_Ramo = e_CodRamo_Residencial) Then
        lMaxParcela = 11
    End If

    If objstcPedido.Cod_Tip_Doc = e_TipDoc_Cotacao Then
        'ajusta o numero de parcelas caso retorne 0
        If lMaxParcela <= 0 Then
            lMaxParcela = 1
        End If
        'Se = Cota��o ent�o atualiza o campo no form
        If objstcPedido.Qtd_Parc > lMaxParcela Then
            'Ficha 900665
            'Call gM46V999.gpMenErro("FGE0075 - Quantidade de parcelas inv�lida. N�mero m�ximo de parcelas permitido: " & lMaxParcela)
            'Exit Sub
            gCarga = True
            frmT46V102A.txtQuaParcelas.Text = lMaxParcela
            gCarga = False
            objstcPedido.Qtd_Parc = lMaxParcela
        End If
    Else
        'Verifica se o numero informado � maior que o permitido
        If lQutdeParcelas > lMaxParcela Then
            If objstcPedido.ColecaoPedVenc.Count > 0 And gM46V999.gTipUsuario = e_Tipo_Usu_Yasuda Then
                For Each lobjstcParc In objstcPedido.ColecaoPedVenc
                    If lobjstcParc.DAT_VENC > objstcPedido.Dat_Ter_Vig Then
                        Call gM46V999.gpMenErro("FGE0075 - Quantidade de parcelas inv�lida (Data da �ltima parcela n�o deve ultrapassar " & _
                                                gM46V999.gfForData(2, lobjstcParc.DAT_VENC) & ". " & val(gM46V999.gfDifDatas(lDataUltVencimento, gM46V999.gfForData(1, Format(CDate(frmT46V101A.txtVigTermino.Text), "dd/mm/yyyy")))) & _
                                              " dias antes do t�mino da vig�ncia  )." & vbCrLf & "N�mero m�ximo de parcelas permitido: " & lMaxParcela)
                        Exit Sub
                    End If
                Next lobjstcParc
                lMaxParcela = lQutdeParcelas
            Else
                If lDataUltVencimento = 0 Then
                    Call gM46V999.gpGraLog(1, "FGE0075 - Quantidade de parcelas inv�lida (Data da �ltima parcela deve ser inferior a data de t�rmino da vig�ncia)." & vbCrLf & "N�mero m�ximo de parcelas permitido: " & lMaxParcela)
                Else
                    If val(gM46V999.gfDifDatas(lDataUltVencimento, gM46V999.gfForData(1, Format(CDate(frmT46V101A.txtVigTermino.Text), "dd/mm/yyyy")))) > 0 Then
                        Call gM46V999.gpMenErro("FGE0075 - Quantidade de parcelas inv�lida (Data da �ltima parcela n�o deve ultrapassar " & _
                                                gM46V999.gfForData(2, lDataUltVencimento) & ". " & val(gM46V999.gfDifDatas(lDataUltVencimento, gM46V999.gfForData(1, Format(CDate(frmT46V101A.txtVigTermino.Text), "dd/mm/yyyy")))) & _
                                              " dias antes do t�mino da vig�ncia  )." & vbCrLf & "N�mero m�ximo de parcelas permitido: " & lMaxParcela)
                    Else
                        Call gM46V999.gpMenErro("FGE0075 - Quantidade de parcelas inv�lida (Data da �ltima parcela deve ser inferior a data de t�rmino da vig�ncia)." & vbCrLf & "N�mero m�ximo de parcelas permitido: " & lMaxParcela)
                    End If
                End If
                Exit Sub
            End If
        End If

        'Pagamento postecipado excluido com exce��o de Planos, Segmenta��o, Endossos,
        'corretor 1601 - SEGURATEC ramo Residencial a partir da tarifa 1074
        'corretor 383111 - ALFATEC ramos Residencial e Empresarial a partir da tarifa 1074
        'OBTEM O CORRETOR DA TELA POIS QUANDO O ACESSO VEM DO KIT A VARIAVEL ESTA ZERADA
        'Ajuste para planinho ipiranga tb validar a regra
        gM46V999.gCod_Corretor = frmT46V102A.txtCorretor(1).Tag
        If objstcPedido.Cod_Produto < 1086 And objstcPedido.ColecaoPedLoc(1).Ren_Con_Seguradora <> 572 Then
            If objstcPedido.Cod_Segmentacao <> 13 And _
               objstcPedido.objstcCtrlEmis.Cod_Iden_Pag_Antec = 2 And _
               (gM46V111.gCod_plano < 1000 Or (gM46V111.gCod_plano = 2300 And objstcPedido.Cod_Ramo = e_CodRamo_Empresarial)) And _
               gM46V999.gCodProduto >= 1072 And _
               ((objstcPedido.Cod_Dizer = 0 And gM46V999.gCodProduto < 1080) Or _
               (objstcPedido.Cod_Dizer >= 0 And objstcPedido.Num_Apol_An = 0 And gM46V999.gCodProduto >= 1080)) Then
    
                If gM46V999.gPermitePostecipada Then
                    If MsgBox("Deseja realmente emitir o pagamento postecipado?", vbQuestion + vbYesNo + vbDefaultButton2) = vbNo Then
                        gM46V999.gPermitePostecipada = False
                    End If
                End If
    
                If gM46V999.gCodProduto < 1074 And gM46V999.gPermitePostecipada = False Then
                    Call gM46V999.gpMenErro("FGE0075 - Pagamento Postecipado n�o permitido.")
                    Exit Sub
                Else
                    If ((gM46V999.gCod_Corretor <> 1601) Or (gM46V999.gCod_Corretor = 1601 And gM46V999.gCod_Ramo <> e_CodRamo_Residencial)) And _
                       ((gM46V999.gCod_Corretor <> 383111) Or (gM46V999.gCod_Corretor = 383111 And gM46V999.gCod_Ramo = e_CodRamo_Condominio)) Then
    
                        If gM46V999.gPermitePostecipada = False Then
                            Call gM46V999.gpMenErro("FGE0075 - Pagamento Postecipado n�o permitido.")
                        End If
                        Exit Sub
                    End If
                End If
            End If
        End If
    End If
End Sub
Private Sub mpVerJurAntPos(ByVal pOrdem As Byte, ByVal pJurosAnt As Single, _
