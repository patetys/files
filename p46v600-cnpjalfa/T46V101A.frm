Private Sub txtRisCEP_LostFocus()
'Rotina Alterada para atender a nova Precifica��o
    Dim lbdP0043000 As ADODB.Connection    'Arquivo - P0043000.
    Dim lBDP00Multi As ADODB.Connection    'Arquivo - P00Multi.
    Dim lMensagem As String         'Mensagem.
    Dim lrsP0043000 As clsYasRecordSet  'Registro - P0043000.
    Dim lrsP00Multi As clsYasRecordSet  'Registro - P00Multi.
    Dim lPos As Byte
    Dim lCEP As String
    Dim lSelect As String
    If gCarga Then Exit Sub

    'Ficha  0901618  - LMI
    'If chkLMI.Value = vbChecked Then
    '   Exit Sub
    'End If


    Screen.MousePointer = vbHourglass

    With txtRisCEP
        '1. Trata campo do CEP.
        If gM46V999.gfPreenchido(mAntCEP) Then
            If gM46V999.gfPreenchido(.Text) Then
                If Replace(mAntCEP, "-", "") = Replace(.Text, "-", "") Then
                    .Text = Left(.Text, 5) & "-" & Right(.Text, 3)
                    If Len(txtRisRegiao.Tag) <> 10 Or val(txtRisRegiao.Tag) = 0 Then
                        GoTo CarregaRegiao
                    End If
                    Screen.MousePointer = vbDefault
                    Exit Sub
                End If
            Else
                If Len(txtRisRegiao.Tag) <> 10 Or val(txtRisRegiao.Tag) = 0 Then
                    GoTo CarregaRegiao
                End If
                Screen.MousePointer = vbDefault
                Exit Sub
            End If
        Else
            If Not gM46V999.gfPreenchido(.Text) Then
                Screen.MousePointer = vbDefault
                Exit Sub
            End If
        End If
        .Text = Trim$(.Text)
        Select Case Len(.Text)
        Case Is < 8
            lPos = InStr(1, .Text, "-")
            If lPos > 6 Then
                .Text = .Text
            ElseIf lPos < 6 And lPos <> 0 Then
                .Text = Format(Left(.Text, lPos - 1), "00000") & "-" & Format(Left(Mid(.Text, lPos + 1), 3), "000")
            Else
                .Text = Format(Format(.Text, "00000000"), "00000-000")
            End If
        Case 8
            lPos = InStr(1, .Text, "-")
            If lPos > 6 Then
                .Text = .Text
            ElseIf lPos <= 6 And lPos <> 0 Then
                .Text = Format(Left(.Text, lPos - 1), "00000") & Left(Mid(.Text, lPos + 1) & "000", 3)
            End If

            If Not IsNumeric(.Text) Then
                Call gM46V999.gpGraLog(1, "FGE0039 - " & gM46V999.gPrefixo & _
                                          "CEP de pernoite do ve�culo inv�lido (n�o num�rico).")
                .Text = ""
                If .Visible = True And .Enabled = True Then
                    .SetFocus
                End If
                Screen.MousePointer = vbDefault
                Exit Sub
            End If
            mPrograma = True
            .Text = Mid$(.Text, 1, 5) & "-" & Mid$(.Text, 6, 3)
            mPrograma = False
            lCEP = .Text
        Case 9
            If Not IsNumeric(Mid$(.Text, 1, 5)) Or Not IsNumeric(Mid$(.Text, 7, 3)) Then
                Call gM46V999.gpGraLog(1, "FGE0001 - " & gM46V999.gPrefixo & "CEP inv�lido (endere�o do segurado - " & .Text & _
                                        " - n�o num�rico - fora do formato nnnnn-nnn).")
                .Text = ""
                If .Visible = True And .Enabled = True Then
                    .SetFocus
                End If
                Screen.MousePointer = vbDefault
                Exit Sub
            End If
        End Select
        .Text = Format(Replace(Trim(.Text), "-", ""), "00000-000")
        If Len(Trim(.Text)) = 8 Then
            If IsNumeric(.Text) Then
                .Text = Left$(.Text, 5) & "-" & Right$(.Text, 3)
            End If
        End If

        '3. Obt�m CEP.
        'a) Abre arquivo.
        If gM46V999.gfAbrBasDados("P0043000", gM46V999.gTipP0043000, gM46V999.gEndP0043000, lbdP0043000, lMensagem) = False Then
            Screen.MousePointer = vbDefault
            Exit Sub
        End If
        'b) Obt�m registro.
        lSelect = "SELECT * FROM P0043000 WHERE Num_CEP = '" & Left$(.Text, 5) & Right$(.Text, 3) & "'"
        If gM46V999.gfObtRegistro(lbdP0043000, lSelect, lrsP0043000, lMensagem) = False Then
            Call gM46V999.gpFecha2(lbdP0043000)
            Screen.MousePointer = vbDefault
            Exit Sub
        End If
        If lrsP0043000.EOF = True Then
            Call gM46V999.gpGraLog(1, "FNL0001 - " & gM46V999.gPrefixo & "CEP n�o localizado (" & .Text & ").")
            Call gM46V999.gpFecha2(lbdP0043000)
            Screen.MousePointer = vbDefault
            mAntCEP = "0"
            Exit Sub
        End If
        'c) Posiciona endere�o.
        If gM46V999.gNovaPropostaLMI Then
            If gM46V999.gfPreenchido(lrsP0043000!tip_logr) Then
                txtRisTipLogradouro.Text = lrsP0043000!tip_logr
            Else
                txtRisTipLogradouro.Text = ""
            End If
            If gM46V999.gfPreenchido(lrsP0043000!Nom_Logr) Then
                txtRisNomLogradouro.Text = Left(lrsP0043000!Nom_Logr, IIf(InStr(1, lrsP0043000!Nom_Logr, "-") > 0, InStr(1, lrsP0043000!Nom_Logr, "-") - 2, 200))
            Else
                txtRisNomLogradouro.Text = ""
            End If
            txtRisComplemento.Text = ""
        Else
            'Ficha  0901618  - LMI
            If chkLMI.Value = vbUnchecked Then
                If gM46V999.gfPreenchido(lrsP0043000!tip_logr) Then
                    txtRisTipLogradouro.Text = lrsP0043000!tip_logr
                Else
                    txtRisTipLogradouro.Text = ""
                End If
                If gM46V999.gfPreenchido(lrsP0043000!Nom_Logr) Then
                    txtRisNomLogradouro.Text = Left(lrsP0043000!Nom_Logr, IIf(InStr(1, lrsP0043000!Nom_Logr, "-") > 0, InStr(1, lrsP0043000!Nom_Logr, "-") - 2, 200))
                Else
                    txtRisNomLogradouro.Text = ""
                End If
                txtRisComplemento.Text = ""
            End If
        End If
        If gM46V999.gfPreenchido(lrsP0043000!Nom_Bairro) Then
            txtRisBairro.Text = lrsP0043000!Nom_Bairro
        Else
            txtRisBairro.Text = ""
        End If
        If gM46V999.gfPreenchido(lrsP0043000!Nom_Cid) Then
            txtRisCidade.Text = lrsP0043000!Nom_Cid
        Else
            txtRisCidade.Text = ""
        End If
        If gM46V999.gfPreenchido(lrsP0043000!Sig_UF) Then
            cboRisUF.Text = lrsP0043000!Sig_UF
        Else
            cboRisUF.ListIndex = -1
        End If
        'd) Fecha tabela e arquivo.
        Call gM46V999.gpFecha2(lbdP0043000)

        Dim lI As Long
        Dim lTemProt As Boolean

        If objstcPedLoc.Cod_DizerItem = 12 Then
            'Por ter sido alterado o local de risco. Retirar os protecionais
            lTemProt = False
            If optProtecao(0).Value = True Then
                For lI = 0 To frmT46V137A.flxProtecao.Rows - 1
                    If frmT46V137A.flxProtecao.TextMatrix(lI, 4) = "Marcado" Then
                        If Not UCase(frmT46V137A.flxProtecao.TextMatrix(lI, 2)) Like "*DESCONTO ESPECIAL*" Then
                            frmT46V137A.flxProtecao.row = lI
                            frmT46V137A.flxProtecao.Col = 0
                            Set frmT46V137A.flxProtecao.CellPicture = LoadPicture("")
                            frmT46V137A.flxProtecao.TextMatrix(lI, 4) = ""
                            frmT46V137A.flxProtecao.Col = 3
                            frmT46V137A.flxProtecao.CellBackColor = &H80000000
                        Else
                            lTemProt = True
                        End If
                    End If
                Next lI
                If lTemProt = False Then
                    optProtecao(1).Value = True
                End If
            End If
        End If

CarregaRegiao:
        If cboPlano.ListIndex <> -1 Then
            If gM46V999.gCodProduto > gM46V999.TarifaAntiga Then
                txtRisRegiao.Text = ""
                objstcPedLoc.Cod_Regiao = 0
                txtRisRegiao.Visible = False
                lblRisRegiao.Visible = False
                objstcPedLoc.Cod_Produto = cboPlano.ItemData(cboPlano.ListIndex)
                gM46V111.gCod_plano = objstcPedLoc.Cod_Produto
                txtRisRegiao.Tag = Format(objstcPedLoc.Cod_Regiao, "00000") & Format(objstcPedLoc.Cod_Produto, "00000")
                gM46V111.gCod_Regiao = val(Right(frmT46V101A.txtRisRegiao.Tag, 4))
            ElseIf cboPlano.ItemData(cboPlano.ListIndex) < 1020 Then
                'Busco o c�digo da regi�o.
                If gM46V999.gfAbrBasDados("P00MULTI2", gM46V999.gTipP00MULTI, gM46V999.gEndP00MULTI, lBDP00Multi, lMensagem) = False Then
                    Call gM46V999.gpGraLog(1, lMensagem)
                    Screen.MousePointer = vbDefault
                    Exit Sub
                End If
                'b) Obt�m registro.
                If Not gM46V999.gfPreenchido(.Text) Then .Text = "0"
                lSelect = "SELECT * FROM TAB_CEP_REGIAO WHERE CEP_INI <= " & Left$(.Text, 5) & Right$(.Text, 3) & _
                        " and CEP_FIM >= " & Left$(.Text, 5) & Right$(.Text, 3)

                If gM46V999.gfObtRegistro(lBDP00Multi, lSelect, lrsP00Multi, lMensagem) = False Then
                    Call gM46V999.gpFecha2(lBDP00Multi)
                    Call gM46V999.gpGraLog(1, lMensagem)
                    Screen.MousePointer = vbDefault
                    Exit Sub
                End If
                If lrsP00Multi.EOF = True Then
                    Call gM46V999.gpFecha2(lBDP00Multi)
                    Screen.MousePointer = vbDefault
                    Exit Sub
                End If
                'objstcPedLoc.Cod_Produto = 0

                objstcPedLoc.Cod_Regiao = lrsP00Multi("Cod_Regiao")
                txtRisRegiao.Text = objstcPedLoc.gDesc_Regiao
                txtRisRegiao.Tag = Format(objstcPedLoc.Cod_Regiao, "00000") & Format(objstcPedLoc.Cod_Produto, "00000")
                txtRisRegiao.Visible = True
                lblRisRegiao.Visible = True
                gM46V111.gCod_Regiao = val(Right(frmT46V101A.txtRisRegiao.Tag, 4))
                If txtClassificacao.Tag = "0" Or txtClassificacao.Tag = "" And gCarga = False Then
                    Screen.MousePointer = vbDefault
                    Call cmdClassificacao_Click
                End If
            Else
                txtRisRegiao.Text = ""
                objstcPedLoc.Cod_Regiao = 0
                txtRisRegiao.Tag = "0"
                gM46V111.gCod_Regiao = 0
            End If
        End If
        If gCarga = False And Me.Tag <> "Desabilitado" Then
            'Call frmT46V117A.mpCepAlterado
            frmT46V117A.gCepAlterado = True
        End If
        mAntCEP = .Text
    End With

    Screen.MousePointer = vbDefault

End Sub

