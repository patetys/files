            If IsNumeric(.Text) Then
                .Text = Format(.Text, "standard")
                If .Text > 2147483647 Then
                    MsgBox "Valor em risco excedeu o limite!", vbInformation, "Aten��o"
                    txtValoRisco.SetFocus
                End If
            Else
                .Text = Format(0, "standard")
            End If
        Else
            .Text = Format(0, "standard")
        End If
