Private Function mfSalvarInspecao(pMensagem As String) As Boolean
    Dim lobjInspecao As clsA46V717A   'Objeto da classe clsA46V717A (TAB_PED_INSP).

    On Error GoTo ControleErro

    Set lobjInspecao = New clsA46V717A
    Set lobjInspecao.M46V999 = gM46V999

    Set lobjInspecao.ConexaoBD = objPedido.ConexaoBD
    If gM46V999.gfPreenchido(objstcPedLoc.objstcPedInsp.nosso_numero) Then
        objstcPedLoc.objstcPedInsp.nosso_numero = objstcPedLoc.nosso_numero
        objstcPedLoc.objstcPedInsp.Num_Item = objstcPedLoc.Num_Item
        If Not lobjInspecao.mfExcluir(objstcPedLoc.objstcPedInsp, "", "") Then
            pMensagem = lobjInspecao.UltimoErro
            GoTo Finalizar
        End If
    End If

    With objstcPedLoc.objstcPedInsp
        .nosso_numero = objstcPedLoc.nosso_numero
        .Num_Item = objstcPedLoc.Num_Item
        .Dat_Cadastro = Left(gM46V999.gfForData(3), 8)
        .Num_Logr_Risco = val(txtRisNumero.Text)
        .Cod_Ramo = objstcPedido.Cod_Ramo
        .Num_Ped = objstcPedLoc.Num_Ped
        .Num_Insp = objstcPedLoc.Num_Insp 'Adicionado por Luiz Alberto em 19/02/2016
    End With
    
    'CR102518
    Call frmT46V193A.SalvarDados(objstcPedLoc.objstcPedInsp)
    
    objstcPedLoc.objstcPedInsp.NUM_PI = objstcPedLoc.NUM_PI
    If Not lobjInspecao.mfIncluir(objstcPedLoc.objstcPedInsp, "", "", "") Then
        pMensagem = lobjInspecao.UltimoErro
        GoTo Finalizar
    End If
    mfSalvarInspecao = True

Finalizar:
    Set lobjInspecao = Nothing
    Exit Function
ControleErro:
    Set lobjInspecao = Nothing
    If gM46V999.gfPreenchido(pMensagem) = False Then
        pMensagem = Err.Description
    End If
    Call gM46V999.gpGraLog(0, "mfSalvarInspecao ERRO - " & Err & " " & ERROR & _
                              Chr(13) & pMensagem)
End Function
Private Function mfSalvarSeguros(pMensagem As String) As Boolean
    Dim lobjPedLocSeg As clsA46V716A    'Objeto da classe clsA46V716A (TAB_PED_LOC_SEGURO).
    Dim lobjstcPedLocSeg As stcA46V716B       'Objeto da classe de estrutura stcA46V716B (TAB_PED_LOC_SEGURO).
    Dim lI As Integer    'Utilizado no for...loop

    On Error GoTo ControleErro

    Set lobjPedLocSeg = New clsA46V716A
    Set lobjPedLocSeg.M46V999 = gM46V999

    If objstcPedLoc.ColecaoPedSeguro.Count > 0 Then
        Set lobjstcPedLocSeg = New stcA46V716B
        lobjstcPedLocSeg.nosso_numero = objstcPedLoc.nosso_numero
        lobjstcPedLocSeg.Num_Item = objstcPedLoc.Num_Item
        If Not lobjPedLocSeg.mfExcluir(lobjstcPedLocSeg, "", "") Then
            pMensagem = lobjPedLocSeg.UltimoErro
            GoTo Finalizar
        End If
    End If
    Set objstcPedLoc.ColecaoPedSeguro = New Collection
    For lI = 1 To 5
        With frmT46V131A
            If .chkCosseguro(lI).Value = True Then
                If .cboConSeguradora(lI).ListIndex <> -1 Then
                    Set lobjstcPedLocSeg = New stcA46V716B
                    lobjstcPedLocSeg.nosso_numero = objstcPedLoc.nosso_numero
                    lobjstcPedLocSeg.Num_Item = objstcPedLoc.Num_Item
                    lobjstcPedLocSeg.Cod_Seguradora = .cboConSeguradora(lI).ItemData(.cboConSeguradora(lI).ListIndex)
                    lobjstcPedLocSeg.Dsc_Outro_Seguro = Left(.cboConSeguradora(lI).Text, 35)
                    lobjstcPedLocSeg.Num_Apol_Ant = .txtConApolice(lI).Text
                    lobjstcPedLocSeg.Num_Item_Ant = .txtConItem(lI).Text
                    lobjstcPedLocSeg.Num_Ordem = lI
                    lobjstcPedLocSeg.Ind_Sinistro = e_SimNao_Nao
                    If Not lobjPedLocSeg.mfIncluir(lobjstcPedLocSeg, "", "", "") Then
                        pMensagem = lobjPedLocSeg.UltimoErro
                        GoTo Finalizar
                    End If
                    objstcPedLoc.ColecaoPedSeguro.Add lobjstcPedLocSeg, lobjstcPedLocSeg.Class_ID
                End If
            End If
        End With
    Next lI
    mfSalvarSeguros = True
Finalizar:
    Set lobjPedLocSeg = Nothing
    Set lobjstcPedLocSeg = Nothing
    Exit Function
ControleErro:
    Set lobjPedLocSeg = Nothing
    Set lobjstcPedLocSeg = Nothing
    If gM46V999.gfPreenchido(pMensagem) = False Then
        pMensagem = Err.Description
    End If
    Call gM46V999.gpGraLog(0, "mfSalvarSeguros ERRO - " & Err & " " & ERROR & _
                              Chr(13) & pMensagem)
End Function

Private Function mfSalvarBens(pMensagem As String) As Boolean
    Dim lobjPedBem As clsA46V715A   'Objeto da classe clsA46V715A (TAB_PED_LOC_BEM).
    Dim lobjstcPedBem As stcA46V715B      'Objeto da classe de estrutura stcA46V715B (TAB_PED_LOC_BEM).
    Dim lI As Integer    'Utilizado no for...loop.
    Dim lCheck As String

    On Error GoTo ControleErro
    lCheck = 1
    Set lobjPedBem = New clsA46V715A
    Set lobjPedBem.M46V999 = gM46V999

    If objstcPedLoc.ColecaoPedLocBem.Count > 0 Then
        Set lobjstcPedBem = New stcA46V715B
        Set lobjstcPedBem.M46V999 = gM46V999

        lobjstcPedBem.nosso_numero = objstcPedLoc.nosso_numero
        lobjstcPedBem.Num_Item = objstcPedLoc.Num_Item
        lCheck = 2
        If Not lobjPedBem.mfExcluir(lobjstcPedBem, "", "") Then
            pMensagem = lobjPedBem.UltimoErro
            GoTo Finalizar
        End If
    End If
    lCheck = 3
    Set objstcPedLoc.ColecaoPedLocBem = New Collection
    lCheck = 4
    For lI = 1 To frmT46V129A.flxBens.Rows - 1
        lCheck = 5
        If gM46V999.gCod_Ramo = e_CodRamo_Roubos And _
           gM46V999.gfPreenchido(frmT46V129A.flxBens.TextMatrix(lI, 2)) And Trim(frmT46V129A.flxBens.TextMatrix(lI, 2)) <> "0" Then
            GoTo Salvar
        End If
        If (gM46V999.gCod_Ramo = e_CodRamo_Empresarial Or _
            gM46V999.gCod_Ramo = e_CodRamo_Residencial Or _
            gM46V999.gCod_Ramo = e_CodRamo_Condominio) And _
            gM46V999.gfPreenchido(frmT46V129A.flxBens.TextMatrix(lI, 1)) And Trim(frmT46V129A.flxBens.TextMatrix(lI, 1)) <> "0" Then
            GoTo Salvar
        Else
            GoTo Proximo
        End If

Salvar:
        Set lobjstcPedBem = New stcA46V715B
        Set lobjstcPedBem.M46V999 = gM46V999

        With lobjstcPedBem
            .nosso_numero = objstcPedLoc.nosso_numero
            .Num_Item = objstcPedLoc.Num_Item
            .Cod_Ramo = objstcPedido.Cod_Ramo
            .Num_Ped = objstcPedido.Num_Ped
            .Dsc_Bem = gM46V999.gfRetirarCaracterEspecial(frmT46V129A.flxBens.TextMatrix(lI, 2), True)
            lCheck = 6
            If IsNumeric(frmT46V129A.flxBens.TextMatrix(lI, 3)) = True Then
                .Val_Bem = gM46V999.CDblx(frmT46V129A.flxBens.TextMatrix(lI, 3))
            Else
                .Val_Bem = 0
            End If
            .Cod_Bem = gM46V999.CDblx(frmT46V129A.flxBens.TextMatrix(lI, 4))
            .Cod_Seq = gM46V999.CDblx(frmT46V129A.flxBens.TextMatrix(lI, 0))
            lCheck = 7
            If Not lobjPedBem.mfIncluir(lobjstcPedBem, "", "", "") Then
                pMensagem = lobjPedBem.UltimoErro
                GoTo Finalizar
            End If
            lCheck = 8
            objstcPedLoc.ColecaoPedLocBem.Add lobjstcPedBem
        End With
Proximo:
    Next lI
    mfSalvarBens = True
Finalizar:
    Set lobjPedBem = Nothing
    Set lobjstcPedBem = Nothing
    Exit Function
ControleErro:
    Set lobjPedBem = Nothing
    Set lobjstcPedBem = Nothing
    If gM46V999.gfPreenchido(pMensagem) = False Then
        pMensagem = Err.Description
    End If
    Call gM46V999.gpGraLog(0, "mfSalvarBens ERRO - " & Err & " " & ERROR & _
                              Chr(13) & "Check " & lCheck & pMensagem)
End Function

Private Function mfSalvarBicicleta(pMensagem As String) As Boolean
