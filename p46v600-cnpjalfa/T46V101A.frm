Private Function mfSalvarObrasArte(pMensagem As String) As Boolean
    Dim lobjPedObrasArte As clsA46V748A
    Dim lobjstcPedObrasArte As stcA46V748B
    Dim lI As Integer
    Dim lCheck As String

    On Error GoTo ControleErro
    
    mfSalvarObrasArte = False
    Set lobjPedObrasArte = New clsA46V748A
    Set lobjPedObrasArte.M46V999 = gM46V999

    If objstcPedLoc.ColecaoObrasArte.Count > 0 Then
        Set lobjstcPedObrasArte = New stcA46V748B
        Set lobjstcPedObrasArte.M46V999 = gM46V999

        lobjstcPedObrasArte.nosso_numero = objstcPedLoc.nosso_numero
        lobjstcPedObrasArte.Num_Item = objstcPedLoc.Num_Item
        
        If Not lobjPedObrasArte.mfExcluir(lobjstcPedObrasArte, "", "") Then
            pMensagem = lobjPedObrasArte.UltimoErro
            GoTo Finalizar
        End If
    End If
    
    Set objstcPedLoc.ColecaoObrasArte = New Collection
    Dim i As Integer
    
    For i = 1 To frmT46V204A.flxObraArtes.Rows - 1
        Set lobjstcPedObrasArte = New stcA46V748B
        Set lobjstcPedObrasArte.M46V999 = gM46V999
    
        With lobjstcPedObrasArte
            .nosso_numero = objstcPedLoc.nosso_numero
            .Cod_Org = objstcPedLoc.Cod_Org
            .Cod_Ramo = objstcPedLoc.Cod_Ramo
            .NUM_PI = objstcPedLoc.NUM_PI
            .Num_Ped = objstcPedLoc.Num_Ped
            .Num_Apol = objstcPedLoc.Num_Apol
            .Num_Endo = objstcPedLoc.Num_Endo
            .Num_Item = objstcPedLoc.Num_Item
            .Cod_Seq = frmT46V204A.flxObraArtes.TextMatrix(i, 0)
            .Descricao = frmT46V204A.flxObraArtes.TextMatrix(i, 1)
            .Valor = gM46V999.CDblx(frmT46V204A.flxObraArtes.TextMatrix(i, 2))
        End With
        
        objstcPedLoc.ColecaoObrasArte.Add lobjstcPedObrasArte
    Next
    
    For Each lobjstcPedObrasArte In objstcPedLoc.ColecaoObrasArte
        If Not lobjPedObrasArte.mfIncluir(lobjstcPedObrasArte, "", "", "") Then
            pMensagem = lobjPedObrasArte.UltimoErro
            GoTo Finalizar
        End If
    Next
    mfSalvarObrasArte = True

Finalizar:
    Set lobjPedObrasArte = Nothing
    Set lobjstcPedObrasArte = Nothing
    Exit Function
    Resume 0
    
ControleErro:
    If gM46V999.gfPreenchido(pMensagem) = False Then
        pMensagem = Err.Description
    End If
    Call gM46V999.gpGraLog(0, "mfSalvarObrasArte ERRO - " & Err & " " & ERROR & _
                              Chr(13) & "Check " & lCheck & pMensagem)
End Function

