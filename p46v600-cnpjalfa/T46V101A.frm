Public Sub ReplicarDadoInspecao()
    Dim lobjInspecao As clsA46V717A
    Dim lMensagem As String
    
    On Error GoTo Erro
    
    Set lobjInspecao = New clsA46V717A
    Set lobjInspecao.M46V999 = gM46V999
    
    If objstcPedido.ColecaoPedLoc.Count < 2 Then
        Call MsgBox("Esta cota��o possui apenas um item!", vbExclamation, Me.Caption)
        GoTo Fim
    End If
    
    lMensagem = "Aten��o! " & vbCrLf
    lMensagem = lMensagem & "Esta a��o ir� atribuir as informa��es digitadas em contato e telefone de inspe��o aos demais itens." & vbCrLf
    lMensagem = lMensagem & "Confirma esta a��o ?"
    
    If MsgBox(lMensagem, vbQuestion + vbYesNo, Me.Caption) = vbYes Then
        Dim objTabPedLoc As stcA46V708B
        
        For Each objTabPedLoc In objstcPedido.ColecaoPedLoc
            Set lobjInspecao.ConexaoBD = objPedido.ConexaoBD
            If gM46V999.gfPreenchido(objTabPedLoc.objstcPedInsp.nosso_numero) Then
                objTabPedLoc.objstcPedInsp.nosso_numero = objTabPedLoc.nosso_numero
                objTabPedLoc.objstcPedInsp.Num_Item = objTabPedLoc.Num_Item
                If Not lobjInspecao.mfExcluir(objTabPedLoc.objstcPedInsp, "", "") Then
                    lMensagem = lobjInspecao.UltimoErro
                End If
            End If
            
            With objTabPedLoc.objstcPedInsp
                .nosso_numero = objTabPedLoc.nosso_numero
                .Num_Item = objTabPedLoc.Num_Item
                .Dat_Cadastro = Left(gM46V999.gfForData(3), 8)
                .Num_Logr_Risco = objTabPedLoc.objstcPedInsp.Num_Logr_Risco
                Call frmT46V193A.SalvarDados(objTabPedLoc.objstcPedInsp)
                .Cod_Ramo = objstcPedido.Cod_Ramo
                .Num_Ped = objTabPedLoc.Num_Ped
            End With
            
            If Not lobjInspecao.mfIncluir(objTabPedLoc.objstcPedInsp, "", "", "") Then
                lMensagem = lobjInspecao.UltimoErro
                GoTo Erro
            End If
        Next
        
    End If
    
    Call gpLimPremios
    MsgBox "Opera��o concluida com sucesso!", vbInformation, Me.Caption
    
Fim:
    Set lobjInspecao = Nothing
    Exit Sub
Erro:
    If Err <> 0 Then
        Call gM46V999.gpGraLog(1, Err & " " & Err.Description, vbCritical)
    Else
        Call gM46V999.gpGraLog(1, lMensagem, vbCritical)
    End If
    Resume Fim
End Sub

