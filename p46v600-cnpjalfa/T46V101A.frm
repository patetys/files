    gCarga = False

    'Salva resultado do c�lculo.
    'a) Atualiza registro do item.
    lUltData = CDbl(gM46V999.gfForData(3))
    'Ficha 0901834 Corre��o de Status (Para Emiss�o Mainframe n�o pode ir 2)
    '    pobjstcItem.Cod_Sit_item = e_SitItem_Calculado

    If pobjstcItem.Num_Item = val(txtNumItem.Text) Then
        gIteUltUsuario = gM46V999.gNomUsuario6
        gIteUltData = lUltData
        Call mpCarregarCobertGrid(pobjstcItem.ColecaoPedCobert)
    End If

    objstcPedido.ColecaoPedLoc.Remove pobjstcItem.Class_ID

    'Verifico se deve ser gravada a observa��o de inspe��o.
    Dim lTexto As String
    
    lTexto = Nova_Observacao(pobjstcItem.Ind_StatusInspecao, pobjstcItem.Num_Insp, pobjstcItem)
    If lMsgInsp <> Empty And pobjstcItem.Ind_StatusInspecao = e_StatusInspecao_ConfNormas Then
        If gM46V999.gNovaPropostaLMI Then
            lTexto = lTexto & "Item " & Format(pobjstcItem.Num_Item, "00000") & ": " & gM46V999.gfRetirarCaracterEspecial(lMsgInsp, True)
        Else
            lTexto = lTexto & gM46V999.gfRetirarCaracterEspecial(lMsgInsp, True)
        End If
    End If
    
    UCase (lTexto)
    
    Set lobjPedObs = New clsA46V714A
    Set lobjPedObs.M46V999 = gM46V999
    
    Set lobjPedObs.ConexaoBD = objPedido.ConexaoBD
    If Not lobjPedObs.mfExcluir(pobjstcItem.objstcPedObs, "", "") Then
        lMensagem = lobjPedObs.UltimoErro
        Call gM46V999.gpMenErro(lMensagem)
        Exit Function
    End If
    
    If Trim(lTexto) <> "" Then
        With pobjstcItem.objstcPedObs
            .nosso_numero = pobjstcItem.nosso_numero
            .Num_Item = pobjstcItem.Num_Item
            .Observacao = Replace(lTexto, vbCrLf, "&%")
        End With
        If Not lobjPedObs.mfIncluir(pobjstcItem.objstcPedObs, "", "", "") Then
            lMensagem = lobjPedObs.UltimoErro
            Call gM46V999.gpMenErro(lMensagem)
            Exit Function
        End If
    End If
    
    If (txtNumItem.Text = pobjstcItem.Num_Item) Then
        gCarga = True
        
        'Indica se tem inspe��o marcada ou n�o
        If pobjstcItem.Insp_Obr = True Or pobjstcItem.Ind_Sin_Inspec > 0 Then
            lblInspecaoDado.Caption = "SIM"
        Else
            lblInspecaoDado.Caption = "N�O"
        End If
        
        frmT46V122A.txtObservacao.Text = Replace(pobjstcItem.objstcPedObs.Observacao, "&%", vbCrLf)
        gCarga = False
    End If

    '############## PROJETO 10018 - INSPECAO ####################
    If gM46V999.gfPreenchido(lMsgInsp) = True Or pobjstcItem.Ind_StatusInspecao = e_StatusInspecao_obrigatoria Then
        If gM46V999.gTipUsuario = e_Tipo_Usu_Corretor Or gM46V999.gTipUsuario = e_Tipo_Usu_CorretorYasuda Then
            If gpGeraLogCalcInspecao(objstcPedido, pobjstcItem) = False Then
                If pobjstcItem.Insp_Agend = True Then
                    Call gM46V999.gpGraLog(1, "N�o gerou arquivo de transmiss�o da inspe��o " & objstcPedido.nosso_numero)
                End If
            End If
        End If
    End If

NaoAgendar:

    'Verifico em que lugar da cole��o ser� adicionado.
    '� feito isso para que n�o seja exibido com os n�mero fora de ordem
    lChave = gpPosicaoColecao(pobjstcItem.Num_Item)
    If objstcPedido.ColecaoPedLoc.Count > 0 And objstcPedido.ColecaoPedLoc.Count <> lChave - 1 Then
        objstcPedido.ColecaoPedLoc.Add pobjstcItem, pobjstcItem.Class_ID, lChave
    Else
        objstcPedido.ColecaoPedLoc.Add pobjstcItem, pobjstcItem.Class_ID
    End If

    mfCalPreItem = True
    Call TesteDesempenho("mfCalPreItem " & pobjstcItem.nosso_numero & " Item: " & pobjstcItem.Num_Item)
    Exit Function
    Resume 0

ControleErro:
    Call gM46V999.gpGraLog(1, Err.Description)
End Function

Private Sub mpCarregarCobertGrid(pColecaoPedCobert As Collection)
    Dim lobjstcCobert As stcA46V704B
    Dim lI As Integer
    Dim lLinhaInicio As Integer
    
    On Error GoTo Erro:
    
    lLinhaInicio = 1
    With flxCobertura
        .Rows = 1
        For Each lobjstcCobert In pColecaoPedCobert
            .Rows = .Rows + 1
            If lobjstcCobert.Cod_Cobert = 1 And gM46V999.gCod_Ramo <> e_CodRamo_Roubos And optVerbasSeparadas(0).Value = False Then
                If txtISBas.Text <> Format(lobjstcCobert.Val_IS, "standard") Then
                    Call gM46V999.gpGraLog(1, "AGE0049 - LMI. B�sico n�o pode ser diferente de " & Format(lobjstcCobert.Val_IS, "standard") & ".")
                End If
                gCarga = True
                txtISBas.Text = Format(lobjstcCobert.Val_IS, "standard")
                gCarga = False
            End If
            
            Dim lJusteNomeCobertura As String
            
            .TextMatrix(.Rows - 1, 0) = lobjstcCobert.Cod_Cobert
            lJusteNomeCobertura = Trim$(lobjstcCobert.gNomeCobertura)
            .TextMatrix(.Rows - 1, 1) = lJusteNomeCobertura

            'Verbas separadas
            If gM46V999.gfPreenchido(lobjstcCobert.Compl_Desc_Cobertura) Then
                .TextMatrix(.Rows - 1, 1) = .TextMatrix(.Rows - 1, 1) & " - " & lobjstcCobert.Compl_Desc_Cobertura
            End If
        
            'Elevador
            If lobjstcCobert.Cod_Cobert = 1103 And gM46V999.gCod_Ramo = e_CodRamo_Condominio Then
                Select Case frmT46V101A.cboElevador.ItemData(frmT46V101A.cboElevador.ListIndex)
                Case 1
                    .TextMatrix(.Rows - 1, 1) = .TextMatrix(.Rows - 1, 1) & " COM ELEVADOR"
                Case 2
                    .TextMatrix(.Rows - 1, 1) = .TextMatrix(.Rows - 1, 1) & " SEM ELEVADOR"
                End Select
            End If
            
            .TextMatrix(.Rows - 1, 2) = Format(lobjstcCobert.Val_IS, "standard")
            .TextMatrix(.Rows - 1, 3) = 0
            .TextMatrix(.Rows - 1, 4) = lobjstcCobert.Tab_Cobert
            .TextMatrix(.Rows - 1, 5) = lobjstcCobert.Per_Franq
            .TextMatrix(.Rows - 1, 6) = lobjstcCobert.Val_Franq_Min
            .TextMatrix(.Rows - 1, 7) = lobjstcCobert.Per_Desc_Coml
            .TextMatrix(.Rows - 1, 8) = lobjstcCobert.Per_Desc_Exp
            .TextMatrix(.Rows - 1, 9) = Format(lobjstcCobert.VAL_PR, "standard")

            For lI = lLinhaInicio To frmT46V117A.flxSelecionadas.Rows - 1
                If val(frmT46V117A.flxSelecionadas.TextMatrix(lI, ColCodCobert)) = lobjstcCobert.Cod_Cobert And optVerbasSeparadas(0).Value = False Then
                    frmT46V117A.flxSelecionadas.TextMatrix(lI, ColValLMG) = Format(lobjstcCobert.Val_IS, "standard")
                    If lI = lLinhaInicio Then
                        lLinhaInicio = lLinhaInicio + 1
                    End If
                    Exit For
                End If
            Next lI
        Next lobjstcCobert
        .row = 0
    End With
    
    Exit Sub
    Resume 0
Erro:
    If pColecaoPedCobert.Count > 0 Then
        Call gM46V999.gpGraLog(0, "mpCarregarCobertGrid" & " Num_Ped: " & pColecaoPedCobert.Item(1).Num_Ped & " Num_Item: " & pColecaoPedCobert.Item(1).Num_Item & " " & Err.Description)
    End If
End Sub

