        flgIgnorarInspecao = VerificarInspecaoSAR(objstcPedido.objstcCtrlEmis.cod_origem, objstcPedido.objstcCtrlEmis.Num_Apol_Ant, objstcPedido.objstcCtrlEmis.Num_Apol_Mar, objstcPedLocTmp.Num_Item, lMensagem)
    End If

    ' Chamar o WebService de Normas
    
    Dim WSClient            As New MSSOAPLib30.SoapClient30
    Dim EnderecoWebService  As String
    Dim Retorno             As String
    Dim errNumb As Long
    Dim errDescr As String
    Dim qtdErros As Integer
    
    Set WSClient = New MSSOAPLib30.SoapClient30
    EnderecoWebService = gM46V999.gUrlWebServiceNormas
    'EnderecoWebService = "http://192.168.1.80:9080/SyasWeb02/WSNormas/Normas.asmx?wsdl"
    On Error Resume Next
    Call WSClient.MSSoapInit(EnderecoWebService)
    
    If Err.Number <> 0 Then
        errNumb = Err.Number
        errDescr = Err.Description
        Err.Clear
        On Error GoTo 0
        Err.Raise errNumb, "mpVerNormasWebService", "Erro ao conectar ao WebService de Normas " & vbCrLf & " (URL " & EnderecoWebService & "): " & vbCrLf & errDescr
    End If
    On Error GoTo 0
    
    Dim codCorr As String
    Dim Coberts As String
    Dim lobjstcCobert As stcA46V704B
    Dim i
    Dim IndSin As Integer
    
    IndSin = 0
    If objstcPedLocTmp.Ind_Sinistro = 1 Then IndSin = 1
    
    codCorr = objstcPedido.objstcCtrlEmis.Cod_Corr
    If objstcPedido.objstcCtrlEmis.Cod_Corr_2 <> 0 Then codCorr = codCorr & "|" & objstcPedido.objstcCtrlEmis.Cod_Corr_2
    If objstcPedido.objstcCtrlEmis.Cod_Corr_3 <> 0 Then codCorr = codCorr & "|" & objstcPedido.objstcCtrlEmis.Cod_Corr_3
    
    For i = 1 To objstcPedLocTmp.ColecaoPedCobert.Count
        Set lobjstcCobert = objstcPedLocTmp.ColecaoPedCobert(i)
        If Coberts <> "" Then Coberts = Coberts & "|"
        Coberts = Coberts & lobjstcCobert.Cod_Cobert & "=" & lobjstcCobert.Val_IS
    Next
    
    ' Tarifa, Ramo, Corretores, Plano, tipoEmissao, classificacao, classificacao_compl, coberturas, classeconstrucao, tipcobert, CEP, UF, qtdevidas
    ' Cobertura � codigo=valor (1=100000|2=10000)
    
    'Tarifa 11.50
    On Error Resume Next
    qtdErros = 0
    Do ' Rotina vai tentar acessar o normas 3 vezes antes de desistir.
        If Err.Number = 0 And qtdErros > 0 Then
            ' Deu certo, sair
            Exit Do
        Else
            Err.Clear
        End If
        
        If gM46V999.gCodProduto >= 1150 Then
            Retorno = WSClient.ValidarNormas_4(objstcPedido.Cod_Produto, objstcPedido.Cod_Ramo, codCorr, gM46V111.gCod_plano, _
                objstcPedLocTmp.Tip_Emissao, objstcPedLocTmp.Cod_Clasf, objstcPedLocTmp.Cod_Compl_Clasf, Coberts, objstcPedLocTmp.Cod_Constr, _
                objstcPedLocTmp.Tip_Cobert, objstcPedLocTmp.Num_Cep_Risco, objstcPedLocTmp.Sig_UF_Risco, objstcPedLocTmp.Qtd_Vidas, IndSin, _
                objstcPedLocTmp.Cod_DizerItem, objstcPedLocTmp.ObjPai.Tip_Pessoa, objstcPedLocTmp.NUM_PI, objstcPedLocTmp.Num_Item, "KitVB6")
        
        Else
            Retorno = WSClient.ValidarNormas_2(objstcPedido.Cod_Produto, objstcPedido.Cod_Ramo, codCorr, gM46V111.gCod_plano, _
                objstcPedLocTmp.Tip_Emissao, objstcPedLocTmp.Cod_Clasf, objstcPedLocTmp.Cod_Compl_Clasf, Coberts, objstcPedLocTmp.Cod_Constr, _
                objstcPedLocTmp.Tip_Cobert, objstcPedLocTmp.Num_Cep_Risco, objstcPedLocTmp.Sig_UF_Risco, objstcPedLocTmp.Qtd_Vidas, IndSin, _
                objstcPedLocTmp.Cod_DizerItem)
        End If
        
        qtdErros = qtdErros + 1
    Loop While qtdErros <= 3 And InStr(UCase(Err.Description), "TIME OUT") > 0
    
    If Err.Number <> 0 Then
        errNumb = Err.Number
        errDescr = Err.Description
        Err.Clear
        On Error GoTo 0
        Err.Raise errNumb, "mpVerNormasWebService", "Erro ao obter normas do WebService de Normas " & vbCrLf & " (URL " & EnderecoWebService & "): " & vbCrLf & errDescr
    End If
    On Error GoTo 0
    
    ' Retorno � sempre Cod_Norma|MensagemUsuario|MensagemCorretor|ClasseAceitacao|Alcada
    ' O separador de normas � sempre ###, e o de campos � |
    

    ' Devo apenas obter as mensagens e o codigo de processo.
    Dim arrNormas
    Dim arrCamposNorma
    Dim strCodigoNorma
    Dim strMensagemUsuario
    Dim strMensagemCorretor
    Dim strClasseAceitacao
    Dim strAlcada
    
    If flgIgnorarInspecao = 2 Then ' Classe 3 - Precisa retornar mais uma mensagem de norma
        Retorno = Retorno & IIf(Retorno <> "", "###", "") & "99.0.0.1|Inspe��o SAR recusada|Inspe��o SAR recusada|3|80"
    End If
    
    If Retorno = "" Then Exit Sub
    
    arrNormas = Split(Retorno, "###")
    
    For i = 0 To UBound(arrNormas)
        arrCamposNorma = Split(arrNormas(i), "|")
        strCodigoNorma = arrCamposNorma(0)
        strMensagemUsuario = arrCamposNorma(1)
        strMensagemCorretor = arrCamposNorma(2)
        strClasseAceitacao = arrCamposNorma(3)
        strAlcada = arrCamposNorma(4)

        lCod = CLng(strAlcada)
        
        'Se na tabela de parametriza��o retornou classe 1 despreza retornos 10 e 80
        If pCod_Aceit = 1 Then
            If lCod <> 55 Then
                GoTo LerProximoErro
            End If
        End If
        
        If lCod = 55 Then
            If flgIgnorarInspecao <> 1 Then
                pMensInsp = strMensagemUsuario
            End If
        Else
            If gM46V999.VerificarNormas Then
                Call gM46V999.gpMenErro("Normas " & strCodigoNorma & " - " & strMensagemUsuario)
                QtdErr = QtdErr + 1
            End If
        End If

LerProximoErro:

    Next
    
    If QtdErr = 0 Then
        pCod_Retorno = 0
    End If
    DoEvents
    
    '###PROJETO SISCOTA
    'DESCOMENTAR LINHAS
    If (gM46V999.PerfilAcesso = e_Perfil_CALC_Gestor) And (gM46V999.gBaseLocal = False) Then
        If val(objstcPedido.objstcCtrlEmis.Num_Cotac) <> 0 Then
            If gM46V999.gfAbrBasDados("P00MULTI", gM46V999.gTipP00MULTI, gM46V999.gEndP00MULTI, lBDP00Multi, lMensagem) = False Then
                Call gM46V999.gpGraLog(2, lMensagem)
                Exit Sub
            End If
            If pItem = objstcPedido.ColecaoPedLoc.Item(1).Num_Item Then
                lUpdate = " Update siscota.dbo.tab_cotacao_div set normas = '' where ccotacao = '" & objstcPedido.objstcCtrlEmis.Num_Cotac & "'"
                If gM46V999.gfExeSQL(lBDP00Multi, lUpdate, lMensagem) <> 0 Then
                    Call gM46V999.gpGraLog(2, lMensagem)
                    Exit Sub
                End If
            End If

            If gM46V999.gfPreenchido(lListaErros) Then
                lUpdate = " Update siscota.dbo.tab_cotacao_div set normas = normas + '" & lListaErros & "' where ccotacao = '" & objstcPedido.objstcCtrlEmis.Num_Cotac & "'"
                If gM46V999.gfExeSQL(lBDP00Multi, lUpdate, lMensagem) <> 0 Then
                    Call gM46V999.gpGraLog(2, lMensagem)
                    Exit Sub
                End If
            End If
        End If
    End If

End Sub

