    Call gpLimPremios
    If cboPlano.ListIndex = -1 Then
        Call gM46V999.gpGraLog(1, "FNP0010 - Plano inv�lido (n�o informado).")
        Exit Sub
    ElseIf gM46V999.gCodProduto = 0 Then
        Call gM46V999.gpGraLog(1, "FGE0091 - Tarifa inv�lida (n�o informada).")
