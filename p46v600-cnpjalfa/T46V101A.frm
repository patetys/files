Private Sub mpEnviarSiscotaAoCorretor()
    Dim lBDSiscota As ADODB.Connection
    Dim lSelect As String
    Dim lMensagem As String
    Dim lrst As clsYasRecordSet
    Dim lNumPed As Long

    If objstcPedido.mStatusDivSiscota <> enum_StatusTransm_Inicio Then
        Call gM46V999.gpGraLog(1, "Cota��o j� vinculada para ser enviada ao corretor.")
        Exit Sub
    End If
    If objstcPedido.Cod_Sit_Ped <> e_SitPedido_ComCalculo Then
        Call gM46V999.gpGraLog(1, "Para enviar ao corretor, a cota��o deve estar calculada.")
        Exit Sub
    End If
    If objstcPedido.objstcCtrlEmis.Tip_Cotac <> "2" Or objstcPedido.objstcCtrlEmis.Num_Cotac = "" Then
        Call gM46V999.gpGraLog(1, "A cota��o deve ter um SISCOTA para poder enviar ao corretor.")
        Exit Sub
    End If

    If objstcPedido.LMI_Unico = 1 Then
        Call gM46V999.gpGraLog(1, "Cota��es de LMI ainda n�o podem ser enviadas ao corretor.")
        Exit Sub
    End If

    If gM46V999.gfAbrBasDados("GED", gM46V999.gTipGed, gM46V999.gEndGed, lBDSiscota, lMensagem) = False Then
        Call gM46V999.gpGraLog(2, lMensagem)
        Exit Sub
    End If
    lSelect = "Select * From siscota.siscota.tab_cotacao as c inner join ged.dbo.tab_ctrl_siscota as s on "
    lSelect = lSelect & " s.ccotacao = c.ccotacao "
    lSelect = lSelect & " Where c.ccotacao= " & gM46V999.gfFormatarCamposSQL(objstcPedido.objstcCtrlEmis.Num_Cotac)
    lSelect = lSelect & " And   c.CRamo= " & gM46V999.gfFormatarCamposSQL(objstcPedido.objstcCtrlEmis.Cod_Ramo)
    If gM46V999.gfObtRegistro(lBDSiscota, lSelect, lrst, lMensagem) = False Then
        Call gM46V999.gpFecha2(lBDSiscota)
        Call gM46V999.gpGraLog(2, lMensagem)
        Exit Sub
    End If
    If lrst.EOF Then
        Call gM46V999.gpGraLog(1, "AGE0023 - SISCOTA n�o informado ou inv�lido.")
        Call gM46V999.gpFecha2(lBDSiscota)
        Exit Sub
    End If
    Call gM46V999.gpFecha2(lBDSiscota)

    If lrst("status_andamento") = 5 Then
        Call gM46V999.gpGraLog(1, "Siscota recusado. N�o ser� poss�vel enviar ao corretor.")
        Exit Sub
    End If

    If lrst("status_andamento") = 3 Then
        Call gM46V999.gpGraLog(1, "Siscota cancelado. N�o ser� poss�vel enviar ao corretor.")
        Exit Sub
    End If

    If lrst("status_fluxo") >= 8 Then
        If MsgBox("SISCOTA j� finalizado. Deseja realmente enviar a cota��o ao corretor?", vbQuestion + vbYesNo) = vbNo Then
            Exit Sub
        End If
    End If

    Call gM46V999.updAtualizaStatusInspecao(objstcPedido.NUM_PI, lMensagem, objstcPedido)

    lSelect = " INSERT INTO [SISCOTA].[dbo].[tab_syas_cotacao]"
    lSelect = lSelect & "       ([CCOTACAO]"
    lSelect = lSelect & "        ,[NOSSO_NUMERO]"
    lSelect = lSelect & "        ,[DATA_INCLUSAO]"
    lSelect = lSelect & "        ,[COD_RAMO]"
    lSelect = lSelect & "        ,[COD_STATUS]"
    lSelect = lSelect & "        ,[STATUS_ENVIO]"
    lSelect = lSelect & "        ,[COD_CORRETOR]"
    lSelect = lSelect & "        ,[COD_USUARIO]"
    lSelect = lSelect & "        ,[NomArq]"
    lSelect = lSelect & "        ,[SENHA])"
    lSelect = lSelect & "      Values ("
    lSelect = lSelect & " '" & lrst("ccotacao") & "',"
    lSelect = lSelect & " '" & objstcPedido.nosso_numero & "',"
    lSelect = lSelect & gM46V999.gfForData(3) & ","
    lSelect = lSelect & objstcPedido.Cod_Ramo & ","
    If lrst("status_fluxo") >= 8 Then
        lSelect = lSelect & 2 & ","
        lSelect = lSelect & 1 & ","
    Else
        lSelect = lSelect & 1 & ","
        lSelect = lSelect & 0 & ","
    End If
    lSelect = lSelect & objstcPedido.objstcCtrlEmis.Cod_Corr & ","
    lSelect = lSelect & "0,"
    lSelect = lSelect & "'',"
    lSelect = lSelect & "'')"

    If gM46V999.gfExeSQL(lBDSiscota, lSelect, lMensagem) <> 0 Then
        Call gM46V999.gpFecha2(lBDSiscota)
        Call gM46V999.gpGraLog(1, lMensagem)
        Exit Sub
    End If

    'Ajuste para retorno a web sem IOF
    If objstcPedido.StatusCotSiscota = enum_StatusTransm_Inicio Then
        objstcPedido.StatusCotSiscota = enum_StatusTransm_EnvioKit
            
        lNumPed = 0
        If gM46V999.gfDisponibilizaCotacaoPortal(objstcPedido.nosso_numero, 0, lMensagem, objPedido.ConexaoBD, lNumPed) = False Then
            Call gM46V999.gpGraLog(1, "Erro na disponibiliza��o da cotac�o para web!")
            Call gM46V999.gpGraLog(0, lMensagem)
            Exit Sub
        End If
    
        Call gM46V999.gpGraLog(1, "Nova referencia " & lNumPed & " gerada com sucesso.")
    End If
    
    Call gM46V999.gpGraLog(1, "Siscota vinculado para ser enviado ao corretor.")
    Call cmdSair_Click

End Sub


