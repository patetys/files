    End If
    
    If objstcPedido.VAL_PR_Informado <> 0 And objstcPedido.VAL_PR_Informado <> objstcPedido.VAL_PR Then
        'If MsgBox("Voc� optou por informar um pr�mio de R$ " & Format(objstcPedido.VAL_PR_Informado, "standard") & ". " & vbCrLf & "O premio calculado � de " & Format(objstcPedido.VAL_PR, "standard") & ". " & vbCrLf & "Voc� tem certeza que deseja manter o premio informado diferente da soma dos pr�mios das coberturas?", vbOKCancel, "Premio informado") = vbOK Then
            objstcPedido.VAL_PR = objstcPedido.VAL_PR_Informado
