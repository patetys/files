Private Function mfConsParcelas(ByRef pParcela1 As Double, pParcelaN As Double) As Boolean
'Fun��o: calcula pr�mios.
'********************Vari�veis padr�o*************************************
    Dim lCkPoint As String    'Variavel utilizada para determinar pontos onde o c�digo j� passou.
    Dim lCkStr As String    'Variavel utilizada para guardar a posi��o das variaveis at� o ultimo
'lCkPoint. (posi��o das variaveis em ordem de declara��o)
'********************Vari�veis Declaradas para o processamento************
    Dim lMaxParcela As Integer  'N�mero m�ximo de parcelas permitido
    Dim lMaxParcelaVista As Integer       'N�mero m�ximo de parcelas permitido a vista
    Dim lMaxParcela30Dia As Integer       'N�mero m�ximo de parcelas permitido 30 dias
    Dim lDataUltVencimento As Double          'Data do ultimo vencimento possivel
    Dim lQutdeParcelas As Integer     'Quantidade de parcelas
    Dim lAuxiliar As String
    Dim lTipPessoa As Integer
    Dim lMensagem As String

    pParcela1 = 0
    pParcelaN = 0

    On Error GoTo ControleErro
    lCkPoint = "1"
    '2. Verifica quantidade de parcelas.
    If Not IsNumeric(frmT46V102A.txtQuaParcelas.Text) And val(Mid(frmT46V112A.cboCodReg.Text, 1, 3)) = 120 Then
        frmT46V102A.txtQuaParcelas.Text = 1
    End If
    
    If Not gM46V999.gfPreenchido(frmT46V102A.txtQuaParcelas.Text) Then
        Screen.MousePointer = vbDefault
        Call gM46V999.gpGraLog(1, "FGE0013 - " & gM46V999.gPrefixo & "Quantidade de parcelas inv�lida (n�o preenchida).")
        Exit Function
    End If
    
    If val(frmT46V102A.txtQuaParcelas.Text) = 0 Then
        If gM46V111.gCod_Dizer = 0 Then
            frmT46V102A.txtQuaParcelas.Text = 1
        End If
    End If

    'Guarda na variavel o numero de parcelas informado
    lQutdeParcelas = val(frmT46V102A.txtQuaParcelas.Text)

    If gM46V999.gTipUsuario = e_Tipo_Usu_Corretor Or gM46V999.gTipUsuario = e_Tipo_Usu_CorretorYasuda Then
        frmT46V120A.txtCusEmissao.Text = frmT46V101A.objstcPedido.getProduto.ProCusApolice
    End If

    If frmT46V102A.txtCorretor(1).Text <> "" Then
        If gCodCorrInst <> frmT46V102A.txtCorretor(1).Tag And gCodCorrInst <> 0 And gM46V999.gCodProtocolo = 0 Then
            'Ficha 1000153 - Automatiza��o do agrupamento de corretores no Syas ap�s o cadastro realizado pelo help-desk.
            If gM46V999.gfVerCorrPermitido_TBS_Corr_Grupo(gCodCorrInst, frmT46V102A.txtCorretor(1).Tag, CInt(gM46V999.gCod_Ramo), lAuxiliar) = False Then
                Call gM46V999.gpGraLog(1, "FGE0017 - C�digo corretor n�o permitido para este usu�rio (" & gM46V999.gNomUsuario & ")")
                Screen.MousePointer = vbDefault
                Exit Function
            End If
        End If
    End If

    If frmT46V102A.optTipPessoa(0).Value = True Then
        lTipPessoa = 2  'Pessoa f�sica.
    Else
        lTipPessoa = 1  'Pessoa jur�dica.
    End If


    lCkPoint = "2"
    mfConsParcelas = True
    Exit Function
ControleErro:
    mfConsParcelas = False

End Function

Private Function VerificarInspecaoSAR(cod_origem As Integer, Num_Apol_Ant As Double, Num_Apol_Mar As Double, Num_Item As Integer, lMensagem As String) As Integer

    Dim strSQL As String
    Dim objRS As clsYasRecordSet
    Dim lBDP00Multi As ADODB.Connection
    
    strSQL = "EXEC proc_VerificarInspecaoSAR " & cod_origem & ", " & Num_Apol_Ant & ", " & Num_Apol_Mar & ", " & Num_Item & ""
    
    If gM46V999.gfAbrBasDados("P00MULTI", gM46V999.gTipP00MULTI, gM46V999.gEndP00MULTI, lBDP00Multi, lMensagem) = False Then
        Call gM46V999.gpGraLog(2, lMensagem)
        Exit Function
    End If
    
    If Not gM46V999.gfObtRegistro(lBDP00Multi, strSQL, objRS, lMensagem) Then
        Call gM46V999.gpGraLog(2, lMensagem)
        Exit Function
    End If
    
    If Not objRS.EOF Then
        VerificarInspecaoSAR = objRS("Retorno")
    Else
        Call gM46V999.gpGraLog(2, "Query " & strSQL & " n�o retornou nenhum registro.")
        Exit Function
    End If
    

End Function

