Private Function mfVerDados(ByRef pTipDocumento As Byte, ByRef pMensagem As String) As Boolean
'Fun��o: verifica se os dados j� est�o calculados.
'        As bases de dados e os recordsets j� ficam abertos.
    Dim lIteNaoDigitado() As Integer    'Itens n�o digitados.
    Dim lOrdem As Long    'Ordem dos itens.
    Dim lQuaNaoDigitado As Long     'Quantidade de itens n�o digitados.
    Dim lobjstcItem As stcA46V708B    'Objeto da classe de estrutura stcA46V708B (TAB_PED_LOC)
    Dim lobjstcCobert As stcA46V704B
    Dim lSelect As String
    mfVerDados = False

    '1. Verifica se o pr�mio est� calculado,
    If objstcPedido.Cod_Sit_Ped <> e_SitPedido_ComCalculo And objstcPedido.Cod_Sit_Ped <> e_SitPedido_Transmitido Then
        pMensagem = "AGE0022 - Pr�mio n�o calculado."
        Exit Function
    End If

    '1100090 - Inspecao Desabilitada
    If (gM46V999.PerfilAcesso = e_Perfil_CALC_Gestor Or gM46V999.PerfilAcesso = e_Perfil_CALC) _
       And (gM46V999.gTipUsuario = e_Tipo_Usu_Yasuda) And (objstcPedido.objstcCtrlEmis.Tip_Cotac = "2") Then
        Dim lBDSiscota As ADODB.Connection
        Dim lrst As clsYasRecordSet
        Dim lMensagem As String
        If gM46V999.gfPreenchido(objstcPedido.objstcCtrlEmis.Num_Cotac) Then
            If gM46V999.gfAbrBasDados("GED", gM46V999.gTipGed, gM46V999.gEndGed, lBDSiscota, lMensagem) = False Then
                Call gM46V999.gpGraLog(2, lMensagem)
                Exit Function
            End If
            lSelect = "Select * From siscota.siscota.tab_cotacao "
            lSelect = lSelect & " Where ccotacao= " & gM46V999.gfFormatarCamposSQL(objstcPedido.objstcCtrlEmis.Num_Cotac)
            lSelect = lSelect & " And   CRamo= " & gM46V999.gfFormatarCamposSQL(objstcPedido.objstcCtrlEmis.Cod_Ramo)
            If gM46V999.gfObtRegistro(lBDSiscota, lSelect, lrst, lMensagem) = False Then
                Call gM46V999.gpFecha2(lBDSiscota)
                Call gM46V999.gpGraLog(2, lMensagem)
                Exit Function
            End If
            If lrst.EOF Then
                pMensagem = "AGE0023 - SISCOTA n�o informado ou inv�lido."
                Call gM46V999.gpFecha2(lBDSiscota)
                Exit Function
            End If
            Call gM46V999.gpFecha2(lBDSiscota)
        End If
    End If

    If objstcPedido.Qtd_Parc = 0 And objstcPedido.Cod_Dizer = 0 Then
        pMensagem = "FTE0012 - " & gM46V999.gPrefixo & "Quantidade de parcelas n�o informado."
        Exit Function
    End If
    '2. Obt�m registros de itens.
    If objstcPedido.ColecaoPedLoc.Count = 0 Then
        pMensagem = "FTE0012 - " & gM46V999.gPrefixo & "N�o localizado registro de item."
        Exit Function
    End If

    '3. Posiciona tipo do documento.
    Select Case objstcPedido.Cod_Tip_Doc
    Case e_TipDoc_Cotacao  'Cota��o.
        If objstcPedido.ColecaoPedLoc.Count = 1 Then
            pTipDocumento = 1     'Cota��o simples.
        Else
            pTipDocumento = 2     'Cota��o coletiva.
        End If
    Case e_TipDoc_Proposta    'Proposta.
        If objstcPedido.ColecaoPedLoc.Count = 1 Then
            pTipDocumento = 3     'Proposta simples.
        Else
            pTipDocumento = 4     'Proposta coletiva.
        End If
    End Select

    '4. Verifica se tem item n�o digitado.
    lQuaNaoDigitado = 0
    For Each lobjstcItem In objstcPedido.ColecaoPedLoc
        If lobjstcItem.Dat_Liber = 0 Then
            lQuaNaoDigitado = lQuaNaoDigitado + 1
            ReDim Preserve lIteNaoDigitado(lQuaNaoDigitado)
            lIteNaoDigitado(lQuaNaoDigitado) = lobjstcItem.Num_Item
        End If
    Next lobjstcItem
    If lQuaNaoDigitado <> 0 Then
        Select Case lQuaNaoDigitado
        Case 1
            pMensagem = "FGE0019 - " & gM46V999.gPrefixo & "Item " & lIteNaoDigitado(1) & " n�o digitado."
        Case Else
            pMensagem = "FGE0020 - " & gM46V999.gPrefixo & "Itens n�o digitados: "
            lOrdem = 0
            Do
                lOrdem = lOrdem + 1
                lQuaNaoDigitado = lQuaNaoDigitado - 1
                Select Case lQuaNaoDigitado
                Case 0
                    pMensagem = pMensagem & Format$(lIteNaoDigitado(lOrdem), "0000") & "."
                    Exit Do
                Case 1
                    pMensagem = pMensagem & Format$(lIteNaoDigitado(lOrdem), "0000") & " e "
                Case Else
                    pMensagem = pMensagem & Format$(lIteNaoDigitado(lOrdem), "0000") & ", "
                End Select
            Loop
        End Select
        Exit Function
    End If
    '5. Verifica se produto est� zerado
    If gM46V999.gCodProduto = 0 Then
        pMensagem = pMensagem & "Produto n�o est� selecionado corretamente."
        Exit Function
    End If

    mfVerDados = True
End Function

Private Sub mnuArqTransmitir_Click()
    Dim lMsgErr As String
    Dim lSql As String
    Dim CnBD As ADODB.Connection
    Dim rs As clsYasRecordSet
    Dim rsBoleto As clsYasRecordSet
    
    On Error GoTo TrataErro
    
    Screen.MousePointer = vbHourglass
    
    If gM46V999.gfAbrBasDados("RAMOSDIVERSOS", gM46V999.gTipDIVERSOS, gM46V999.gEndDIVERSOS, CnBD, lMsgErr) = False Then
        GoTo TrataErro
    End If
         
    'Verificar Valor de cobertura zerado Tarifa 11.48
    If objstcPedido.Cod_Dizer <= 1 Then
        lSql = "SELECT COUNT(*) Qtd "
        lSql = lSql & " FROM Tab_ped_Cobert "
        lSql = lSql & " WHERE Val_PR = 0 AND NUM_PI = " & objstcPedido.NUM_PI
        
        If gM46V999.gfObtRegistro(CnBD, lSql, rs, lMsgErr) = False Then
            Call gM46V999.gpFecha2(CnBD)
            GoTo TrataErro
        End If
        
        If Not rs.EOF Then
            If rs!Qtd > 0 Then
                Call gM46V999.gpGraLog(1, "N�o � possivel transmitir esta proposta!" & vbCrLf & "Valor de cobertura zerado, recalcule e tente novamente!")
                GoTo Fim
            End If
        End If
    End If
    
    'T0044807
    lSql = " select * from p0044800.dbo.T0044807 Where "
    lSql = lSql & " num_cgc_cpf = '" & Trim(objstcPedido.Num_Cgc_Cpf) & "'"
    
    If gM46V999.gfObtRegistro(CnBD, lSql, rs, lMsgErr) = False Then
        Call gM46V999.gpFecha2(CnBD)
        GoTo TrataErro
    End If
    
    lSql = " select COD_BCO_COBR from tab_ped t JOIN Tab_Ctrl_Emis c ON C.Nosso_Numero = t.Nosso_numero Where "
    lSql = lSql & " ((t.COD_BCO_COBR > 0 AND c.cod_iden_pag_antec = 1) or c.cod_iden_pag_antec = 2) AND  t.num_pi = " & objstcPedido.NUM_PI
    
    If gM46V999.gfObtRegistro(CnBD, lSql, rs, lMsgErr) = False Then
        Call gM46V999.gpFecha2(CnBD)
        GoTo TrataErro
    End If
    
    If rs.EOF Then
        Call gM46V999.gpGraLog(1, "N�o foi poss�vel transmitir.(COD_BCO_COBR=0)! Favor ligar para o suporte! Ramal 1988")
        GoTo Fim
    End If
    
    If rs.EOF Then
        Call gM46V999.gpGraLog(1, "Registro no SISCAD n�o encontrado! N�o � poss�vel transmitir.(transmiss�o)")

    Else
        'tab_ctrl_pag_antec - Ajuste Run Off
        'Ajustar para o Banco que foi carregado na Tab_ctrl_PagAntec
        If objstcPedido.objstcCtrlEmis.Num_Bloq > 0 Then
            lSql = "SELECT PAGTO.COD_BANCO"
            lSql = lSql & " FROM SYASPORTAL..P0045200 BOLETO"
            lSql = lSql & " INNER JOIN TAB_CTRL_EMIS EMIS"
            lSql = lSql & "     ON  EMIS.NUM_BLOQ = BOLETO.NUM_BOLETO"
            lSql = lSql & " INNER JOIN SYAS_EMIS..TAB_CTRL_PAGANTEC PAGTO"
            lSql = lSql & "     ON PAGTO.NUM_BOLETO = RIGHT(EMIS.NUM_BLOQ,6)"
            lSql = lSql & " AND PAGTO.COD_RAMO = EMIS.COD_RAMO"
            lSql = lSql & " AND PAGTO.DAT_VENC = BOLETO.DAT_VENC"
            lSql = lSql & " Where EMIS.Cod_Ramo = " & objstcPedido.Cod_Ramo
            lSql = lSql & " And EMIS.NUM_PI = " & objstcPedido.NUM_PI
            
            If gM46V999.gfObtRegistro(CnBD, lSql, rsBoleto, lMsgErr) = False Then
                Call gM46V999.gpFecha2(CnBD)
                GoTo TrataErro
            End If
            
            If Not rsBoleto.EOF() Then
                If Not rsBoleto!COD_BANCO Is Nothing Then
                    If rsBoleto!COD_BANCO <> objstcPedido.Cod_Bco_Cobr And _
                    (Left(objstcPedido.objstcCtrlEmis.Num_Bloq, 1) = 4 Or Left(objstcPedido.objstcCtrlEmis.Num_Bloq, 1) = 5) Then 'boleto avulso / automatico
                        objstcPedido.Cod_Bco_Cobr = rsBoleto!COD_BANCO
                    End If
                End If
            End If
            
        End If
    
        'Interface SAP
        lMsgErr = Empty
        If Not GravaInterfaceSAP(objPedido, objstcPedido, lMsgErr) Then
            If gM46V999.gfPreenchido(lMsgErr) Then
                GoTo TrataErro
            End If
        End If
        
        'Grava��o PI para inspe��o
        lMsgErr = Empty
        If Not GravaPIinspecao(objPedido, objstcPedido, lMsgErr) Then
            If gM46V999.gfPreenchido(lMsgErr) Then
                GoTo TrataErro
            End If
        End If
        
        'Salvar Texto formatado
        lMsgErr = Empty
        lSql = "DELETE FROM TAB_PED_TEXTO_APOL WHERE NUM_PI = " & objstcPedido.NUM_PI
        If gM46V999.gfExeSQL(CnBD, lSql, lMsgErr) <> 0 Then
            Call gM46V999.gpFecha2(CnBD)
            GoTo TrataErro
        End If
        
        lSql = "EXEC dbo.[proc_RetornaTexto] " & objstcPedido.NUM_PI
        If gM46V999.gfExeSQL(CnBD, lSql, lMsgErr) <> 0 Then
            Call gM46V999.gpFecha2(CnBD)
            GoTo TrataErro
        End If
        
        'Transmitir
        If mfTransmitir(False, lMsgErr) = False Then
            If gM46V999.gfPreenchido(lMsgErr) Then
                GoTo TrataErro
            End If
        End If
    End If
    
Fim:
    Screen.MousePointer = vbDefault
    Set rsBoleto = Nothing
    Exit Sub
    
TrataErro:
    If Err.Number <> 0 Then
        lMsgErr = "Erro: " & Err & " Descri��o: " & Err.Description & " SQL: " & lSql
    End If
    lMsgErr = "[ERR] - mnuArqTransmitir_Click Erro: " & lMsgErr
    Call gM46V999.gpGraLog(1, lMsgErr)
    GoTo Fim
End Sub

Private Function mfExisteErrosTriagem() As Boolean
    Dim lSelect As String       'Select
    Dim lrst As clsYasRecordSet    'Registro
    Dim lMensagem As String         'Mensagem
    Dim bdGed As ADODB.Connection

    mfExisteErrosTriagem = False

    If Not gM46V999.gfAbrBasDados("GED", gM46V999.gTipGed, gM46V999.gEndGed, bdGed, lMensagem) Then
        Call gM46V999.gpGraLog(1, lMensagem)
        Exit Function
    End If

    'Se n�o tem registro na base do GED � porque � a primeira digita��o (IST)
    lSelect = "Select * from ged.dbo.tab_ctrl_emis where num_pi = " & gM46V111.gNum_Pi

    If gM46V999.gfObtRegistro(bdGed, lSelect, lrst, lMensagem) = False Then
        Call gM46V999.gpGraLog(1, lMensagem)
        Exit Function
    End If

    If lrst.EOF Then
        lSelect = "Select * from ged.dbo.tab_prop_mensagem where num_pi = " & gM46V111.gNum_Pi
        lSelect = lSelect & " and dat_liber=0"

        If gM46V999.gfObtRegistro(bdGed, lSelect, lrst, lMensagem) = False Then
            Call gM46V999.gpGraLog(1, lMensagem)
            Exit Function
        End If
        If lrst.EOF Then
            mfExisteErrosTriagem = False
        Else
            Dim lCod_mensagem As String
            Do While Not lrst.EOF
                lCod_mensagem = "" & lrst!cod_mensagem
                If lCod_mensagem <> "10000" And lCod_mensagem <> "10001" And lCod_mensagem <> "10002" And lCod_mensagem <> "10003" Then
                    mfExisteErrosTriagem = True
                End If
                lrst.MoveNext
            Loop
        End If
    End If

End Function

