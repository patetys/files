Private Function mfSalvarJuros(pMensagem As String) As Boolean
    Dim lobjPedJuros As clsA46V711A
    Dim lobjstcPedJuros As stcA46V711B
    Dim lI As Integer

    On Error GoTo ControleErro

    Set lobjPedJuros = New clsA46V711A
    Set lobjPedJuros.M46V999 = gM46V999

    Set lobjstcPedJuros = New stcA46V711B
    '    If objstcPedido.ColecaoPedJuros.Count > 0 Then
    lobjstcPedJuros.nosso_numero = objstcPedido.nosso_numero
    If Not lobjPedJuros.mfExcluir(lobjstcPedJuros, "", "", "") Then
        pMensagem = lobjPedJuros.UltimoErro
        GoTo Finalizar
    End If
    '    End If
    Set objstcPedido.ColecaoPedJuros = New Collection

    ''2016-08-05: Check Exception de Juros
    Call CheckExceptionJuros

    For lI = 1 To 12    '<- originalmente 10
        'Carne
        Set lobjstcPedJuros = New stcA46V711B
        With lobjstcPedJuros
            .nosso_numero = objstcPedido.nosso_numero
            .Num_Parcela = lI
            
            'Estava zerando os juros da 1 parcela
'            If lI > 1 Then
                .Val_Ant = frmT46V142A.txtAntJuro(lI).Text
                .Val_Pos = frmT46V142A.txtPosJuro(lI).Text
'            Else
'                .Val_Ant = 0
'                .Val_Pos = frmT46V142A.txtPosJuro(lI).Text
'            End If
            .Tip_Compensacao = e_FormaPagamento.e_FormaPagamento_Carne
        End With
        If Not lobjPedJuros.mfIncluir(lobjstcPedJuros, "", "", "") Then
            pMensagem = lobjPedJuros.UltimoErro
            GoTo Finalizar
        End If
        objstcPedido.ColecaoPedJuros.Add lobjstcPedJuros, lobjstcPedJuros.Class_ID

        'Debito em conta
        Set lobjstcPedJuros = New stcA46V711B
        With lobjstcPedJuros
            .nosso_numero = objstcPedido.nosso_numero
            .Num_Parcela = lI
            If lI > 1 Then
                .Val_Ant = frmT46V142A.txtAntJuro(lI + 12).Text
                .Val_Pos = frmT46V142A.txtPosJuro(lI + 12).Text
            Else
                .Val_Ant = 0
                .Val_Pos = frmT46V142A.txtPosJuro(lI + 12).Text
            End If
            .Tip_Compensacao = e_FormaPagamento.e_FormaPagamento_Debito
        End With
        If Not lobjPedJuros.mfIncluir(lobjstcPedJuros, "", "", "") Then
            pMensagem = lobjPedJuros.UltimoErro
            GoTo Finalizar
        End If
        objstcPedido.ColecaoPedJuros.Add lobjstcPedJuros, lobjstcPedJuros.Class_ID
        
        'Cartao de Credito
        If objstcPedido.Cod_Bco_Cobr = 999 And objstcPedido.Cod_Agen_Bas_Cor = 9999 And objstcPedido.Num_Cta_Bas_Cor = 9999999 Then
            Set lobjstcPedJuros = New stcA46V711B
            With lobjstcPedJuros
                .nosso_numero = objstcPedido.nosso_numero
                .Num_Parcela = lI
                .Val_Ant = frmT46V142A.txtAntJuro(lI + 24).Text
                .Val_Pos = frmT46V142A.txtPosJuro(lI + 24).Text
                .Tip_Compensacao = 4
            End With
            If Not lobjPedJuros.mfIncluir(lobjstcPedJuros, "", "", "") Then
                pMensagem = lobjPedJuros.UltimoErro
                GoTo Finalizar
            End If
            objstcPedido.ColecaoPedJuros.Add lobjstcPedJuros, lobjstcPedJuros.Class_ID
        End If
    Next
    mfSalvarJuros = True
Finalizar:
    Set lobjstcPedJuros = Nothing
    Set lobjPedJuros = Nothing
    Exit Function
ControleErro:
    Set lobjstcPedJuros = Nothing
    Set lobjPedJuros = Nothing
    If gM46V999.gfPreenchido(pMensagem) = False Then
        pMensagem = Err.Description
    End If
    Call gM46V999.gpGraLog(0, "mfSalvarJuros ERRO - " & Err & " " & ERROR & _
                              Chr(13) & pMensagem)
End Function


Private Function mfSalvarCorretores(pMensagem As String) As Boolean
    Dim lObjPedCorr As clsA46V705A
    Dim lObjstcPedCorr As stcA46V705B
    Dim lI As Integer
    Dim lJ As Integer
    Dim lGravaPerCorr As Boolean

    On Error GoTo ControleErro

    Set lObjPedCorr = New clsA46V705A
    Set lObjPedCorr.M46V999 = gM46V999

    Set lObjstcPedCorr = New stcA46V705B
    Set lObjstcPedCorr.M46V999 = gM46V999

    If objstcPedido.ColecaoPedCorr.Count > 0 Then
        lObjstcPedCorr.nosso_numero = objstcPedido.nosso_numero
        If Not lObjPedCorr.mfExcluir(lObjstcPedCorr, "", "", "") Then
            pMensagem = lObjPedCorr.UltimoErro
            GoTo Finalizar
        End If
    End If

    Set objstcPedido.ColecaoPedCorr = New Collection

    For lJ = 1 To 3
        gCod_RamoCorr = 0
        lGravaPerCorr = True
        If gM46V999.gCod_Ramo <> e_CodRamo_Automoveis Then
            gCod_RamoCorr = objstcPedido.Cod_Ramo
        Else
            If lJ = 1 Then
                gCod_RamoCorr = e_CodRamoAuto
                If objstcPedido.objstcPedAuto.Val_Pr_Auto = 0 Then
                    lGravaPerCorr = False
                End If
            ElseIf lJ = 2 And objstcPedido.objstcPedAuto.Val_Pr_Rc <> 0 Then
                gCod_RamoCorr = e_CodRamoRC
            ElseIf lJ = 3 And objstcPedido.objstcPedAuto.Val_Pr_App <> 0 Then
                gCod_RamoCorr = e_CodRamoapp
            End If
        End If
        If gCod_RamoCorr <> 0 Then
            For lI = 1 To 3
                If val(frmT46V102A.txtCorretor(lI).Tag) <> 0 Then
                    Set lObjstcPedCorr = New stcA46V705B
                    Set lObjstcPedCorr.M46V999 = gM46V999

                    With lObjstcPedCorr
                        .nosso_numero = objstcPedido.nosso_numero
                        .Cod_Corr = frmT46V102A.txtCorretor(lI).Tag
                        .Num_Ordem_Corr = lI
                        If lGravaPerCorr Then .Per_Corr = gM46V999.CDblx(frmT46V102A.txtCorComissao(lI).Text)
                        .Cod_Ramo = gCod_RamoCorr
                        .Num_Ped = objstcPedido.Num_Ped
                        .NUM_PI = gM46V111.gNum_Pi
                    End With
                    If Not lObjPedCorr.mfIncluir(lObjstcPedCorr, "", "", "") Then
                        pMensagem = lObjPedCorr.UltimoErro
                        GoTo Finalizar
                    End If
                    objstcPedido.ColecaoPedCorr.Add lObjstcPedCorr, lObjstcPedCorr.Class_ID
                End If
            Next lI
        End If
        If gM46V999.gCod_Ramo <> e_CodRamo_Automoveis Then
            Exit For
        End If
    Next lJ

SelecionaRamosAuto:
Terminou:

    mfSalvarCorretores = True
Finalizar:
    Set lObjstcPedCorr = Nothing
    Set lObjPedCorr = Nothing
    Exit Function

ControleErro:
    Set lObjstcPedCorr = Nothing
    Set lObjPedCorr = Nothing
    If gM46V999.gfPreenchido(pMensagem) = False Then
        pMensagem = Err.Description
    End If
    Call gM46V999.gpGraLog(0, "mfSalvarCorretores ERRO - " & Err & " " & ERROR & _
                              Chr(13) & pMensagem)
End Function

