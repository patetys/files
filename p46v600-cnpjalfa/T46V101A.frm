Private Function mfCarregar_101A()
    Dim lMensagem As String     'Mensagem.
    Dim lDiasDatVenc As Integer

    flagCalcular = False
    isEndosso = False
    optSinistroSinNaoChanged = False

    Screen.MousePointer = vbHourglass
    Call TesteDesempenho("mfCarregar_101A " & gM46V111.gComNosNumero)

    '[Instanciar a classe]
    Set objPedido = New clsA46V702A
    Set objPedido.M46V999 = gM46V999

    Set objstcPedido = New stcA46V702B
    Set objstcPedido.M46V999 = gM46V999

    objstcPedido.nosso_numero = gM46V111.gComNosNumero
    
    Call TesteDesempenho("mfCarregar_101A Objetos " & gM46V111.gComNosNumero)
    If Not objPedido.mfCarregarColecao(objstcPedido, "", "", True) Then
        Call gM46V999.gpGraLog(1, objPedido.UltimoErro)
