Private Function mfPosicionaJuros() As Boolean
    Dim lJuros As Single
    Dim lMensagem As String
    Dim lI As Integer

    For lI = 1 To 12
    
        If objstcPedido.Num_PI_Auto_Progresso <> 0 And lI = objstcPedido.Qtd_Parc_Progresso Then
            lJuros = objstcPedido.Per_Juro_Progresso
            frmT46V142A.txtAntJuro(lI).Text = Format(lJuros, "standard")
            frmT46V142A.txtPosJuro(lI).Text = Format(lJuros, "standard")
            frmT46V142A.txtAntJuro(lI + 12).Text = Format(lJuros, "standard")
            frmT46V142A.txtPosJuro(lI + 12).Text = Format(lJuros, "standard")
        Else
            'Carne
            '1001224 - Condi��es Diferenciada - Seguratec
            If Not gM46V111.gfBuscaJurosParm(objstcPedLoc, lI, 1, e_FormaPagamento_Carne, lJuros, lMensagem) Then
                Call gM46V999.gpGraLog(0, lMensagem)
            End If
            frmT46V142A.txtAntJuro(lI).Text = Format(lJuros, "standard")
            '1001224 - Condi��es Diferenciada - Seguratec
            If Not gM46V111.gfBuscaJurosParm(objstcPedLoc, lI, 2, e_FormaPagamento_Carne, lJuros, lMensagem) Then
                Call gM46V999.gpGraLog(0, lMensagem)
            End If
            frmT46V142A.txtPosJuro(lI).Text = Format(lJuros, "standard")
    
            'Debito em conta
            '1001224 - Condi��es Diferenciada - Seguratec
            If Not gM46V111.gfBuscaJurosParm(objstcPedLoc, lI, 1, e_FormaPagamento_Debito, lJuros, lMensagem) Then
                Call gM46V999.gpGraLog(0, lMensagem)
            End If
                frmT46V142A.txtAntJuro(lI + 12).Text = Format(lJuros, "standard")
            '1001224 - Condi��es Diferenciada - Seguratec
            If Not gM46V111.gfBuscaJurosParm(objstcPedLoc, lI, 2, e_FormaPagamento_Debito, lJuros, lMensagem) Then
                Call gM46V999.gpGraLog(0, lMensagem)
            End If
                frmT46V142A.txtPosJuro(lI + 12).Text = Format(lJuros, "standard")
    
        End If
    Next lI

    mfPosicionaJuros = True
End Function

