        If gM46V103.mfAjustesPontuais(e_Tip_Valor_DescComl, TpoValor, lCoef_Desc_Coml, lMensagem, objstcPedLoc, 0, "") = False Then
            Call gM46V999.gpGraLog(0, lMensagem)
        End If
        txtDescComercial.Text = Format(lCoef_Desc_Coml, "standard")
    End If

    'CR93893 - Ajuste para quando mudar a classifica��o zerar o Num_PI
    Dim lCobert As stcA46V704B
    For Each lCobert In objstcPedLoc.ColecaoPedCobert
        lCobert.Num_Meses_PI = 0
