Private Function mfGeraLogCalculo(ByRef pMsgErr As String) As Boolean
    Dim clsA46V101A As clsA46V101A  'Cria arquivo de transmiss�o.
    Dim lobjPedido As clsA46V702A    'Objeto da classe clsA46V702A  (TAB_PED)
    Dim lArqTransmissao As String           'Endere�o do arquivo de transmiss�o.
    Dim lCodCorretor As Long          'C�digo do corretor.
    Dim lMensagem As String     'Mensagem.
    Dim lUsuario As String    'Long     'C�digo do usu�rio de transmiss�o.

    Err.Clear
    On Error GoTo TrataErro: mfGeraLogCalculo = False

    '4. Posiciona controles para criar arquivo de transmiss�o.
    If gM46V999.gfPreenchido(frmT46V102A.txtCorretor(1).Tag) Then
        lCodCorretor = frmT46V102A.txtCorretor(1).Tag
    Else
        lCodCorretor = 9999999
    End If

    '5. Busca o usuario de Transmissao
    If gfBuscaUsuarioTransmissao(lUsuario, lMensagem) = False Then
        GoTo TrataErro
    End If
    Set clsA46V101A = New clsA46V101A
    Set clsA46V101A.M46V999 = gM46V999

    Set lobjPedido = New clsA46V702A
    Set lobjPedido.M46V999 = gM46V999
    lobjPedido.Colecao.Add objstcPedido, objstcPedido.Class_ID

    '6. Cria arquivo de transmiss�o. (da COTACAO * somente log de calculo)
    If clsA46V101A.gfCriArqTransmissao(lCodCorretor, lUsuario, _
                                       lobjPedido.Colecao, lArqTransmissao, lMensagem, , , True) = False Then
        GoTo TrataErro
    End If

    ' =====================
    'Finalizado com Sucesso
    mfGeraLogCalculo = True
    ' =====================

SAIDA:
    '9. Encerra processo.
    GoSub FechaObj: Err.Clear
    On Error GoTo 0
    Exit Function

TrataErro:
    If gM46V999.gfPreenchido(lMensagem) = False Then
        lMensagem = Err & " - " & ERROR
    End If
    pMsgErr = "mfTransmitir Erro:" & lMensagem
    GoTo SAIDA

FechaObj:
    Set clsA46V101A = Nothing
    Set lobjPedido = Nothing
    Return
End Function

