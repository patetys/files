Function mfSalvar() As Boolean
'********************Vari�veis padr�o*************************************
    Dim lCkPoint As String    'Variavel utilizada para determinar pontos onde o c�digo j� passou.
    Dim lCkStr As String    'Variavel utilizada para guardar a posi��o das variaveis at� o ultimo
'lCkPoint. (posi��o das variaveis em ordem de declara��o)
'********************Vari�veis Declaradas para o processamento************
    Dim lMensagem As String    'Mensagem.
    Dim lAtivo As String
    Dim lBlnSiscad As Boolean    'Indicador se existe dados no Siscad
    Dim lI As Integer
    Dim lLin As Integer
    Dim lLin2 As Integer
    Dim lcol As Integer
    Dim lDig As String
    Dim clsA99V001 As clsA99V001
    Dim lQtdTelPrinc As Integer
    Dim lLinTelPrinc As Integer

    gM46V999.gDesconsiderou = 0

    If gM46V999.gChamaSelecionarCoberturas = True Then
        Call frmT46V117A.mpSelecionarCoberturas(objstcPedLoc.ColecaoPedCobert)
        Call frmT46V117A.mpCepAlterado
    End If

    AlteraFranquia = False
    If gM46V999.gDesabilitarForms Then
        If Not mfSalvarEspecificacao(lMensagem) Then GoTo ControleErro
        If Not frmT46V193A.mfAlterarDadosInspecao(lMensagem, objstcPedLoc, txtNumInsp.Text) Then GoTo ControleErro
        mfSalvar = True
        Exit Function
    End If

    Err = 0
    lCkPoint = ""
    lCkStr = ""

    mfSalvar = False
    On Error GoTo ControleErro
    '1. Verifica situa��o do documento.
    lCkPoint = "1"
    If objstcPedido.Cod_Sit_Ped = e_SitPedido_Transmitido Then
        lMensagem = "AGE0020 - Proposta " & gM46V111.gNumPedido & " (nosso n�mero " & gM46V111.gComNosNumero & _
                    ") j� transmitida." & vbLf & vbLf & _
                    "Foi acionado o processo de salvar os dados da proposta e este processo modifica " & _
                    "a indica��o de que a proposta j� foi transmitida." & vbLf & vbLf & _
                    "Confirma a execu��o deste processo?"
        If MsgBox(lMensagem, vbQuestion + vbYesNo + vbDefaultButton2) = vbYes Then
            Call gM46V999.gpGraLog(0, lMensagem & " SIM.")
        Else
            Call gM46V999.gpGraLog(0, lMensagem & " N�O.")
            mfSalvar = True
            Exit Function
        End If
    End If
    lCkPoint = "2"

    '1. Se foco est� em algum campo que possue evento LostFocus, o mesmo deve ser acionado.
    'Obs.: Estes comandos foram necess�rios pois em um caso muito especial n�o existe nenhum campo com
    '      com foco e ocorreu erro.
    On Error Resume Next
    lAtivo = UCase$(ActiveControl.Name)
    On Error GoTo 0
    If gM46V999.gCod_Ramo = e_CodRamo_Roubos Or gM46V999.gCod_Ramo = e_CodRamo_Riscos_diversos Then
        If val(Replace(frmT46V102A.txtCep.Text, "-", "")) = 0 And val(Replace(Me.txtRisCEP.Text, "-", "")) <> 0 Then
            With frmT46V102A
                .txtTipLogradouro = Me.txtRisTipLogradouro.Text
                .txtNomLogradouro = Me.txtRisNomLogradouro.Text
                .txtNumero = Me.txtRisNumero
                .txtComplemento = Me.txtRisComplemento.Text
                .txtBairro = Me.txtRisBairro.Text
                .txtCidade = Me.txtRisCidade.Text
                .cboUF.Text = Me.cboRisUF.Text
                .txtCep = Me.txtRisCEP.Text
            End With
        End If
    End If


    If gM46V999.gfPreenchido(lAtivo) Then
        Select Case lAtivo
        Case "TXTRISCEP"
            If gM46V999.gfPreenchido(txtRisCEP.Text) Then
                Call txtRisCEP_LostFocus
                If Not gM46V999.gfPreenchido(txtRisCEP.Text) Then
                    Exit Function
                End If
            End If
        Case "TXTCOMISSAO"
            If gM46V999.gfPreenchido(txtComissao.Text) Then
                Call txtComissao_LostFocus
                If Not gM46V999.gfPreenchido(txtComissao.Text) Then
                    Exit Function
                End If
            End If
        Case "TXTVIGINICIO"
            If gM46V999.gfPreenchido(txtVigInicio.Text) Then
                Call txtVigInicio_LostFocus
                If Not gM46V999.gfPreenchido(txtVigInicio.Text) Then
                    Exit Function
                End If
            End If
        Case "TXTVIGTERMINO"
            If gM46V999.gfPreenchido(txtVigTermino.Text) Then
                Call txtVigTermino_LostFocus
                If Not gM46V999.gfPreenchido(txtVigTermino.Text) Then
                    Exit Function
                End If
            End If
        Case "TXTISBAS"
            If gM46V999.gfPreenchido(txtISBas.Text) Then
                Call txtISBas_LostFocus
                If Not gM46V999.gfPreenchido(txtISBas.Text) Then
                    Exit Function
                End If
            End If
        Case "TXTVALORISCO"
            If gM46V999.gfPreenchido(txtValoRisco.Text) Then
                Call txtValoRisco_LostFocus
                If Not gM46V999.gfPreenchido(txtValoRisco.Text) Then
                    Exit Function
                End If
            End If
            '[FRH-F901588][CASE abaixo para que seja ajustado o Desc.Coml tamb�m ao utilizar a
            '              tecla de atalho F3 para calcular]
        Case UCase("txtDescComercial")
            If gM46V999.gfPreenchido(txtDescComercial.Text) Then
                Call txtDescComercial_LostFocus
                If Not gM46V999.gfPreenchido(txtDescComercial.Text) Then
                    Exit Function
                End If
            End If
        End Select
    End If

    'Atualizar com os dados do Siscad
    lCkPoint = "2AA"

    If gM46V999.gTipUsuario = e_Tipo_Usu_Yasuda And (gM46V999.PerfilAcesso <> e_Perfil_CALC And gM46V999.PerfilAcesso <> e_Perfil_CALC_Gestor) Then
        Call frmT46V102A.mpAtualizaDadosSegurado(lBlnSiscad, False)
        If lBlnSiscad = False Then
            lMensagem = "FGE0020 - Dados do Siscad n�o localizados."
            MsgBox lMensagem, vbInformation
            If Not UCase(gM46V999.gSerDIVERSOS) Like "*MIX*" Then
                'Exit Function
            End If
            lMensagem = ""
        End If
    End If

    lCkPoint = "2AB"
    If gM46V999.gfDisponivel("frmT46V129A") Then
        For lI = 1 To frmT46V129A.flxBens.Rows - 1
            If Not gM46V999.gfPreenchido(frmT46V129A.flxBens.TextMatrix(lI, 1)) And _
               Not gM46V999.gfPreenchido(frmT46V129A.flxBens.TextMatrix(lI, 2)) And _
               gM46V999.CDblx(frmT46V129A.flxBens.TextMatrix(lI, 3)) = 0 Then
                'Nenhum campo preenchido (ignorar)
            ElseIf Not gM46V999.gfPreenchido(frmT46V129A.flxBens.TextMatrix(lI, 2)) Or _
                   gM46V999.CDblx(frmT46V129A.flxBens.TextMatrix(lI, 3)) = 0 And _
                   gM46V999.gCod_Ramo = e_CodRamo_Roubos Then
                lMensagem = "FNL0053 - Preencher corretamente a linha " & lI & " da tela de Rela��o de Bens."
                MsgBox lMensagem, vbInformation
                frmT46V129A.Show
                Exit Function
            ElseIf Not gM46V999.gfPreenchido(frmT46V129A.flxBens.TextMatrix(lI, 1)) Or _
                   Not gM46V999.gfPreenchido(frmT46V129A.flxBens.TextMatrix(lI, 2)) Then 'Or _
                   'gM46V999.CDblx(frmT46V129A.flxBens.TextMatrix(lI, 3)) = 0 Then
                If gM46V999.gCod_Ramo <> e_CodRamo_Roubos Then
                    lMensagem = "FNL0053 - Preencher corretamente a linha " & lI & " da tela de Rela��o de Bens."
                    MsgBox lMensagem, vbInformation
                    frmT46V129A.Show
                    Exit Function
                End If
            End If
        Next
    End If

    lCkPoint = "2AC"
    If gM46V999.gfDisponivel("frmT46V184A") Then
        With frmT46V184A.flxBenef
            For lLin = 1 To .Rows - 1
                For lcol = 1 To .Cols - 3
                    'Todos os campos s�o obrigat�rios
                    If (optBeneficiario(0).Value = True) And (Not gM46V999.gfPreenchido(.TextMatrix(lLin, lcol))) Then
                        lMensagem = "FNL0053 - Preencher corretamente a linha " & lLin & " da tela de Inclus�o de Benefici�rios."
                        MsgBox lMensagem, vbInformation
                        frmT46V184A.Show
                        DoEvents
                        Exit Function
                    End If

                    Set clsA99V001 = New clsA99V001     'Calcula d�gitos.
                    Set clsA99V001.M46V999 = gM46V999

                    'Tipo pessoa
                    If lcol = 2 Then
                        If gM46V999.gfPreenchido(.TextMatrix(lLin, lcol)) = True Then
                            If UCase(.TextMatrix(lLin, lcol)) = "F�SICA" Then
                                If Not clsA99V001.DIG_CPF(.TextMatrix(lLin, 3), lDig, lMensagem) Then
                                    lMensagem = "FNL0053 - Preencher corretamente CPF na linha " & lLin & " da tela de Inclus�o de Benefici�rios."
                                    MsgBox lMensagem, vbInformation
                                    frmT46V184A.Show
                                    Exit Function
                                End If
                            Else
                                If Not clsA99V001.DIG_CNPJ(.TextMatrix(lLin, 3), lDig, lMensagem) Then
                                    lMensagem = "FNL0053 - Preencher corretamente CNPJ na linha " & lLin & " da tela de Inclus�o de Benefici�rios."
                                    MsgBox lMensagem, vbInformation
                                    frmT46V184A.Show
                                    Exit Function
                                End If
                            End If
                        End If
                    End If

                    'CPF / CNPJ
                    If lcol = 3 Then
                        If lLin > 1 Then
                            For lLin2 = 1 To .Rows - 1
                                If lLin <> lLin2 Then
                                    If .TextMatrix(lLin, lcol) = .TextMatrix(lLin2, lcol) Then
                                        '' 20180615: Ignorar regra se imobiliario
                                        If objstcPedido.Cod_Estip <> 20 Then
                                            lMensagem = "FNL0053 - CPF / CNPJ duplicado na linha " & lLin & " da tela de Inclus�o de Benefici�rios."
                                            MsgBox lMensagem, vbInformation
                                            frmT46V184A.Show
                                            Exit Function
                                        End If
                                    End If
                                End If
                            Next
                        End If
                    End If

                    'Participa��o
                    If lcol = 5 Then
                        If val(.TextMatrix(lLin, lcol)) > 100 Then
                            lMensagem = "FNL0053 - Participa��o n�o pode ser maior que 100% na linha " & lLin & " da tela de Inclus�o de Benefici�rios."
                            MsgBox lMensagem, vbInformation
                            frmT46V184A.Show
                            Exit Function
                        End If
                    End If
                Next
            Next

            Set clsA99V001 = Nothing
        End With

        If gM46V999.gfPreenchido(frmT46V184A.flxBenef) = True And optBeneficiario(0).Value = True Then
            If val(frmT46V184A.lblPartic.Caption) <> 100 Then
                lMensagem = "FNL0053 - A soma do valor de participa��o deve ser igual a 100% na tela de Inclus�o de Benefici�rios."
                MsgBox lMensagem, vbInformation
                frmT46V184A.Show
                Exit Function
            End If
        End If
        
        Dim linhas As Integer
        Dim Linha As Variant
        
        Linha = mfSplitClausula(frmT46V184A.txtClausula.Text, Asc(vbCrLf), 80)
        
        If UBound(Linha) > 10 Then
            lMensagem = "FNL0053 - A clausula beneficiaria n�o pode ter mais de 10(dez) linhas."
            MsgBox lMensagem, vbInformation
            frmT46V184A.Show
            Exit Function
        End If
        
    End If

    lCkPoint = "2AD"

    '2. Salvo os dados de comum
    lCkPoint = "2A"
    If Not mfSalvarComum(lMensagem) Then GoTo ControleErro

    lCkPoint = "2B"
    '3. Salvo os dados do item
    If Not mfSalvarItem(lMensagem) Then GoTo ControleErro
    
''    If bInspFlag <> 1 Then 'S� entrar� sen�o estiver pesquisando item
''        ''    '3.1 Verifica a inspe��o programada com o n� da mesma
''        If Not mfVerificaProgramada(lMensagem) Then GoTo ControleErro
''    End If
    
''    bInspFlag = 2
    
    lCkPoint = "2C"
    '3.2.Salvo a observa��o
    If Not mfSalvarObsLocalCertificado(lMensagem) Then GoTo ControleErro

    '3.3. Salva dados de inspe��o de todos os itens
    Dim objTabPedLoc As stcA46V708B
    Dim lobjInspecao As clsA46V717A
    
    Set lobjInspecao = New clsA46V717A
    Set lobjInspecao.M46V999 = gM46V999
    
    For Each objTabPedLoc In objstcPedido.ColecaoPedLoc
        Set lobjInspecao.ConexaoBD = objPedido.ConexaoBD
        If gM46V999.gfPreenchido(objTabPedLoc.objstcPedInsp.nosso_numero) Then
            objTabPedLoc.objstcPedInsp.nosso_numero = objTabPedLoc.nosso_numero
            objTabPedLoc.objstcPedInsp.Num_Item = objTabPedLoc.Num_Item
            lobjInspecao.mfExcluir objTabPedLoc.objstcPedInsp, "", ""
        End If
    
        If Not lobjInspecao.mfIncluir(objTabPedLoc.objstcPedInsp, "", "", "") Then
            lMensagem = "lobjInspecao.mfIncluir - " & lobjInspecao.UltimoErro
            GoTo ControleErro
        End If
    Next

    lCkPoint = "18"
    'Salvar Texto da Especifica��o (Beneficiarios)
    'tem que ser depois que salva o item para utilizar a colecao de coberturas atualizada.
    If Not mfSalvarTextoEspecPadrao(lMensagem, False) Then GoTo ControleErro

    lCkPoint = "4"
    '4. Atualizo a grade de itens
    Call mpCriGraItens
    lCkPoint = "5"
    '5. Desabilito o salvar.
    Call mpDesSalvar
    lCkPoint = "6"

    gM46V999.gEfetuouCalculo = False
    mfSalvar = True

    Exit Function
ControleErro:
    Call gM46V999.gpGraLog(1, "mfSalvar ERRO - " & lMensagem, vbCritical)
    'Obtem o inicio da mensagem de erro
    If Err.Number <> 0 Then
        lMensagem = "mfSalvar ERRO - " & Err & " " & ERROR & _
                        Chr(13) & "CheckPoint " & lCkPoint & " - " & lMensagem
        Call gM46V999.gpGraLog(0, lMensagem)
    End If
    
''    bInspFlag = 3
    
    mfSalvar = False
End Function
