    Call TesteDesempenho("mpAtualizaJurosNovo " & gM46V111.gComNosNumero)
    
    'Juros por parcela.
    Dim MaxAntec As Integer, MaxPosPg As Integer
    MaxAntec = 4  'M�ximo permitido de Parcelas sem juros
    MaxPosPg = 3

    If gCodCorrInst = 1601 Or gCodCorrInst = 0 Then
        'Diferenciado para Seguratec - 15/02/2007 - Fernando
        MaxAntec = gM46V999.gProQuaMaxParcelas
        MaxPosPg = gM46V999.gProQuaMaxParcelas
    ElseIf gCodCorrInst = 435241 Or gCodCorrInst = 288911 Then
        'Diferenciado para Avant Marine 435241 e Marine 288911 - 15/02/2007 - Fernando
        MaxAntec = 5
        MaxPosPg = 4
        'Ficha 901507
    ElseIf (gCodCorrInst = 8001 Or gCodCorrInst = 8002 Or gCodCorrInst = 8003 Or gCodCorrInst = 8004 Or _
            gCodCorrInst = 8005 Or gCodCorrInst = 8006 Or gCodCorrInst = 8008 Or gCodCorrInst = 8011 Or _
            gCodCorrInst = 8014 Or gCodCorrInst = 8028) And gM46V999.gCod_Ramo = e_CodRamo_Residencial Then
        'Diferenciado para Volks - 15/09/2009
        MaxAntec = 9
        MaxPosPg = 9
        gM46V999.gProQuaMaxParcelas = 9
    End If

    'Ficha 901772
    If gM46V999.gCod_Ramo = e_CodRamo_Residencial And gM46V111.gCod_plano = 1 And gCodCorrInst = 1601 Then
        If (Left(frmT46V101A.txtClassificacao, 7) = "001 -11" Or Left(frmT46V101A.txtClassificacao.Text, 6) = "001-11" Or _
            Left(frmT46V101A.txtClassificacao, 7) = "001 -11" Or Left(frmT46V101A.txtClassificacao.Text, 6) = "001-21") Then
            'Diferenciado para Seguratec - 23/11/2009
            MaxAntec = 5
            MaxPosPg = 4
        End If
    End If

    If gM46V999.gTipoAcesso = DIGITACAO Then
        If frmT46V102A.txtJuros.Enabled Then
            If gM46V999.gfPreenchido(frmT46V102A.txtJuros.Text) Then
                lPerJuros = frmT46V102A.txtJuros.Text
