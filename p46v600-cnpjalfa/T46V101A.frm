                            ElseIf flxVista.Rows <= CByte(lParcelasGrid) Then
                                If CByte(lParcelasGrid) = 1 Then
                                    .AddItem "Fracionamento n�o contempla 1 parcela."
                                Else
                                    .AddItem "Fracionamento n�o contempla " & _
                                             lParcelasGrid & " parcelas."
                                    .AddItem "N�mero m�ximo de parcelas permitido: " & (flxVista.Rows - 1)
                                    gCarga = True
                                    frmT46V102A.txtQuaParcelas.Text = (flxVista.Rows - 1)
                                    gCarga = False
                                End If
                            Else
                                flxVista.row = CByte(lParcelasGrid)
                                flxVista.Col = 1  'Valor da primeira parcela.
                                If flxVista.Text = "" Then flxVista.Text = 0
                                lParcela1 = CDbl(flxVista.Text)
                                flxVista.Col = 2  'Valor das demais parcelas.
                                If flxVista.Text = "" Then flxVista.Text = 0
                                lParcelaN = CDbl(flxVista.Text)
                                flxVista.Col = 3  'Juro.
                                lJuros = flxVista.Text
                                Call mpPosResParcelamento(lParcelasGrid, _
                                                          lParcela1, lParcelaN, lJuros)
                            End If
                        Else
                            flxVista.row = CByte(gM46V999.gProQuaMaxParcelas)
                            flxVista.Col = 1  'Valor da primeira parcela.
                            lParcela1 = CDbl(flxVista.Text)
                            flxVista.Col = 2  'Valor das demais parcelas.
                            lParcelaN = CDbl(flxVista.Text)
                            flxVista.Col = 3  'Juro.
                            lJuros = flxVista.Text
                            Call mpPosResParcelamento(gM46V999.gProQuaMaxParcelas, lParcela1, lParcelaN, _
                                                      lJuros)
                        End If
                    End If
                Else
                    .AddItem "Parcelamento n�o calculado:"
                    .AddItem "- quantidade de parcelas n�o num�rica."
                End If
            Else
                .AddItem "Parcelamento n�o calculado:"
                .AddItem "- quantidade de parcelas n�o preenchida."
            End If
        End With
    End If

    objstcPedido.Dat_Liber = Left(lUltData, 8)
    objstcPedido.Hor_Liber = Mid(lUltData, 9, 4)
    objstcPedido.Cod_User_Liber = gM46V999.gNomUsuario6
    

    'Campo inclu�do por solicita��o da Sandra 03/12/2010
    objstcPedido.Ind_CondGerais = 1

    If gM46V999.gPermitePrInformado Then
        'Salvar ctrl_emiss com os novos premios atualizados
        If Not mfSalvarCtrlEmiss(lMensagem) Then Exit Function
    End If

    '===17) Altera o registro.
    'a)
    If Not objPedido.mfAlterar(objstcPedido, "", "", mComUltData, mComUltUsuario) Then
        Call gM46V999.gpGraLog(2, objPedido.UltimoErro)
        Exit Function
    End If
    'b) Posiciona informa��es de data e usu�rio da �ltima atualiza��o.
    mComUltData = Left(lUltData, 8)
    mComUltUsuario = gM46V999.gNomUsuario6
    lCkPoint = "16"
    '13. Calcula e grava c�digo de verifica��o da unicidade da proposta.
    'a) Calcula c�digo de verifica��o.
    If objstcPedido.Cod_Tip_Doc = e_TipDoc_Proposta Then
        If gM46V999.gfCalCodUnicidade_V1(objstcPedido, lMensagem) = False Then
            Call gM46V999.gpGraLog(1, lMensagem)
            Exit Function
        End If
        objstcPedido.Dat_Liber = mComUltData
        objstcPedido.Cod_User_Liber = mComUltUsuario
        If Not objPedido.mfAlterar(objstcPedido, "", "", mComUltData, mComUltUsuario) Then
            lMensagem = objPedido.UltimoErro
            Call gM46V999.gpGraLog(1, lMensagem)
            Exit Function
        End If
    End If
    lCkPoint = "17"

    If Not mfSalvarTextoEspecPadrao(lMensagem, True) Then GoTo ControleErro
    If Not gM46V999.mfSalvarNovosTextoCoberturas(objstcPedido, lMensagem, "") Then GoTo ControleErro

    'Salva os dados LMI
    If objstcPedido.LMI_Unico = 1 Then
        Set lobjPedLMI = New clsA46V732A
        Set lobjPedLMI.M46V999 = gM46V999
        If Not lobjPedLMI.mfGerarDadosLMI(objstcPedido, "", "") Then
            lMensagem = lobjPedLMI.UltimoErro
            GoTo ControleErro
        End If
    End If

    'Vai gerar o arquivo com o c�lculo
    'mnuArqTransmitir_Click 'n�o gerar
    panAguarde.Visible = False

    '14. Exibe form de fracionamento ou de totaliza��o (nesta ordem).
    If gM46V999.gfDisponivel("frmT46V124A") Then
        frmT46V124A.Show vbModeless, Me
    Else
        frmT46V123A.Show vbModeless, Me
    End If
    
    'Ajute retirar premio minimo do imobiliario
    If gTemErro_T46V124A = True Then
        panAguarde.Visible = False
        Call gpLimPremios
    
        If gM46V999.gfDisponivel("frmT46V136A") Then
            frmT46V136A.Show vbModeless, Me
        End If
        Exit Function
    End If
    
    If gM46V999.gTipoAcesso = DIGITACAO Then
        Call mpCarregarTriagem
    Else
        If gM46V999.gTipUsuario = e_Tipo_Usu_Corretor Then
            If (lsNOSSO_NUMERO <> objstcPedido.nosso_numero) _
               Or (lsCod_Unicidade <> objstcPedido.Cod_Unicidade) Then

                lsNOSSO_NUMERO = objstcPedido.nosso_numero        '-- evita ficar gerando varios arquivos com mesmo conteudo
                lsCod_Unicidade = objstcPedido.Cod_Unicidade

                If objstcPedido.Cod_Tip_Doc = e_TipDoc_Cotacao Then
                    'Coleta o Log da cota��o
                    If mfGeraLogCalculo(lMensagem) = False Then
                        Call gM46V999.gpGraLog(0, lMensagem)
                    End If
                ElseIf objstcPedido.Cod_Tip_Doc = e_TipDoc_Proposta And gM46V999.gNovaTransmissaoMulti = False Then
                    'Projeto 9075 - gera arquivo de transmissao (oculto extens�o .091)
                    If mfTransmitir(True, lMensagem) = False Then
                        Call gM46V999.gpGraLog(0, lMensagem)
                    End If
                End If
            End If
        End If
    End If

    ' Progresso - Atualizando a tabela com o numero do PI
    If objstcPedido.Num_PI_Auto_Progresso <> 0 Then
        If Not gM46V999.mfSalvarPIAutoProgresso(objstcPedido, lMensagem, "") Then GoTo ControleErro
    End If

    mfCalPremios = True
    If objstcPedido.mStatusDivSiscota = 0 Or gM46V999.gTipoAcesso = DIGITACAO Then
        mnuSituacao.Caption = Chr(183) & Space(10) & "PI: " & objstcPedido.objstcCtrlEmis.NUM_PI & " -  Consistido"
    End If
    
    'Residencial Supremo
    If objstcPedido.Cod_Estip = 30 And objstcPedido.Cod_Ramo = 113 Then
        txtVlrAss24h.Text = Format(objstcPedLoc.Val_Ass24h, "standard")
        txtVlrInspecao.Text = Format(objstcPedLoc.ValCustoInspecao, "standard")
    End If
    
Fim:
    Screen.MousePointer = vbDefault
    Me.MousePointer = vbDefault
    Exit Function
    Resume 0

ControleErro:
    If Err <> 0 Then
        lMensagem = Err & " " & Err.Description & Chr(13) & "CheckPoint " & lCkPoint
    End If
    
    lMensagem = "mfCalPremios ERRO - " & lMensagem
    Call gM46V999.gpGraLog(1, lMensagem, vbCritical)
    mfCalPremios = False
    GoTo Fim
End Function


Private Sub mpPosResParcelamento(ByVal pQuaParcelas As String, ByVal pParcela1 As String, _
                                 ByVal pParcelaN As String, ByVal pJuros As String)
'Procedure: posiciona resultado do parcelamento.
    Dim Aux As String

    With frmT46V123A.lstResultado
        .Clear
        If Not gM46V999.gfPreenchido(frmT46V102A.txtQuaParcelas.Text) Then
            If .ListCount = 0 Then
                .AddItem "Parcelamento n�o calculado:"
            End If
            .AddItem "- quantidade de parcelas n�o informada."
        Else
            If Not IsNumeric(frmT46V102A.txtQuaParcelas.Text) Then
                If .ListCount = 0 Then
                    .AddItem "Parcelamento n�o calculado:"
                End If
                .AddItem "- quantidade de parcelas n�o num�rica."
            End If
        End If
        If .ListCount <> 0 Then
            Exit Sub
        End If
        'Ficha 900046
        '        If frmT46V102A.optPagAntecipado(1) = True Or frmT46V102A.optPagAntecipado(2) = True Then
        If frmT46V102A.optPagAntecipado(1) = True Then
            Aux = "Pagamento antecipado "
            If gM46V999.CDblx(frmT46V102A.txtValorPgAnt) <> 0 Then
                Aux = Aux & ":" & gM46V999.CDblx(frmT46V102A.txtValorPgAnt)
            End If
        Else
            Aux = "Pagamento postecipado"
        End If
        If gM46V999.CDblx(frmT46V102A.txtValorPgAnt) <> 0 Then
            If gM46V999.CDblx(frmT46V102A.txtValorPgAnt) <> gM46V999.CDblx(pParcela1) Then
                Aux = Aux & " - Diferen�a entre a "
                .AddItem Aux
                Aux = "1� Parcela ser� rateada nas demais parcelas."
            End If
        End If
        .AddItem Aux
        .AddItem ""
        .AddItem "Quantidade de parcelas: " & pQuaParcelas
        If pQuaParcelas = 1 Then
            .AddItem "Valor da parcela: " & Format$(pParcela1, "standard")
        Else
            .AddItem "Primeira parcela: " & Format$(pParcela1, "standard")
            .AddItem "Demais parcelas: " & Format$(pParcelaN, "standard")
        End If
        .AddItem "Juros: " & Format$(pJuros, "standard") & "%"
        If pParcela1 = 0 Then
            .AddItem "Sem movimento de pr�mio."
        End If
    End With
End Sub

