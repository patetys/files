    If objstcPedido.Cod_Produto >= 1044 Then
        'Ajuste Pontual Fator de Prote��o  Simony
        Dim FatoresObrigatorios As String
        Dim RetFatores() As String    'Recebe itens da variavel lInfoConexao
        Dim lObjPedFator As clsA46V720A
        Dim lobjstcPedFator As stcA46V720B
        Dim lInd As Integer

        Unload frmT46V137A
        optProtecao(1).Value = True
        Set objstcPedLoc.ColecaoPedFator = New Collection
        mPrograma = True
        optProtecao(0).Value = False
        mPrograma = False


        FatoresObrigatorios = objstcPedLoc.gTemProtecaoObrigatoria
        If FatoresObrigatorios <> "" Then
            mPrograma = True
            optProtecao(0).Value = True
            mPrograma = False
            If FatoresObrigatorios <> "False" Then
                RetFatores = Split(FatoresObrigatorios, ";")
                For lInd = 0 To UBound(RetFatores())
                    If RetFatores(lInd) <> "" Then
                        Set lobjstcPedFator = New stcA46V720B
                        Set lObjPedFator = New clsA46V720A
                        Set lObjPedFator.M46V999 = gM46V999
                        With lobjstcPedFator
                            .nosso_numero = objstcPedLoc.nosso_numero
                            .nosso_numero = objstcPedLoc.NUM_PI
                            .Num_Ped = objstcPedLoc.Num_Ped
                            .Cod_Ramo = objstcPedLoc.Cod_Ramo
                            .Num_Item = objstcPedLoc.Num_Item
                            .Cod_Org = objstcPedLoc.Cod_Org
                            .Cod_Fator = Mid(RetFatores(lInd), 1, InStr(RetFatores(lInd), "@") - 1)
                            .Desc_Fator = Mid(RetFatores(lInd), InStr(RetFatores(lInd), "@") + 1)
                            Set .ObjPai = objstcPedLoc
                        End With
                        ''If lObjPedFator.mfIncluir(lobjstcPedFator, "", "") = True Then
                        On Error Resume Next
                        objstcPedLoc.ColecaoPedFator.Add lobjstcPedFator, lobjstcPedFator.Class_ID
                    End If
                Next
            End If
        End If
        Load frmT46V137A
        Call frmT46V137A.mpSelecionarFatores(objstcPedLoc.ColecaoPedFator)
    End If

    Call mpCarregaAss24h
End Sub

