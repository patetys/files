            frmT46V123A.flxResValores.TextMatrix(2, 1) = objstcPedido.Val_IOF
            frmT46V123A.flxResValores.TextMatrix(3, 1) = Round(objstcPedido.VAL_PR + objstcPedido.Val_IOF, 2)
        
        'End If
    End If

    If objstcPedido.mTransmissao = True Then
        If Abs((Round(objstcPedido.VAL_PR, 2) - objstcPedido.mValPrTransmitido)) > 0.1 Then
            If objstcPedido.Cod_Estip = 20 And Abs((Round(objstcPedido.VAL_PR, 2) - objstcPedido.mValPrTransmitido)) <= 100 Then
                ' Pode ser que seja uma proposta do Imobili�rio transmitida com premio m�nimo.
                ' Se for, apenas corrigir o VAL_PR e continuar
                objstcPedido.VAL_PR = objstcPedido.mValPrTransmitido
                objstcPedido.Val_IOF = (objstcPedido.VAL_PR / 100#) * 7.38
                
                Call mpCarregarCobertGrid(objstcPedLoc.ColecaoPedCobert)
                'Atualiza Fracionamento
                frmT46V123A.flxResValores.TextMatrix(0, 1) = Round(objstcPedido.VAL_PR, 2)
                frmT46V123A.flxResValores.TextMatrix(2, 1) = objstcPedido.Val_IOF
                frmT46V123A.flxResValores.TextMatrix(3, 1) = Round(objstcPedido.VAL_PR + objstcPedido.Val_IOF, 2)
                
                If frmT46V124A.flxVistaCarne.Rows > 1 Then
                    frmT46V124A.flxVistaCarne.TextMatrix(1, 1) = Round(objstcPedido.VAL_PR + objstcPedido.Val_IOF, 2)
                End If
                If frmT46V124A.flxVistaDebConta.Rows > 1 Then
                    frmT46V124A.flxVistaDebConta.TextMatrix(1, 1) = Round(objstcPedido.VAL_PR + objstcPedido.Val_IOF, 2)
                End If
                If frmT46V124A.flx30diasCarne.Rows > 1 Then
                    frmT46V124A.flx30diasCarne.TextMatrix(1, 1) = Round(objstcPedido.VAL_PR + objstcPedido.Val_IOF, 2)
                End If
                If frmT46V124A.flx30diasDebConta.Rows > 1 Then
                    frmT46V124A.flx30diasDebConta.TextMatrix(1, 1) = Round(objstcPedido.VAL_PR + objstcPedido.Val_IOF, 2)
                End If
                If frmT46V101A.objstcPedido.Cod_Bco_Cobr = 999 And _
                   frmT46V101A.objstcPedido.Cod_Agen_Bas_Cor = 9999 And _
                   frmT46V101A.objstcPedido.Num_Cta_Bas_Cor = 9999999 Then
                    If frmT46V124A.flxCartao.Rows > 1 Then
                        frmT46V124A.flxCartao.TextMatrix(1, 1) = Round(objstcPedido.VAL_PR + objstcPedido.Val_IOF, 2)
                    End If
                End If
            Else
                Call gM46V999.gpGraLog(1, "Premio calculado divergente do premio transmitido." & vbCrLf & "Calculado: " & Format(objstcPedido.VAL_PR, "standard") & " Trasmitido: " & Format(objstcPedido.mValPrTransmitido, "standard"))
                Call gpLimPremios
                panAguarde.Visible = False
                Exit Function
            End If
        End If
        
        If Abs((Round(objstcPedido.Val_Pr_Antec, 2) - objstcPedido.mValPrAntecTransmitido)) And objstcPedido.mValPrAntecTransmitido <> 0 Then
            Call gM46V999.gpGraLog(1, "Premio antecipado divergente do premio antecipado transmitido." & vbCrLf & "Calculado: " & Format(objstcPedido.Val_Pr_Antec, "standard") & " Trasmitido: " & Format(objstcPedido.mValPrAntecTransmitido, "standard"))
            'panAguarde.Visible = False
            'Exit Function
        End If
    End If

    ' Preencher as informa��es de parcelamento
