Private Sub txtComissao_LostFocus()
    Dim lAux As String
    Me.Refresh
    With txtComissao
        '1. Verifica se alterou campo.
        If gM46V999.gfPreenchido(mAntComissao) Then
            If gM46V999.gfPreenchido(txtComissao.Text) Then
                If mAntComissao = txtComissao.Text Then
                    Exit Sub
                End If
            Else
                txtComissao.Text = "0,00"
                Exit Sub
            End If
        Else
            If Not gM46V999.gfPreenchido(txtComissao.Text) Then
                txtComissao.Text = "0,00"
                Exit Sub
            End If
        End If

        '2. Procedimento padr�o para edi��o da comiss�o.
        If gM46V999.gfPreenchido(.Text) Then
            If IsNumeric(.Text) Then
                .Text = Format$(gM46V999.CDblx(.Text), "standard")
            Else
                .Text = Format$(0, "standard")
            End If
        End If
        If CDbl(.Text) >= 100 Then
            .Text = 99.99
        End If

        '3. Posiciona quadro de corretores.
        With frmT46V102A
            If val(.txtCorretor(1).Tag) = 691801 And val(.txtCorretor(2).Tag) = 689001 And val(txtComissao.Text) > 5 Then   'AC&F e Uni�o Power (U P)
                lAux = txtComissao.Text - 5
                .txtCorComissao(1).Text = Format(lAux, "standard")

                .txtCorretor(2).Text = "U P"
                .txtCorretor(2).Tag = 689001        'Uni�o Power
                lAux = 5
                .txtCorComissao(2).Text = Format(lAux, "standard")

                .txtCorretor(3) = ""
                .txtCorComissao(3).Text = ""
            Else
                .txtCorComissao(1).Text = txtComissao.Text
                '.txtCorretor(2) = ""
                .txtCorComissao(2).Text = "0,00"
                '.txtCorretor(3) = ""
                .txtCorComissao(3).Text = "0,00"
            End If
            
            '11.72 - Cocorretagem
            Dim lCorretor As String    'Corretor.
            Dim lMensagem As String    'Mensagem.
            Dim lSaida() As Variant    'Resultado da busca de corretores.
            Dim lQuaCorretores
            Dim lI
            
            If gM46V999.gfObtCorretor(3, "0", lSaida, lMensagem) = False Then
                Call gM46V999.gpGraLog(1, lMensagem)
                Exit Sub
            End If
            
            lQuaCorretores = UBound(lSaida)
                
            If lQuaCorretores > 1 Then
                
                For lI = 1 To lQuaCorretores
                
                    .txtCorretor(lI).Text = lSaida(lI, 3)
                    .txtCorretor(lI).Tag = lSaida(lI, 1)
                    .txtCorComissao(lI).Text = Format(lSaida(lI, 8), "standard")
                                    
                Next lI
            
            End If
            
        End With
    End With
End Sub

