Private Sub mpImpressaoBoleto(pOpcao As Byte, pDataDigit As Long)
    Dim lobjstcBoleto As stcA99V009B
    Dim lobjstcDados As stcA28V720B
    Dim lobjDados As clsA28V720A
    Dim lMensagem As String
    Dim lBDConexao As ADODB.Connection
    Dim lretorno As Integer
    If (gM46V999.gTipUsuario = e_Tipo_Usu_Corretor Or gM46V999.gTipUsuario = e_Tipo_Usu_CorretorYasuda) And _
       Left(objstcPedido.objstcCtrlEmis.Num_Bloq, 1) = 5 Then
        If Not mfVerificarBoletoLote(lretorno) Then
            If lretorno = 3 Then
                Call gM46V999.gpGraLog(1, "FGE0103 - N�mero do boleto inv�lido. Pertence a outra proposta.")
            ElseIf lretorno = 2 Then
                Call gM46V999.gpGraLog(1, "FGE0103 - N�mero do boleto inv�lido. N�o localizado no lote de boleto.")
            End If
            'N�o gera o boleto
        ElseIf lretorno = 4 Then
            If objstcPedido.Val_PriParcela <> 0 Then
                Set lobjstcBoleto = New stcA99V009B
                Set lobjstcBoleto.M46V999 = gM46V999

                With lobjstcBoleto
                    .Corretor = frmT46V102A.txtCorretor(1).Text
                    .LocalImagensBarra = App.Path
                    .numeroBanco = objstcPedido.Cod_Bco_Cobr
                    Select Case .numeroBanco
                    Case 237, 341, 356, 399
                        'OK
                    Case Else
                        .numeroBanco = 341
                    End Select
                    Select Case .numeroBanco
                    Case 237
                        .LocalImagensBanco = gM46V999.gAppPath & "STBS57_237.BMP"
                    Case 341
                        .LocalImagensBanco = gM46V999.gAppPath & "STBS55_341.BMP"
                    Case 409
                        .LocalImagensBanco = gM46V999.gAppPath & "STBS75_409.BMP"
                    Case 347
                        .LocalImagensBanco = gM46V999.gAppPath & "STBS59_347.BMP"
                    Case 356
                        .LocalImagensBanco = gM46V999.gAppPath & "STBS75_356.BMP"
                    Case 399
                        .LocalImagensBanco = gM46V999.gAppPath & "STBS75_399.BMP"
                    End Select
                    .NomeSacado = objstcPedido.Nom_Segurado
                    .CPF_CNPJ_Sacado = objstcPedido.gCNPJ_CPF_Formatado
                    .NossoNumero = Left(objstcPedido.objstcCtrlEmis.Num_Bloq, 7)
                    .DigYasNossoNumero = objstcPedido.objstcCtrlEmis.DIG_BLOQUETO

                    .NumeroDoc = objstcPedido.objstcCtrlEmis.Num_Bloq & "-" & objstcPedido.objstcCtrlEmis.DIG_BLOQUETO
                    .ramo = objstcPedido.gDesc_Ramo
                    .valorDocumento = Round(objstcPedido.Val_PriParcela, 2)
                    If objstcPedido.Dat_Ini_Vig < gM46V999.gHoje Then
                        .vencimento = Format(Date + 7, "yyyymmdd")
                    Else
                        .vencimento = Format(CDate(gM46V999.gfForData(2, objstcPedido.Dat_Ini_Vig)) + 7, "yyyymmdd")
                    End If
                    .Vigencia = gM46V999.gfForData(2, objstcPedido.Dat_Ini_Vig) & " a " & gM46V999.gfForData(2, objstcPedido.Dat_Ter_Vig)
                    .MensagemPgto = objstcPedido.Cod_Unid_Prod & " " & objstcPedido.objstcCtrlEmis.Cod_Corr & " PARC 01/01"

                    .CarregarDados = True

                    If Not gM46V999.gfAbrBasDados("P0045300", gM46V999.gTipP0045300, gM46V999.gEndP0045300, lBDConexao, lMensagem) Then
                        Call gM46V999.gpGraLog(1, lMensagem)
                        Exit Sub
                    End If
                    Set .ConexaoBD = lBDConexao
                    .NomeTabela = "P0045300"
                End With

                Call frmT99V009A.gpInstanciarForm(lobjstcBoleto, True)

                Set lobjstcDados = New stcA28V720B
                Set lobjstcDados.M46V999 = gM46V999

                With lobjstcDados
                    .COD_BANCO = lobjstcBoleto.numeroBanco
                    .NUM_BOLETO = lobjstcBoleto.NossoNumero
                    .nosso_numero = objstcPedido.nosso_numero
                    .COD_UNID = objstcPedido.Cod_Unid_Prod
                    .Cod_Ramo = objstcPedido.Cod_Ramo
                    .Nom_Segurado = Left(objstcPedido.Nom_Segurado, 50)
                    .CPF_CNPJ_Segurado = Left(objstcPedido.gCNPJ_CPF_Formatado, 50)
                    .VAL_PR = CSng(lobjstcBoleto.valorDocumento)
                    .DAT_VENC = lobjstcBoleto.vencimento
                    .Cod_Corr = objstcPedido.objstcCtrlEmis.Cod_Corr
                    .NUM_LINHA_DIGIT = Left(lobjstcBoleto.linhaDigitavel, 60)
                    .Cod_User = gM46V999.gNomUsuario6
                    If pDataDigit = 0 Then
                        .DAT_DIGIT = gM46V999.gHoje
                    Else
                        .DAT_DIGIT = pDataDigit
                    End If
                    .HOR_DIGIT = Format(Time, "hhmmss")
                    .STATUS = 2
                End With
                Set lobjDados = New clsA28V720A
                Set lobjDados.M46V999 = gM46V999

                If Not lobjDados.gfAlterar(lobjstcDados, "") Then
                    Call gM46V999.gpGraLog(1, lobjDados.UltimoErro)
                    Exit Sub
                End If
            End If
        End If
    End If
End Sub
Private Function mfVerificarBoletoLote(ByRef pRetorno As Integer) As Boolean
    Dim lBDP00452 As ADODB.Connection
    Dim lrst As clsYasRecordSet
    Dim lMensagem As String
    Dim lSelect As String

    pRetorno = 0
    If Not gM46V999.gfAbrBasDados("P0045200", gM46V999.gTipP0045200, gM46V999.gEndP0045200, lBDP00452, lMensagem) Then
        pRetorno = 1
        Call gM46V999.gpGraLog(1, lMensagem)
        Exit Function
    End If

    lSelect = " Select * from p0045200 where num_boleto = " & objstcPedido.objstcCtrlEmis.Num_Bloq
    If Not gM46V999.gfObtRegistro(lBDP00452, lSelect, lrst, lMensagem) Then
        pRetorno = 1
        Call gM46V999.gpGraLog(1, lMensagem)
        Exit Function
    End If

    If lrst.EOF Then
        pRetorno = 2
        mfVerificarBoletoLote = False
        Exit Function
    End If
    If lrst("Nosso_Numero") <> objstcPedido.nosso_numero Then
        If lrst("Nosso_Numero") = objstcPedido.Nosso_Numero_Original Then
            pRetorno = 5
            mfVerificarBoletoLote = False
            Exit Function
        End If
        pRetorno = 3
        lMensagem = "O boleto informado pertence a outro "
    Else
        pRetorno = 4
        mfVerificarBoletoLote = True
    End If
End Function

Public Sub mpImprimirRelatorioPDF2(ByVal pOpcao As Byte)
'Procedure: imprime ou visualiza.

'Par�metro de entrada...pOpcao......0 = visualizar impress�o.
