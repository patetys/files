                    Else
                        If val(lParcelasGrid) <= gM46V999.gProQuaMaxParcelas Then
                            If flxVista.Rows = 1 Then
                                gCarga = True
                                frmT46V102A.txtQuaParcelas.Text = 0
                                gCarga = False
                                lParcela1 = 0
                                lParcelaN = 0
                                lJuros = 0
