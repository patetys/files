    If Not mfSalvarTelefones(pMensagem) Then GoTo Finalizar

    If Not mfSalvarObrasArte(pMensagem) Then GoTo Finalizar
    lCkPoint = "28"
    If Not mfSalvarAllRisks(pMensagem) Then GoTo Finalizar
    lCkPoint = "29"

    lblAntNumItem.Caption = txtNumItem.Text
    mfSalvarItem = True
Finalizar:
    Set lobjPedLoc = Nothing
    Exit Function
ControleErro:
    'Obtem o inicio da mensagem de erro
    Call gM46V999.gpGraLog(0, "mfSalvarItem ERRO - " & Err & " " & ERROR & _
                              "CheckPoint " & lCkPoint & " - " & pMensagem)

    If gM46V999.gfPreenchido(pMensagem) = False Then
        pMensagem = Err.Description
    End If
    mfSalvarItem = False
End Function

