                lTexto = UCase("Item " & Format(pobjstcPedLoc.Num_Item, "00000") & ": Inspecao obrigatoria")
            Case e_StatusInspecao_programada
                lTexto = UCase("Item " & Format(pobjstcPedLoc.Num_Item, "00000") & ": Inspecao programada n� " & Format(pNum_Insp, "000000"))
        End Select
    Else
        Select Case pNovo_Ind_StatusInspecao
            Case e_StatusInspecao_Dispensada
                lTexto = UCase("Inspecao dispensada")
            Case e_StatusInspecao_obrigatoria
                lTexto = UCase("Inspecao obrigatoria")
            Case e_StatusInspecao_programada
                lTexto = UCase("Inspecao programada n� ") & Format(pNum_Insp, "000000")
        End Select
    End If
    
    pTexto = pTexto & IIf(Len(pTexto) > 0, vbCrLf, "") & lTexto
    Nova_Observacao = pTexto
    Exit Function
    
Erro:
    Nova_Observacao = pobjstcPedLoc.objstcPedObs.Observacao
End Function

Private Function Get_Ind_StatusInspecao() As e_StatusInspecao
    Dim lretorno As e_StatusInspecao
    
    If optCondicaoInspecao(0).Value Then
        lretorno = e_StatusInspecao_ConfNormas
    Else
        If optCondicaoInspecao(1).Value Then
            lretorno = e_StatusInspecao_Dispensada
        Else
            If optCondicaoInspecao(2).Value Then
                lretorno = e_StatusInspecao_obrigatoria
            Else
                lretorno = e_StatusInspecao_programada
            End If
        End If
    End If

    Get_Ind_StatusInspecao = lretorno
End Function

