    If CDbl(txtValoRisco.Text) <> 0 And txtCoefISVR.Visible Then
        txtCoefISVR.Text = CDbl(txtISBas.Text) / CDbl(txtValoRisco.Text)
        If val(txtCoefISVR.Text) >= 10 Then
            Call gM46V999.gpGraLog(1, "FGE0111 - Coeficiente LMI/VR inv�lido.(maior que 9,99)")
            txtValoRisco.Text = ""
            If txtValoRisco.Visible And txtValoRisco.Enabled Then
                txtValoRisco.SetFocus
