Private Function mfSalvarTelefones(pMensagem As String) As Boolean
    Dim lobjPedTelefones As clsA46V736A   'Objeto da classe clsA46V736A (TAB_PED_TELEFONES).
    Dim lobjstcPedTelefones As stcA46V736B      'Objeto da classe de estrutura stcA46V736B (TAB_PED_TELEFONES).
    Dim lI As Integer    'Utilizado no for...loop.
    Dim lCheck As String

    On Error GoTo ControleErro

    lCheck = 1
    Set lobjPedTelefones = New clsA46V736A
    Set lobjPedTelefones.M46V999 = gM46V999

    If objstcPedido.ColecaoTelefones.Count > 0 Then
        Set lobjstcPedTelefones = New stcA46V736B
        Set lobjstcPedTelefones.M46V999 = gM46V999

        lobjstcPedTelefones.nosso_numero = objstcPedido.nosso_numero
        lCheck = 2
        If Not lobjPedTelefones.mfExcluir(lobjstcPedTelefones, "", "", "") Then
            pMensagem = lobjPedTelefones.UltimoErro
            GoTo Finalizar
        End If
    End If
    lCheck = 3
    Set objstcPedido.ColecaoTelefones = New Collection
    lCheck = 4
    For lI = 1 To frmT46V102A.flxTelefones.Rows - 1
        lCheck = 5

Salvar:
        Set lobjstcPedTelefones = New stcA46V736B
        Set lobjstcPedTelefones.M46V999 = gM46V999

        'Verifica se o telefone est� em branco
        If gM46V999.gfPreenchido(frmT46V102A.flxTelefones.TextMatrix(lI, 3)) = True Then

            With lobjstcPedTelefones
                .nosso_numero = objstcPedido.nosso_numero

                Select Case UCase(frmT46V102A.flxTelefones.TextMatrix(lI, 1))
                Case "RESIDENCIAL"
                    .Tip_Telefone = 1
                Case "CELULAR"
                    .Tip_Telefone = 2
                Case "COMERCIAL"
                    .Tip_Telefone = 3
                Case "FAX"
                    .Tip_Telefone = 4
                Case Else
                    .Tip_Telefone = 0
                End Select

                If gM46V999.gfPreenchido(frmT46V102A.flxTelefones.TextMatrix(lI, 2)) = False Then
                    .DDD_Telefone = 0
                Else
                    .DDD_Telefone = frmT46V102A.flxTelefones.TextMatrix(lI, 2)
                End If

                If gM46V999.gfPreenchido(frmT46V102A.flxTelefones.TextMatrix(lI, 3)) = False Then
                    .Numero_Telefone = 0
                Else
                    .Numero_Telefone = Replace(frmT46V102A.flxTelefones.TextMatrix(lI, 3), "-", Empty)
                End If

                If gM46V999.gfPreenchido(frmT46V102A.flxTelefones.TextMatrix(lI, 4)) = False Then
                    .Ramal_Telefone = 0
                Else
                    .Ramal_Telefone = val(frmT46V102A.flxTelefones.TextMatrix(lI, 4))
                End If

                .Obs_Telefone = frmT46V102A.flxTelefones.TextMatrix(lI, 5)
                frmT46V102A.flxTelefones.row = lI
                If frmT46V102A.flxTelefones.CellPicture = frmT46V102A.picChecked Then
                    .Ind_Principal = 1
                Else
                    .Ind_Principal = 2
                End If
                .NUM_PI = objstcPedido.NUM_PI
                .Num_Apol = objstcPedido.Num_Apol
                .Num_Endo = objstcPedido.Num_Endo
                lCheck = 6
                If Not lobjPedTelefones.mfIncluir(lobjstcPedTelefones, "", "", "") Then
                    pMensagem = lobjPedTelefones.UltimoErro
                    GoTo Finalizar
                End If
                lCheck = 7
                objstcPedido.ColecaoTelefones.Add lobjstcPedTelefones
            End With
        End If

Proximo:
    Next lI
    mfSalvarTelefones = True
Finalizar:
    Set lobjPedTelefones = Nothing
    Set lobjstcPedTelefones = Nothing
    Exit Function
    Resume 0
ControleErro:
    Set lobjPedTelefones = Nothing
    Set lobjstcPedTelefones = Nothing
    If gM46V999.gfPreenchido(pMensagem) = False Then
        pMensagem = Err.Description
    End If
    Call gM46V999.gpGraLog(0, "mfSalvarTelefones ERRO - " & Err & " " & ERROR & _
                              Chr(13) & "Check " & lCheck & pMensagem)
End Function

