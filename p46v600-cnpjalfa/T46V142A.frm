Private Sub txtAntJuro_KeyPress(Index As Integer, KeyAscii As Integer)
    If KeyAscii = vbKeyReturn Then
        KeyAscii = 0
        SendKeys "{TAB}"
    End If
End Sub

Private Sub txtAntJuro_KeyUp(Index As Integer, KeyCode As Integer, Shift As Integer)
    Dim lI As Integer    'Utilizado como índice.

    Select Case KeyCode
    Case vbKeyPageUp            'Posiciona na primeira ocorręncia de juro antecipado.
        If txtAntJuro(1).Visible = True And txtAntJuro(1).Enabled = True Then
            txtAntJuro(1).SetFocus
        End If
    Case vbKeyPageDown          'Posiciona na última ocorręncia de juro antecipado (visível).
        For lI = 12 To 1 Step -1    'For lI = 13 To 0 Step -1
            If txtAntJuro(lI).Visible = True And txtAntJuro(lI).Enabled = True Then
                txtAntJuro(lI).SetFocus
                Exit For
            End If
        Next lI
    Case vbKeyUp                'Posiciona na ocorręncia anterior de juro antecipado (visível).
        If Index = 1 Then
            For lI = 12 To 1 Step -1    'For lI = 13 To 0 Step -1
                If txtAntJuro(lI).Visible = True And txtAntJuro(lI).Enabled = True Then
                    txtAntJuro(lI).SetFocus
                    Exit For
                End If
            Next lI
        Else
            If txtAntJuro(Index - 1).Visible = True And txtAntJuro(Index - 1).Enabled = True Then
                txtAntJuro(Index - 1).SetFocus
            End If
        End If
    Case vbKeyDown              'Posiciona na ocorręncia posterior de juro antecipado (visível).
        If Index = 12 Then
            If txtAntJuro(1).Visible = True And txtAntJuro(1).Enabled = True Then
                txtAntJuro(1).SetFocus
            End If
        Else
            If txtAntJuro(Index + 1).Visible = True And txtAntJuro(Index + 1).Enabled = True Then
                txtAntJuro(Index + 1).SetFocus
            Else
                If txtAntJuro(1).Visible = True And txtAntJuro(1).Enabled = True Then
                    txtAntJuro(1).SetFocus
                End If
            End If
        End If
    Case vbKeyRight             'Posiciona na próxima ocorręncia de juro postecipado.
        If txtPosJuro(Index).Visible = True And txtPosJuro(Index).Enabled = True Then
            txtPosJuro(Index).SetFocus
        End If
    Case vbKeyLeft              'Posiciona na ocorręncia anterior de juro postecipado.
        If Index = 1 Then
            For lI = 12 To 1 Step -1    'For lI = 13 To 0 Step -1
                If txtPosJuro(lI).Visible = True And txtPosJuro(lI).Enabled = True Then
                    txtPosJuro(lI).SetFocus
                    Exit For
                End If
            Next lI
        Else
            If txtPosJuro(Index - 1).Visible = True And txtPosJuro(Index - 1).Enabled = True Then
                txtPosJuro(Index - 1).SetFocus
            End If
        End If
    End Select
End Sub

Private Sub txtAntJuro_LostFocus(Index As Integer)
    With txtAntJuro(Index)
        If gM46V999.gfPreenchido(.Text) Then
            
            If gM46V999.CDblx(.Text) < 100 Then
                .Text = Format$(CSng(.Text), "standard")
            Else
                .Text = Format$(99.99, "standard")
            End If
        Else
            .Text = Format$(0, "standard")
        End If
    End With

End Sub

