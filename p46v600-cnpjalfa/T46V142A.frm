Public Function getJuros(ByVal pFormaPagto As e_FormaPagamento, ByVal pPagtoAntecipado As Boolean, ByVal pParcela As Integer) As Double
    Dim lretorno As Double
    lretorno = 0
    
    On Error GoTo Erro
    
    If pParcela = 0 Then
        pParcela = 1
    Else
        If pParcela > 12 Then
            pParcela = 12
        End If
    End If
    
    If pFormaPagto = e_FormaPagamento_Debito Then
        pParcela = pParcela + 12
    End If
    
    If pPagtoAntecipado Then
        lretorno = gM46V999.CDblx(txtAntJuro(pParcela).Text)
    Else
        lretorno = gM46V999.CDblx(txtPosJuro(pParcela).Text)
    End If
    
    getJuros = lretorno
    Exit Function
Erro:
   Call gM46V999.gpGraLog(1, "T46V142A.getJuros() Cod: " & Err.Number & " - MsgErro: " & Err.Description)
End Function
