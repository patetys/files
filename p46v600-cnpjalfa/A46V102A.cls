Private Function mfVerBoston(ByVal pAgencia As Long, ByVal pConta As Double, ByRef pMensagem As String) _
        As Boolean
'Funï¿½ï¿½o: verifica informaï¿½ï¿½es de conta Boston.

'Parï¿½metros de entrada...pAgencia....Cï¿½digo da agï¿½ncia.
'                        pConta......Nï¿½mero da conta.
'Parï¿½metro de saï¿½da......pMensagem...Mensagem.

    Dim lAgencia As String    'Cï¿½digo da agï¿½ncia.
    Dim lConta As String  'Nï¿½mero da conta.
    Dim lDigito As String   'Dï¿½gito.

    mfVerBoston = False

    '1. Verifica agï¿½ncia.
    If pAgencia > 9999 Then
        pMensagem = "FGE0073 - Cï¿½digo de agï¿½ncia invï¿½lido (" & pAgencia & _
                  " - Banco de Boston - mais que 4 posiï¿½ï¿½es)."
        Exit Function
    End If
    lAgencia = Format$(pAgencia, "0000")

    '2. Verifica conta.
    If pConta > 99999999 Then
        pMensagem = "FGE2076 - Nï¿½mero de conta corrente invï¿½lido (" & pConta & _
                  " - Banco de Boston - mais que 8 posiï¿½ï¿½es)."
        Exit Function
    End If
    lConta = Format(pConta, "00000000")

    '3. Calcula e verifica dï¿½gito.
    Set clsA99V001 = New clsA99V001
    Set clsA99V001.M46V999 = M46V999

    If clsA99V001.DIG_BOSTON(Left$(lConta, 7), lDigito, pMensagem) = False Then
        Exit Function
    End If
    Set clsA99V001 = Nothing
    If lDigito <> Mid$(lConta, 8, 1) Then
        pMensagem = "FGE2077 - Dï¿½gito de conta corrente invï¿½lido (Banco de Boston - " & pConta & ")."
        'Ficha 900591
        '1001180 - Validaï¿½ï¿½o de DV na Triagem
        '        If M46V999.gTipoAcesso = DIGITACAO Then
        '            MsgBox pMensagem, vbCritical
        '            M46V999.gPodeEmitir = False
        '            mfVerBoston = True
        Exit Function
        '        Else
        '            Exit Function
        '        End If
    End If

    mfVerBoston = True
End Function
Private Function mfVerBradesco(ByVal pAgencia As Long, ByVal pConta As Double, _
                               ByRef pMensagem As String, Optional blnVerificarAgencia As Boolean = True) As Boolean
'Funï¿½ï¿½o: verifica informaï¿½ï¿½es de conta Bradesco.

'Parï¿½metros de entrada...pAgencia....Cï¿½digo da agï¿½ncia.
'                        pConta......Nï¿½mero da conta.
'Parï¿½metro de saï¿½da......pMensagem...Mensagem.

    Dim lAgencia As String    'Cï¿½digo da agï¿½ncia.
    Dim lConta As String  'Nï¿½mero da conta.
    Dim lDigito As String   'Dï¿½gito.

    mfVerBradesco = False
    
    If blnVerificarAgencia Then
        '1. Verifica agï¿½ncia.
        If pAgencia > 99999 Then
            pMensagem = "FGE0073 - Cï¿½digo de agï¿½ncia invï¿½lido (" & pAgencia & _
                      " - Banco Bradescon - mais que 5 posiï¿½ï¿½es)."
            Exit Function
        End If
        lAgencia = Format$(pAgencia, "00000")
        Set clsA99V001 = New clsA99V001
        Set clsA99V001.M46V999 = M46V999
    
        If clsA99V001.DIG_BRADESCO(Left$(lAgencia, 4), lDigito, pMensagem) = False Then
            Exit Function
        End If
        Set clsA99V001 = Nothing
        If lDigito <> Mid$(lAgencia, 5, 1) Then
            pMensagem = "FGE0073 - Cï¿½digo de agï¿½ncia invï¿½lido (" & pAgencia & _
                      " - Banco Bradesco - dï¿½gito invï¿½lido)."
            Exit Function
        End If
    End If

    '2. Verifica conta.
    If pConta > 99999999 Then
        pMensagem = "FGE2076 - Nï¿½mero de conta corrente invï¿½lido (" & pConta & _
                  " - Banco Bradesco - mais que 8 posiï¿½ï¿½es)."
        Exit Function
    End If
    lConta = Format(pConta, "00000000")
    Set clsA99V001 = New clsA99V001
    Set clsA99V001.M46V999 = M46V999

    If clsA99V001.DIG_BRADESCO(Left$(lConta, 7), lDigito, pMensagem) = False Then
        Exit Function
    End If
    Set clsA99V001 = Nothing
    If lDigito <> Mid$(lConta, 8, 1) Then
        pMensagem = "FGE2077 - Dï¿½gito de conta corrente invï¿½lido (Banco Bradesco - " & pConta & ")."
        'Ficha 900591
        '1001180 - Validaï¿½ï¿½o de DV na Triagem
        '        If M46V999.gTipoAcesso = DIGITACAO Then
        '            MsgBox pMensagem, vbCritical
        '            M46V999.gPodeEmitir = False
        '            mfVerBradesco = True
        Exit Function
        '        Else
        '            Exit Function
        '        End If
    End If

    mfVerBradesco = True
End Function
Public Function mfVerConta(ByVal pOpcao As Byte, ByVal pBanco As Integer, ByVal pAgencia As Long, _
                           ByVal pConta As Double, ByRef pMensagem As String) As Boolean
'Funï¿½ï¿½o: verifica informaï¿½ï¿½es de conta corrente.

'Parï¿½metros de entrada...pOpcao......1 = Conta para dï¿½bito.
'                                    2 = Indicador de seguro.
'                                    3 = Conta de restituiï¿½ï¿½o
'                        pBanco......Cï¿½digo do banco.
'                        pAgencia....Cï¿½digo da agï¿½ncia.
'                        pConta......Cï¿½digo da conta.
'Parï¿½metro de saï¿½da......pMensagem...Mensagem.

    mfVerConta = False

    '1. Verifica opï¿½ï¿½o.
    If Not M46V999.gfPreenchido(pOpcao) Then
        pMensagem = "FTE0006 - Opï¿½ï¿½o invï¿½lida (verifica conta corrente - opï¿½ï¿½o nï¿½o preenchida)."
        Exit Function
    End If
    If Not IsNumeric(pOpcao) Then
        pMensagem = "FTE0006 - Opï¿½ï¿½o invï¿½lida (verifica conta corrente - opï¿½ï¿½o nï¿½o numï¿½rica)."
        Exit Function
    End If
    If pOpcao <> 1 And pOpcao <> 2 And pOpcao <> 3 Then
        pMensagem = "FTE0006 - Opï¿½ï¿½o invï¿½lida (verifica conta corrente - opï¿½ï¿½o diferente de 1, 2 e 3: " & _
                    pOpcao & ")."
        Exit Function
    End If

    '2. Verifica banco.
    If pBanco = 0 Then
        Select Case pOpcao
        Case 1  'Conta para dï¿½bito.
            pMensagem = "FGE0095 - Cï¿½digo do banco invï¿½lido (conta para dï¿½bito - banco nï¿½o " & _
                        "preenchido)."
        Case 2  'Indicador do seguro.
            pMensagem = "FGE0095 - Cï¿½digo do banco invï¿½lido (conta do indicador de seguro - " & _
                        "banco nï¿½o preenchido )."
        Case 3  'conta de restituiï¿½ï¿½o.
            pMensagem = "FGE0095 - Cï¿½digo do banco invï¿½lido (conta de restituiï¿½ï¿½o - " & _
                        "banco nï¿½o preenchido )."
        End Select
        Exit Function
    End If
    
    Dim codigo As Integer, Nome As String, nomeAbreviado As String, isCarne As Boolean, isDebito As Boolean, isRestituicao As Boolean
    pMensagem = Empty
    
    If (M46V999.GetBancoByID(pBanco, codigo, Nome, nomeAbreviado, isCarne, isDebito, isRestituicao, pMensagem) = False Or codigo = 0) Then
        pMensagem = "FGE0095 - Cï¿½digo do banco invï¿½lido. " & pMensagem
        Exit Function
    End If
    
    If pOpcao = 1 Then  'Conta para dï¿½bito.
        ''20170116: original
        'Select Case pBanco
        '    'Projeto 11080 - Debito automatico - Banco do Brasil
        'Case 1, 237, 341, 409, 479, 356, 399, 33, 47, 422, 756    '09029
        '    'Nada a fazer.
        'Case Else
        '    pMensagem = "FGE0095 - Cï¿½digo do banco invï¿½lido (conta para dï¿½bito - " & pBanco & ")."
        '    Exit Function
        'End Select
        ''20170116: fim
        If codigo = 0 Or isDebito = False Then
            pMensagem = "FGE0095 - Cï¿½digo do banco invï¿½lido para conta dï¿½bito (" & pBanco & ")."
            Exit Function
        End If
    End If

    If pOpcao = 3 Then  'Conta para restituiï¿½ï¿½o.
        ''20170116: original jï¿½ comentado
        '        Select Case pBanco
        '        Case 1, 104, 748, 399, 756, 3, 394, 320, 47, 289, 634, 21, 604, 477, 376, 263, 745, 641, 29, 422, 479, 456, 464, 341, 237, 653, 370, 611, 707, 487, 610, 33, 41
        '            'Nada a fazer.
        '        Case Else
        '            pMensagem = "FGE0095 - Cï¿½digo do banco invï¿½lido (conta de restituiï¿½ï¿½o - " & pBanco & ")."
        '            Exit Function
        '        End Select
        ''20170116: fim
        If codigo = 0 Or isRestituicao = False Then
            pMensagem = "FGE0095 - Cï¿½digo do banco invï¿½lido para conta restituiï¿½ï¿½o (" & pBanco & ")."
            Exit Function
        End If
    End If


    '3. Verifica agï¿½ncia.
    If IsNull(pAgencia) Then
        Select Case pOpcao
        Case 1      'Conta para dï¿½bito.
            pMensagem = "FGE0073 - Cï¿½digo de agï¿½ncia invï¿½lido (conta para dï¿½bito - nï¿½o preenchido)."
        Case 2      'Indicador de seguro.
            pMensagem = "FNP0073 - Cï¿½digo de agï¿½ncia invï¿½lido (conta do indicador do seguro - nï¿½o preenchido)."
        Case 3      'conta de restituiï¿½ï¿½o.
            pMensagem = "FNP0073 - Cï¿½digo de agï¿½ncia invï¿½lido (conta de restituiï¿½ï¿½o - nï¿½o preenchido)."
        End Select
        Exit Function
    End If
    
    If pAgencia = 0 Then
        Select Case pOpcao
        Case 1      'Conta para dï¿½bito.
            pMensagem = "FGE0073 - Cï¿½digo de agï¿½ncia invï¿½lido (conta para dï¿½bito - nï¿½o preenchido)."
        Case 2      'Indicador de seguro.
            pMensagem = "FGE0073 - Cï¿½digo de agï¿½ncia invï¿½lido (conta do indicador do seguro - nï¿½o preenchido)."
        Case 3      'conta de restituiï¿½ï¿½o.
            pMensagem = "FGE0073 - Cï¿½digo de agï¿½ncia invï¿½lido (conta de restituiï¿½ï¿½o - nï¿½o preenchido)."
        End Select
        Exit Function
    End If

    '3. Verifica conta.
    If IsNull(pConta) Then
        Select Case pOpcao
        Case 1      'Conta para dï¿½bito.
            pMensagem = "FNP2002 - Nï¿½mero da conta corrente nï¿½o preenchido (conta para dï¿½bito)."
        Case 2      'Indicador de seguro.
            pMensagem = "FNP2002 - Nï¿½mero da conta corrente nï¿½o preenchido (conta do indicador do seguro)."
        Case 3      'conta de restituiï¿½ï¿½o.
            pMensagem = "FNP2002 - Nï¿½mero da conta corrente nï¿½o preenchido (conta de restituiï¿½ï¿½o)."
        End Select
        Exit Function
    End If
    If pConta = 0 Then
        Select Case pOpcao
        Case 1      'Conta para dï¿½bito.
            pMensagem = "FNP2002 - Nï¿½mero da conta corrente nï¿½o preenchido (conta para dï¿½bito)."
        Case 2      'Indicador de seguro.
            pMensagem = "FNP2002 - Nï¿½mero da conta corrente nï¿½o preenchido (conta do indicador do seguro)."
        Case 3      'conta de restituiï¿½ï¿½o.
            pMensagem = "FNP2002 - Nï¿½mero da conta corrente nï¿½o preenchido (conta de restituiï¿½ï¿½o)."
        End Select
        Exit Function
    End If

    '4. Verificaï¿½ï¿½es especï¿½ficas por banco.
    Select Case pBanco
    Case 1  'Projeto 11080 - Debito automatico - Banco do Brasil
        If mfVerBancoBrasil(pAgencia, pConta, pMensagem, pOpcao <> 3) = False Then
            Exit Function
        End If
    Case 237    'Bradesco.
        If mfVerBradesco(pAgencia, pConta, pMensagem, pOpcao <> 3) = False Then
            Exit Function
        End If
    Case 341    'Itaï¿½.
        If mfVerItau(pAgencia, pConta, pMensagem) = False Then
            Exit Function
        End If
    Case 347    'Sudameris.
        If mfVerSudameris(pAgencia, pConta, pMensagem) = False Then
            Exit Function
        End If
    Case 409    'Unibanco.
        If mfVerUnibanco(pAgencia, pConta, pMensagem) = False Then
            Exit Function
        End If
    Case 479    'Boston.
        If mfVerBoston(pAgencia, pConta, pMensagem) = False Then
            Exit Function
        End If
    Case 356    'Real
        If mfVerReal(pAgencia, pConta, pMensagem) = False Then
            Exit Function
        End If
    Case 399
        If mfVerHSBC(pAgencia, pConta, pMensagem) = False Then
            Exit Function
        End If
    Case 33
        If mfVerSantander(pAgencia, pConta, pMensagem) = False Then
            Exit Function
        End If
    Case 47
        If mfVerBanese(pAgencia, pConta, pMensagem) = False Then
            Exit Function
        End If
    'Nova Tarifaï¿½ï¿½o
    Case 422    'Safra
        If mfVerSAFRA(pAgencia, pConta, pMensagem) = False Then
            Exit Function
        End If
    Case 756    'BANCOOB
        If mfVerBANCOOB(pAgencia, pConta, pMensagem) = False Then
            Exit Function
        End If
    'Novo Convï¿½nio banco BRB
    Case 70    'BANCOBRB
        If mfVerBANCOBRB(pAgencia, pConta, pMensagem) = False Then
            Exit Function
        End If
    Case Else
        ''If pOpcao <> 3 Then
        If codigo = 0 Then      ''Codigo=0 : nao achou banco
            Exit Function
        End If
    End Select

    mfVerConta = True
End Function

Private Function mfVerHSBC(ByVal pAgencia As Long, ByVal pConta As Double, ByRef pMensagem As String) _
        As Boolean
'Funï¿½ï¿½o: verifica informaï¿½ï¿½es de conta HSBC

'Parï¿½metros de entrada...pAgencia....Cï¿½digo da agï¿½ncia.
'                        pConta......Nï¿½mero da conta.
'Parï¿½metro de saï¿½da......pMensagem...Mensagem.

    Dim lAgencia As String    'Cï¿½digo da agï¿½ncia.
    Dim lConta As String  'Nï¿½mero da conta.
    Dim lDigito As String   'Dï¿½gito.

    mfVerHSBC = False

    '1. Verifica agï¿½ncia.
    If pAgencia > 9999 Then
        pMensagem = "FGE0073 - Cï¿½digo de agï¿½ncia invï¿½lido (" & pAgencia & _
                  " - Banco HSBC- mais que 4 posiï¿½ï¿½es)."
        Exit Function
    End If

    lAgencia = Format$(pAgencia, "0000")

    '2. Verifica conta.
    If pConta > 99999999999# Then
        pMensagem = "FGE2076 - Nï¿½mero de conta corrente invï¿½lido (" & pConta & _
                  " - Banco HSBC - mais que 11 posiï¿½ï¿½es)."
        Exit Function
    End If

    lConta = Format(pConta, "00000000000")

    '3. Calcula e verifica dï¿½gito.
    Set clsA99V001 = New clsA99V001
    Set clsA99V001.M46V999 = M46V999

    If clsA99V001.DIG_HSBC(lAgencia, Left$(lConta, 10), lDigito, pMensagem) = False Then
        Exit Function
    End If

    Set clsA99V001 = Nothing

    If lDigito <> Mid$(lConta, 11, 1) Then
        pMensagem = "FGE2077 - Dï¿½gito de conta corrente invï¿½lido (Banco HSBC- " & pConta & ")."
        'Ficha 900591
        '1001180 - Validaï¿½ï¿½o de DV na Triagem
        '        If M46V999.gTipoAcesso = DIGITACAO Then
        '            MsgBox pMensagem, vbCritical
        '            M46V999.gPodeEmitir = False
        '            mfVerHSBC = True
        Exit Function
        '        Else
        '            Exit Function
        '        End If
    End If

    mfVerHSBC = True
End Function


