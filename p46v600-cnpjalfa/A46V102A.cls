'Projeto 11080 - Debito automatico - Banco do Brasil
Private Function mfVerBancoBrasil(ByVal pAgencia As Long, ByVal pConta As Double, _
                                  ByRef pMensagem As String, Optional blnVerificarAgencia As Boolean = False) As Boolean
'Funï¿½ï¿½o: verifica informaï¿½ï¿½es de conta Sudameris.

'Parï¿½metros de entrada...pAgencia....Cï¿½digo da agï¿½ncia.
'                        pConta......Nï¿½mero da conta.
'Parï¿½metro de saï¿½da......pMensagem...Mensagem.

    Dim lAgencia As String    'Cï¿½digo da agï¿½ncia.
    Dim lConta As String  'Nï¿½mero da conta.
    Dim lDigito As String   'Dï¿½gito.

    mfVerBancoBrasil = False
    
    If blnVerificarAgencia Then
        '1. Verifica agï¿½ncia.
        If pAgencia > 99999 Then
            pMensagem = "FGE0073 - Cï¿½digo de agï¿½ncia invï¿½lido (" & pAgencia & _
                      " - Banco do Brasil - mais que 5 posiï¿½ï¿½es)."
            Exit Function
        End If
    
        lAgencia = Format$(pAgencia, "000000000")
    
        '3. Calcula e verifica dï¿½gito.
        Set clsA99V001 = New clsA99V001
        Set clsA99V001.M46V999 = M46V999
    
        lDigito = ""
        If clsA99V001.DIG_BANCOBRASIL(lAgencia, lDigito, pMensagem) = False Then
            Exit Function
        End If
        Set clsA99V001 = Nothing
    
        If lDigito = "X" Then lDigito = "0"
        If lDigito <> Mid$(lAgencia, 9, 1) Then
            pMensagem = "FGE2077 - Dï¿½gito da agï¿½ncia invï¿½lido (Banco do Brasil- " & pAgencia & ")."
            'Ficha 900591
'            If M46V999.gTipoAcesso = DIGITACAO Then
'                MsgBox pMensagem, vbCritical
'                M46V999.gPodeEmitir = False
'                mfVerBancoBrasil = True
'                Exit Function
'            Else
                Exit Function
'            End If
        End If
    End If
    
    If pConta > 9999999999# Then
        pMensagem = "FGE2076 - Nï¿½mero de conta corrente invï¿½lido (" & pConta & _
                  " - Banco do Brasil - mais que 10 posiï¿½ï¿½es)."
        Exit Function
    End If

    lConta = Format$(pConta, "000000000")


    '3. Calcula e verifica dï¿½gito.
    Set clsA99V001 = New clsA99V001
    Set clsA99V001.M46V999 = M46V999

    If clsA99V001.DIG_BANCOBRASIL(Left$(lConta, 8), lDigito, pMensagem) = False Then
        Exit Function
    End If
    Set clsA99V001 = Nothing

    If lDigito = "X" Then lDigito = "0"
    If lDigito <> Mid$(lConta, 9, 1) Then
        pMensagem = "FGE2077 - Dï¿½gito de conta corrente invï¿½lido (Banco do Brasil- " & pConta & ")."
'        'Ficha 900591
'        If M46V999.gTipoAcesso = DIGITACAO Then
'            MsgBox pMensagem, vbCritical
'            M46V999.gPodeEmitir = False
'            mfVerBancoBrasil = True
'            Exit Function
'        Else
            Exit Function
'        End If
    End If

    mfVerBancoBrasil = True
End Function

